@model IPagedList<AlignHR.Models.SalaryPeriod>
@using X.PagedList
@using X.PagedList.Mvc.Core
@using X.PagedList.Web.Common

@{
    ViewData["Title"] = "Salary Periods";
    ViewBag.ActivePage = "SalaryPeriods";
}

<section class="filter-bar mb-2" aria-label="Salary periods filters">
    <div class="input-group input-group-sm me-auto" style="width: auto;">
        <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input class="form-control"
               type="search"
               name="search"
               value="@Context.Request.Query["search"]"
               placeholder="Search period"
               aria-label="Search records"
               hx-get="@Url.Action("Index")"
               hx-target="#salaryperiods-index-page"
               hx-select="#salaryperiods-index-page"
               hx-trigger="keyup[key=='Enter'], search"
               hx-include="[name='search']"
               hx-push-url="true"
               form="none" />
    </div>
    <div class="filter-group">
        <div class="dropdown">
            <button class="btn btn-export-custom btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport">
                Columns
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Period Name" checked />Period Name</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Start Date" checked />Start Date</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="End Date" checked />End Date</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="EOBI Amount" />EOBI Amount</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Active" checked />Active</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Status" checked />Status</label></li>
            </ul>
        </div>
        <a class="btn btn-export-custom btn-sm" id="exportBtn" href="#"><i class="fa-solid fa-download me-1"></i>Export</a>
        <a class="btn btn-primary btn-sm" asp-action="Create"><i class="fa-solid fa-plus me-1"></i>Create</a>
    </div>
</section>

<section class="table-shell" data-erp-table id="salaryperiods-index-page">
    <div class="erp-table-wrap">
        <table class="table table-hover erp-table">
            <thead>
                <tr>
                    <th scope="col"><button class="table-sort" type="button" data-sort="0">Period Name</button></th>
                    <th scope="col">Start Date</th>
                    <th scope="col">End Date</th>
                    <th scope="col" style="display: none;">EOBI Amount</th>
                    <th scope="col">Active</th>
                    <th scope="col">Status</th>
                    <th scope="col" class="text-end sticky-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in Model)
                {
                    string pName = l.PeriodName;
                    if (!string.IsNullOrEmpty(pName) && pName.Contains("/"))
                    {
                        var p = pName.Split('/');
                        if (p.Length == 2) pName = $"{p[0]}-{p[1].PadLeft(2, '0')}";
                    }
                    <tr>
                        <td data-label="Period Name"><span class="fw-semibold">@pName</span></td>
                        <td data-label="Start Date">@l.StartDate.ToString("dd MMM yyyy")</td>
                        <td data-label="End Date">@l.EndDate.ToString("dd MMM yyyy")</td>
                        <td data-label="EOBI Amount" style="display: none;">@l.EOBIAmount?.ToString("N2")</td>
                        <td data-label="Active">
                            <span class="status-badge @(l.IsActive ? "status-active" : "status-risk")">@(l.IsActive ? "Yes" : "No")</span>
                        </td>
                        <td data-label="Status">
                            @if (l.IsProcessed)
                            {
                                <span class="status-badge status-approved">Processed</span>
                            }
                            else
                            {
                                <span class="status-badge status-pending">Open</span>
                            }
                            @if (l.IsPostedToGL)
                            {
                                <span class="status-badge status-active ms-1">Posted</span>
                            }
                        </td>
                        <td data-label="Actions" class="text-end sticky-actions">
                            <div class="d-flex justify-content-end gap-1">
                                @if (l.IsPostedToGL)
                                {
                                    <span class="btn btn-icon btn-sm btn-icon-info" title="Locked - Posted to GL" style="opacity:0.5; cursor:default;"><i class="fa-solid fa-lock"></i></span>
                                }
                                else
                                {
                                    <a class="btn btn-icon btn-sm btn-icon-primary" asp-action="Edit" asp-route-id="@l.SalaryPeriodID" title="Edit"><i class="fa-solid fa-pen-to-square"></i></a>
                                    <form asp-action="Delete" asp-route-id="@l.SalaryPeriodID" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this period?');">
                                        <button class="btn btn-icon btn-sm btn-icon-danger" type="submit" title="Delete"><i class="fa-solid fa-trash-can"></i></button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="empty-state" data-table-empty style="display: @(Model.Any() ? "none" : "block");">
            <i class="fa-solid fa-inbox"></i>
            <h3 class="h6 mt-2 mb-1">No records match the current filters</h3>
            <p class="text-muted mb-0">Adjust search or column criteria.</p>
        </div>
    </div>

    <div class="table-footer">
        <span class="text-muted small fw-semibold">Showing @Model.FirstItemOnPage-@Model.LastItemOnPage of @Model.TotalItemCount</span>
        <nav aria-label="Salary periods pagination">
            @Html.PagedListPager(Model, page => Url.Action("Index", new {
                page,
                search = Context.Request.Query["search"]
            }), new PagedListRenderOptions
            {
                UlElementClasses = new[] { "pagination", "pagination-sm", "mb-0" },
                LiElementClasses = new[] { "page-item" },
                PageClasses = new[] { "page-link" }
            })
        </nav>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
