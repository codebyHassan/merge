@model AlignHR.Models.HrRequisitionFormViewModel
@using AlignHR.Security

@{
    ViewData["Title"] = "Requisition — " + Model.RequisitionNo;
    ViewBag.ActivePage = "HrRequisitions";

    var statusClass = Model.Status switch
    {
        "Approved"  => "badge-success",
        "Submitted" => "badge-warning",
        "Rejected"  => "badge-danger",
        "Cancelled" => "badge-danger",
        _           => "badge-secondary"
    };
}

<style>
    .rec-label {
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: var(--ahr-text-tertiary);
    }
</style>

<div class="animate-fade-in">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show py-2 small" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show py-2 small" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ── Hero + specifications ── *@
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex flex-wrap align-items-start justify-content-between gap-3">
                <div>
                    <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                        <h1 class="h5 fw-bold mb-0 font-monospace">@(Model.RequisitionNo ?? "—")</h1>
                        <span class="status-badge @statusClass">@(Model.Status ?? "—")</span>
                    </div>
                    <div class="text-muted small">@(Model.PositionTitle ?? "—")</div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    @if (Model.RequisitionType == "Transfer" && Model.Status == "Approved" && Model.TransferEmployeeId.HasValue)
                    {
                        <button type="button" class="btn btn-success btn-sm"
                                data-bs-toggle="modal" data-bs-target="#confirmTransferModal">
                            Confirm Transfer
                        </button>
                    }
                    <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">Back</a>
                </div>
            </div>

            <hr class="my-3" />

            <div class="row g-3">
                <div class="col-6 col-md-3">
                    <div class="rec-label mb-1">Department</div>
                    <div class="small fw-medium">@(ViewBag.DepartmentName ?? "—")</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="rec-label mb-1">Type</div>
                    <div class="small fw-medium">@(Model.RequisitionType ?? "—")</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="rec-label mb-1">Nature</div>
                    <div class="small fw-medium">@(Model.Nature ?? "—")</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="rec-label mb-1">Budget / Month</div>
                    <div class="small fw-medium font-monospace">
                        @(Model.BudgetAmountPerMonth.HasValue ? Model.BudgetAmountPerMonth.Value.ToString("N0") : "—")
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="rec-label mb-1">Initial Date</div>
                    <div class="small fw-medium">@(Model.InitialDate?.ToString("dd MMM yyyy") ?? "—")</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="rec-label mb-1">Promised Date</div>
                    <div class="small fw-medium">@(Model.PromisedDate?.ToString("dd MMM yyyy") ?? "—")</div>
                </div>

                @if (Model.RequisitionType == "Replacement" && Model.ReplacementEmployeeId.HasValue)
                {
                    <div class="col-6 col-md-3">
                        <div class="rec-label mb-1">Replaced Employee</div>
                        <div class="small fw-medium">@(ViewBag.ReplacementEmployeeName ?? "—")</div>
                    </div>
                }
                else if (Model.RequisitionType == "Transfer")
                {
                    <div class="col-6 col-md-3">
                        <div class="rec-label mb-1">Employee</div>
                        <div class="small fw-medium">@(ViewBag.TransferEmployeeName ?? "—")</div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="rec-label mb-1">Transfer From</div>
                        <div class="small fw-medium">@(ViewBag.TransferFromDepartmentName ?? "—")</div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── Reason ── *@
    @if (!string.IsNullOrWhiteSpace(Model.Reason))
    {
        <div class="card mb-3">
            <div class="card-header">Reason / Justification</div>
            <div class="card-body">
                <div class="small" style="line-height:1.65;white-space:pre-wrap;">@Model.Reason</div>
            </div>
        </div>
    }

    @* ── Required Skills + Company Offerings ── *@
    @if (Model.Skills.Any() || Model.Offerings.Any())
    {
        <div class="row g-3">
            <div class="col-12 col-lg-6">
                <div class="card h-100">
                    <div class="card-header">Required Skills</div>
                    <div class="card-body">
                        @if (Model.Skills.Any())
                        {
                            <ol class="mb-0 ps-3">
                                @foreach (var skill in Model.Skills)
                                {
                                    <li class="small py-1">
                                        @skill.SkillName
                                        @if (skill.YearsExperience.HasValue)
                                        {
                                            <span class="text-muted"> — @(skill.YearsExperience.Value.ToString("0.#")) yr@(skill.YearsExperience.Value != 1 ? "s" : "")</span>
                                        }
                                        @if (!skill.IsMandatory)
                                        {
                                            <span class="text-muted"> (optional)</span>
                                        }
                                    </li>
                                }
                            </ol>
                        }
                        else
                        {
                            <div class="text-muted small">—</div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-6">
                <div class="card h-100">
                    <div class="card-header">Company Offerings</div>
                    <div class="card-body">
                        @if (Model.Offerings.Any())
                        {
                            <ol class="mb-0 ps-3">
                                @foreach (var offering in Model.Offerings)
                                {
                                    <li class="small py-1">
                                        @offering.OfferingName
                                        @if (!string.IsNullOrWhiteSpace(offering.Description))
                                        {
                                            <span class="text-muted"> — @offering.Description</span>
                                        }
                                    </li>
                                }
                            </ol>
                        }
                        else
                        {
                            <div class="text-muted small">—</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

</div>

@if (Model.RequisitionType == "Transfer" && Model.Status == "Approved" && Model.TransferEmployeeId.HasValue)
{
    <div class="modal fade" id="confirmTransferModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title h6 mb-0">Confirm Employee Transfer</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-action="ConfirmTransfer" asp-controller="HrRequisitions">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="requisitionId" value="@Model.Id" />
                    <div class="modal-body">
                        <p class="small mb-2">
                            Employee <strong>@(ViewBag.TransferEmployeeName ?? "—")</strong> will be moved
                            from <strong>@(ViewBag.TransferFromDepartmentName ?? "current department")</strong>
                            to <strong>@(ViewBag.DepartmentName ?? "—")</strong>.
                        </p>
                        <p class="small text-muted">
                            A history entry will be recorded automatically.
                        </p>
                        <div class="mb-1">
                            <label class="form-label">Effective Date</label>
                            <input type="date" name="effectiveDate" class="form-control form-control-sm"
                                   value="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")" required />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success btn-sm">Confirm Transfer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
