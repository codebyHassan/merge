@model List<AlignHR.Models.HrRecruiterInboxItemViewModel>

@{
    ViewData["Title"] = "Recruiter Head Inbox";
    ViewBag.ActivePage = "HrRecruitmentHead";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2 small" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2 small" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}

@if (ViewBag.NoUnit == true)
{
    <div class="form-shell w-100">
        <div class="card-inner text-center py-5">
            <i class="fa-solid fa-users-gear fa-2x text-muted mb-3"></i>
            <h5 class="text-muted">No recruitment unit assigned</h5>
            <p class="text-muted small">Your account is not configured as a Recruitment Head for any unit. Contact your administrator.</p>
        </div>
    </div>
}
else
{
    <section class="filter-bar mb-2" aria-label="Recruiter inbox actions">
        <div class="filter-group ms-auto">
            <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Requisitions</a>
        </div>
    </section>

    <section class="table-shell" data-erp-table>
        <div class="erp-table-wrap">
            <table class="table table-hover erp-table">
                <thead>
                    <tr>
                        <th>Req. No</th>
                        <th>Position</th>
                        <th>Department</th>
                        <th>Date</th>
                        <th>Recruiter</th>
                        <th>Assignment</th>
                        <th class="text-end sticky-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td data-label="Req. No">@item.RequisitionNo</td>
                            <td data-label="Position">@item.PositionTitle</td>
                            <td data-label="Department">@(item.DepartmentName ?? "—")</td>
                            <td data-label="Date">@(item.CreatedOn?.ToString("dd MMM yyyy") ?? "—")</td>
                            <td data-label="Recruiter">@(item.AssignedRecruiterName ?? "—")</td>
                            <td data-label="Assignment">
                                @if (item.IsAssigned)
                                {
                                    <span class="status-badge badge-success">Assigned</span>
                                }
                                else
                                {
                                    <span class="status-badge badge-secondary">Pending</span>
                                }
                            </td>
                            <td data-label="Actions" class="text-end sticky-actions">
                                <a class="btn btn-icon btn-sm btn-icon-secondary" title="View"
                                   asp-controller="HrRequisitions" asp-action="Details" asp-route-id="@item.RequisitionId">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                @if (!item.IsAssigned)
                                {
                                    <a class="btn btn-icon btn-sm btn-icon-success ms-1" title="Assign Recruiter"
                                       asp-controller="HrAssignments" asp-action="Assign" asp-route-requisitionId="@item.RequisitionId">
                                        <i class="fa-solid fa-user-check"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!Model.Any())
            {
                <div class="empty-state" data-table-empty>
                    <i class="fa-solid fa-inbox"></i>
                    <h3 class="h6 mt-2 mb-1">No approved requisitions</h3>
                    <p class="text-muted mb-0">There are no approved requisitions pending assignment in your departments.</p>
                </div>
            }
        </div>
    </section>
}
