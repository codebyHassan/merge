@model AlignHR.Models.Document
@{
    ViewData["Title"] = "Delete Document";
    ViewBag.ActivePage = "Documents";
}

<div class="form-shell w-100">
    <div class="card-inner">
        <form asp-action="Delete" method="post" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="DocumentID" />

            <div class="d-flex align-items-center gap-2 mb-4">
                <div style="width:40px;height:40px;border-radius:10px;background:rgba(220,53,69,.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="fa-solid fa-trash-can text-danger"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold">Confirm Delete</h6>
                    <p class="mb-0 small text-muted">This action cannot be undone.</p>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-12 col-md-3">
                    <label class="form-label small fw-semibold text-muted mb-0">Document No</label>
                    <div class="value fw-bold font-monospace">@Model.DocumentNo</div>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label small fw-semibold text-muted mb-0">Title</label>
                    <div class="value fw-semibold">@Model.Title</div>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label small fw-semibold text-muted mb-0">Employee</label>
                    <div class="value">@(Model.Employee?.FullName ?? "-")</div>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label small fw-semibold text-muted mb-0">File</label>
                    <div class="value">@Model.FileName</div>
                </div>
            </div>

            <div class="alert alert-danger d-flex align-items-center gap-2 py-2" role="alert">
                <i class="fa-solid fa-circle-exclamation flex-shrink-0"></i>
                <span class="small">The file will also be deleted from the server.</span>
            </div>

            <div class="row mt-4">
                <div class="col-12 d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-left"></i> Cancel</a>
                    <button type="submit" class="btn btn-danger btn-sm"><i class="fa-solid fa-trash-can"></i> Delete Document</button>
                </div>
            </div>
        </form>
    </div>
</div>
