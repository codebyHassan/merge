@model IPagedList<AlignHR.Models.Document>
@using X.PagedList
@using X.PagedList.Mvc.Core
@using X.PagedList.Web.Common

@{
    ViewData["Title"] = "Documents";
    ViewBag.ActivePage = "Documents";
    var currentFilter = ViewData["CurrentFilter"]?.ToString();
}

<section class="filter-bar mb-2" aria-label="Document filters">
    <div class="input-group input-group-sm me-auto" style="width: auto;">
        <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input class="form-control"
               type="search"
               name="searchQuery"
               value="@currentFilter"
               placeholder="Search by document no, title, or employee"
               aria-label="Search records"
               hx-get="@Url.Action("Index")"
               hx-target="#documents-index-page"
               hx-select="#documents-index-page"
               hx-trigger="keyup[key=='Enter'], search"
               hx-include="[name='searchQuery']"
               hx-push-url="true"
               form="none" />
    </div>
    <div class="filter-group">
        <div class="dropdown">
            <button class="btn btn-export-custom btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport">
                Columns
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="DocNo" checked />Doc No</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Title" checked />Title</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Employee" checked />Employee</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Category" checked />Category</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Status" checked />Status</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Date" checked />Upload Date</label></li>
            </ul>
        </div>
        <a class="btn btn-primary btn-sm" asp-action="Create"><i class="fa-solid fa-plus me-1"></i>Upload Document</a>
    </div>
</section>

<section class="table-shell" data-erp-table id="documents-index-page">
    <div class="erp-table-wrap">
        <table class="table table-hover erp-table">
            <thead>
                <tr>
                    <th scope="col"><button class="table-sort" type="button" data-sort="0">Doc No</button></th>
                    <th scope="col">Title</th>
                    <th scope="col">Employee</th>
                    <th scope="col">Category</th>
                    <th scope="col">Status</th>
                    <th scope="col">Upload Date</th>
                    <th scope="col" class="text-end sticky-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td data-label="Doc No"><span class="fw-semibold font-monospace">@item.DocumentNo</span></td>
                        <td data-label="Title">@item.Title</td>
                        <td data-label="Employee">@(item.Employee?.FullName ?? "-")</td>
                        <td data-label="Category">@(item.Category?.CategoryName ?? "-")</td>
                        <td data-label="Status"><span class="status-badge @(item.Status == "Active" ? "status-active" : item.Status == "Draft" ? "badge-secondary" : item.Status == "Expired" ? "status-risk" : "badge-warning")">@(item.Status ?? "Draft")</span></td>
                        <td data-label="Upload Date">@item.UploadDate.ToString("dd MMM yyyy")</td>
                        <td data-label="Actions" class="text-end sticky-actions">
                            <div class="d-flex justify-content-end gap-1">
                                @if (!string.IsNullOrEmpty(item.FilePath))
                                {
                                    <a class="btn btn-icon btn-sm btn-icon-primary" href="@item.FilePath" target="_blank" title="Download"><i class="fa-solid fa-download"></i></a>
                                }
                                <a class="btn btn-icon btn-sm btn-icon-primary" asp-action="Edit" asp-route-id="@item.DocumentID" title="Edit"><i class="fa-solid fa-pen-to-square"></i></a>
                                <form asp-action="Delete" asp-route-id="@item.DocumentID" method="post" class="d-inline"
                                      onsubmit="return confirm('Are you sure you want to delete this document?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-icon btn-sm btn-icon-danger" title="Delete">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="empty-state" data-table-empty>
                <i class="fa-solid fa-inbox"></i>
                <h3 class="h6 mt-2 mb-1">No records match the current filters</h3>
                <p class="text-muted mb-0">Adjust search or upload a new document.</p>
            </div>
        }
    </div>

    <div class="table-footer">
        <span class="text-muted small fw-semibold">Showing @Model.FirstItemOnPage-@Model.LastItemOnPage of @Model.TotalItemCount</span>
        <nav aria-label="Documents pagination">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page, searchQuery = currentFilter }), new PagedListRenderOptions
            {
                UlElementClasses = new[] { "pagination", "pagination-sm", "mb-0" },
                LiElementClasses = new[] { "page-item" },
                PageClasses = new[] { "page-link" }
            })
        </nav>
    </div>
</section>
