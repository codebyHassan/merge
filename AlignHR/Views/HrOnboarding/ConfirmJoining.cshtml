@model AlignHR.Models.HrJoiningConfirmationFormViewModel

@{
    ViewData["Title"] = "Confirm Joining";
    ViewBag.ActivePage = "HrOnboarding";
}

<div class="form-shell w-100 animate-fade-in">
    <div class="card-inner">
        <div class="mb-3 small text-muted">
            Candidate: <strong>@(Model.CandidateName ?? "—")</strong>
            @if (!string.IsNullOrEmpty(Model.JobTitle)) { <span>· @Model.JobTitle</span> }
        </div>

        <div class="alert alert-info py-2 small mb-3">
            <i class="fa-solid fa-circle-info me-1"></i>
            Confirming joining will <strong>create an Employee record and User account</strong>
            for this candidate. This action cannot be undone.
        </div>

        <form asp-action="ConfirmJoining" method="post" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="OnboardingId" />
            <input type="hidden" asp-for="CandidateName" />
            <input type="hidden" asp-for="JobTitle" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger p-2 mb-3 small">
                    <div asp-validation-summary="ModelOnly"></div>
                </div>
            }

            <div class="fw-semibold small mb-2 text-muted">Joining Details</div>
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-4">
                    <label asp-for="JoinedDate" class="form-label small fw-semibold">Actual Joining Date <span class="text-danger">*</span></label>
                    <input asp-for="JoinedDate" type="date" class="form-control form-control-sm" required />
                    <span asp-validation-for="JoinedDate" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Remarks" class="form-label small fw-semibold">Remarks</label>
                    <textarea asp-for="Remarks" class="form-control form-control-sm" rows="2"
                              placeholder="Any notes about the joining…"></textarea>
                </div>
            </div>

            <hr class="my-3 opacity-25" />
            <div class="fw-semibold small mb-2 text-muted">Employee Record — Required Fields</div>
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label asp-for="DepartmentFk" class="form-label small fw-semibold">Department <span class="text-danger">*</span></label>
                    <select asp-for="DepartmentFk" asp-items="ViewBag.Departments"
                            class="form-select form-select-sm" required>
                        <option value="">— Select Department —</option>
                    </select>
                    <span asp-validation-for="DepartmentFk" class="text-danger small"></span>
                </div>
                <div class="col-12 col-md-4">
                    <label asp-for="LocationFk" class="form-label small fw-semibold">Location <span class="text-danger">*</span></label>
                    <select asp-for="LocationFk" asp-items="ViewBag.Locations"
                            class="form-select form-select-sm" required>
                        <option value="">— Select Location —</option>
                    </select>
                    <span asp-validation-for="LocationFk" class="text-danger small"></span>
                </div>
                <div class="col-12 col-md-3">
                    <label asp-for="NTN" class="form-label small fw-semibold">NTN (Tax Number)</label>
                    <input asp-for="NTN" class="form-control form-control-sm" placeholder="e.g. 1234567-8" />
                </div>
                <div class="col-12 col-md-2 d-flex align-items-end">
                    <div class="form-check mb-1">
                        <input asp-for="IsFiler" type="checkbox" class="form-check-input" />
                        <label asp-for="IsFiler" class="form-check-label small">Tax Filer</label>
                    </div>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-12 d-flex justify-content-end gap-2">
                    <a asp-action="Details" asp-route-id="@Model.OnboardingId"
                       class="btn btn-outline-secondary btn-sm">Cancel</a>
                    <button type="submit" class="btn btn-success btn-sm">
                        <i class="fa-solid fa-user-plus me-1"></i>Confirm & Create Employee
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
