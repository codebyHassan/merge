@model IPagedList<AlignHR.Models.LeaveBalance>
@using X.PagedList
@using X.PagedList.Mvc.Core

@{
    ViewData["Title"] = "Leave Balances";
    ViewBag.ActivePage = "LeaveBalances";
}

<div class="page-header">
    <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <span>Leave Balances</span>
    </div>

    <div class="page-header-row">
        <div>
            <h1 class="page-title">Employee Leave Balances</h1>
            <p class="page-subtitle">Track and manage leave allocations, usage, and availability</p>
        </div>

        <div class="flex gap-8">
            <a class="btn btn-primary btn-sm" asp-action="Create">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
                Add Balance
            </a>
        </div>
    </div>
</div>

<div class="table-shell">
    <div class="table-toolbar">
        <div class="table-card-title">All Balances (@Model.TotalItemCount)</div>

        <div class="table-filters">
            <form method="get" asp-action="Index" onsubmit="return false;" style="display: flex; align-items: center; gap: 8px;">
                <div style="position: relative; width: 100%;">
                    <input type="text" name="searchQuery" class="filter-input form-control" placeholder="Search by employee or leave type..." value="@ViewData["CurrentFilter"]"
                           hx-get="@Url.Action("Index")"
                           hx-target="#table-container"
                           hx-select="#table-container"
                           hx-indicator="#search-loader"
                           hx-trigger="keyup changed delay:500ms, search" />
                    <span id="search-loader" class="htmx-indicator" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%);">
                        <div class="search-loader"></div>
                    </span>
                </div>
            </form>
        </div>
    </div>

    <div id="table-container">
        <div class="erp-table-wrap">
            <table class="table table-hover erp-table">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Leave Type</th>
                        <th>Year</th>
                        <th>Allocated</th>
                        <th>Used</th>
                        <th>Pending</th>
                        <th>C/F</th>
                        <th>Available</th>
                        <th>Updated</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="flex flex-column">
                                        <span class="font-medium text-dark">@item.Employee?.FullName</span>
                                        <span class="text-muted small">ID: @item.Employee?.Id</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="status-badge active" style="background: var(--bg-surface); color: var(--text-main); border: 1px solid var(--border-light);">
                                        @item.LeaveType?.Code
                                    </span>
                                </td>
                                <td>@item.Year</td>
                                <td class="font-medium">@item.Allocated</td>
                                <td class="text-danger">@item.Used</td>
                                <td class="text-warning">@item.Pending</td>
                                <td>@item.CarriedForward</td>
                                <td>
                                    <span class="status-badge @(item.Available > 0 ? "active" : "inactive")">
                                        @item.Available
                                    </span>
                                </td>
                                <td class="text-muted small">@item.UpdatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="table-actions">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-icon btn-sm" title="Edit">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                            </svg>
                                        </a>

                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-icon btn-sm success" title="Details">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z" />
                                                <circle cx="12" cy="12" r="3" />
                                            </svg>
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-icon btn-sm text-danger" title="Delete">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <polyline points="3 6 5 6 21 6" />
                                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                            </svg>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="text-center py-5 text-muted">
                                No leave balances found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.PageCount > 1)
        {
            <div class="pagination-wrapper mt-4 d-flex flex-column align-items-center gap-3">
                <div class="text-muted small">
                    Showing page @Model.PageNumber of @Model.PageCount
                </div>
                @Html.PagedListPager(Model, page => Url.Action("Index", new { page, searchQuery = ViewData["CurrentFilter"] }),
                new X.PagedList.Web.Common.PagedListRenderOptions
                {
                    DisplayLinkToFirstPage = X.PagedList.Web.Common.PagedListDisplayMode.IfNeeded,
                    DisplayLinkToLastPage = X.PagedList.Web.Common.PagedListDisplayMode.IfNeeded,
                    DisplayLinkToPreviousPage = X.PagedList.Web.Common.PagedListDisplayMode.Always,
                    DisplayLinkToNextPage = X.PagedList.Web.Common.PagedListDisplayMode.Always,
                    MaximumPageNumbersToDisplay = 5,
                    ContainerDivClasses = new[] { "pagination pagination-sm m-0" },
                    UlElementClasses = new[] { "pagination" },
                    LiElementClasses = new[] { "page-item" },
                    PageClasses = new[] { "page-link" }
                })
            </div>
        }
    </div>
</div>
