@model AlignHR.Models.LeaveBalance

@{
    ViewData["Title"] = "Leave Balance Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header animate-fade">
    <div>
        <h1 class="page-title">Balance Details</h1>
        <p class="page-subtitle">Detailed view of leave allocation for @Model.Employee?.FullName</p>
    </div>
    <div class="flex gap-8">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;margin-right:8px">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
            </svg>
            Edit Balance
        </a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>

<div class="animate-fade" style="animation-delay: 0.1s">
    <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 24px;">
        
        <!-- Left Column: Employee Info -->
        <div class="hr-card" style="margin-bottom:0;">
            <div class="card-header">
                <div class="card-title"><i class="fas fa-user"></i> Employee Information</div>
            </div>
            <div class="card-body">
                <div class="flex flex-column gap-16">
                    <div class="detail-item">
                        <label class="detail-label">Full Name</label>
                        <div class="detail-value font-medium">@Model.Employee?.FullName</div>
                    </div>
                    <div class="detail-item">
                        <label class="detail-label">Employee ID</label>
                        <div class="detail-value">@Model.Employee?.Id</div>
                    </div>
                    <div class="detail-item">
                        <label class="detail-label">Leave Type</label>
                        <div class="detail-value">
                            <span class="status-badge active">@Model.LeaveType?.Code - @Model.LeaveType?.Name</span>
                        </div>
                    </div>
                    <div class="detail-item">
                        <label class="detail-label">Fiscal Year</label>
                        <div class="detail-value">@Model.Year</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Balance Summary -->
        <div class="hr-card" style="margin-bottom:0;">
            <div class="card-header">
                <div class="card-title"><i class="fas fa-chart-pie"></i> Balance Summary</div>
            </div>
            <div class="card-body">
                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-bottom: 32px;">
                    <div class="summary-stat">
                        <div class="text-muted small mb-1">Total Entitlement</div>
                        <div class="h3 mb-0 font-bold">@(Model.Allocated + Model.CarriedForward)</div>
                        <div class="text-muted smallest">(@Model.Allocated + @Model.CarriedForward C/F)</div>
                    </div>
                    <div class="summary-stat">
                        <div class="text-muted small mb-1">Total Deductions</div>
                        <div class="h3 mb-0 font-bold text-danger">@(Model.Used + Model.Pending)</div>
                        <div class="text-muted smallest">(@Model.Used Used + @Model.Pending Pending)</div>
                    </div>
                    <div class="summary-stat">
                        <div class="text-muted small mb-1">Available</div>
                        <div class="h3 mb-0 font-bold text-success">@Model.Available</div>
                        <div class="text-muted smallest">Ready to use</div>
                    </div>
                </div>

                <div class="erp-table-wrap" style="border: 1px solid var(--border-light); border-radius: 8px;">
                    <table class="table table-hover erp-table mb-0">
                        <thead>
                            <tr>
                                <th>Category</th>
                                <th>Value</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Allocated</td>
                                <td class="font-medium">@Model.Allocated</td>
                                <td class="text-muted small">Standard leaves given for the year</td>
                            </tr>
                            <tr>
                                <td>Carried Forward</td>
                                <td class="font-medium">@Model.CarriedForward</td>
                                <td class="text-muted small">Leaves from previous year</td>
                            </tr>
                            <tr>
                                <td>Used</td>
                                <td class="text-danger">@Model.Used</td>
                                <td class="text-muted small">Approved and taken leaves</td>
                            </tr>
                            <tr>
                                <td>Pending</td>
                                <td class="text-warning">@Model.Pending</td>
                                <td class="text-muted small">Applied but not yet approved</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="mt-4 pt-3 border-top text-muted small">
                    Last updated: @Model.UpdatedAt.ToString("F")
                </div>
            </div>
        </div>
    </div>
</div>
