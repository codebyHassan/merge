@model AlignHR.Models.Department
@{
    ViewData["Title"] = "Department Details";
    ViewBag.ActivePage = "Departments";
}

<div class="form-shell w-100 animate-fade-in">
    <div class="card-inner">
        <div class="row g-3">
            <div class="col-12 col-md-3">
                <label class="form-label small fw-semibold text-muted mb-0">Department Code</label>
                <div class="value fw-semibold text-primary">@Model.Code</div>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label small fw-semibold text-muted mb-0">Department Name</label>
                <div class="value fw-bold">@Model.Name</div>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label small fw-semibold text-muted mb-0">Department Owner</label>
                <div class="value">@Model.Owner</div>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label small fw-semibold text-muted mb-0">Owner Role</label>
                <div class="value">@(Model.Role ?? "—")</div>
            </div>

            <div class="col-12">
                <label class="form-label small fw-semibold text-muted mb-0">Description</label>
                <div class="value">@(Model.Description ?? "—")</div>
            </div>
        </div>

        <hr class="my-4 text-muted opacity-25" />

        <!-- Audit Row -->
        <div class="row g-3">
            <div class="col-12 col-md-3">
                <label class="form-label small fw-semibold text-muted mb-0">Created At</label>
                <div class="value small">@Model.createat.ToString("dd MMM yyyy HH:mm:ss")</div>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label small fw-semibold text-muted mb-0">Created By</label>
                <div class="value small">@Model.createdby</div>
            </div>
            @if (Model.updateat > DateTime.MinValue)
            {
                <div class="col-12 col-md-3">
                    <label class="form-label small fw-semibold text-muted mb-0">Updated At</label>
                    <div class="value small">@Model.updateat.ToString("dd MMM yyyy HH:mm:ss")</div>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label small fw-semibold text-muted mb-0">Updated By</label>
                    <div class="value small">@Model.updatedby</div>
                </div>
            }
        </div>

        <!-- Action Buttons -->
        <div class="row mt-4">
            <div class="col-12 d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back</a>
            </div>
        </div>
    </div>
</div>
