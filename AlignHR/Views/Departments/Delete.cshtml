@model AlignHR.Models.Department
@{
    ViewData["Title"] = "Delete Department";
    ViewBag.ActivePage = "Departments";
}

<div class="form-shell w-100">
    <div class="card-inner">
        <form asp-action="Delete" method="post" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="d-flex align-items-center gap-2 mb-4">
                <div style="width:40px;height:40px;border-radius:10px;background:rgba(220,53,69,.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="fa-solid fa-trash-can text-danger"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold">Confirm Delete</h6>
                    <p class="mb-0 small text-muted">This action cannot be undone.</p>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-12 col-md-3">
                    <label class="form-label small fw-semibold text-muted mb-0">Code</label>
                    <div class="value fw-semibold text-primary">@Model.Code</div>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label small fw-semibold text-muted mb-0">Name</label>
                    <div class="value fw-bold">@Model.Name</div>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label small fw-semibold text-muted mb-0">Owner</label>
                    <div class="value">@Model.Owner</div>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label small fw-semibold text-muted mb-0">Role</label>
                    <div class="value">@(Model.Role ?? "-")</div>
                </div>
            </div>

            <div class="alert alert-danger d-flex align-items-center gap-2 py-2" role="alert">
                <i class="fa-solid fa-circle-exclamation flex-shrink-0"></i>
                <span class="small">Deleting this department may affect linked employees and records.</span>
            </div>

            <div class="row mt-4">
                <div class="col-12 d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-left"></i> Cancel</a>
                    <button type="submit" class="btn btn-danger btn-sm"><i class="fa-solid fa-trash-can"></i> Delete Department</button>
                </div>
            </div>
        </form>
    </div>
</div>

