@model IPagedList<AlignHR.Models.PayRollDefinationFile>
@using X.PagedList
@using X.PagedList.Mvc.Core
@using X.PagedList.Web.Common

@{
    ViewData["Title"] = "Salary Structures";
    ViewBag.ActivePage = "PayRollDefinationFile";
}

<section class="filter-bar mb-2" aria-label="Salary structures filters">
    <div class="input-group input-group-sm me-auto" style="width: auto;">
        <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input class="form-control"
               type="search"
               name="search"
               value="@Context.Request.Query["search"]"
               placeholder="Search structure"
               aria-label="Search records"
               hx-get="@Url.Action("Index")"
               hx-target="#structure-index-page"
               hx-select="#structure-index-page"
               hx-trigger="keyup[key=='Enter'], search"
               hx-include="[name='search']"
               hx-push-url="true"
               form="none" />
    </div>
    <div class="filter-group">
        <div class="dropdown">
            <button class="btn btn-export-custom btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport">
                Columns
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Definition Name" checked />Definition Name</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Created At" checked />Created At</label></li>
            </ul>
        </div>
        <a class="btn btn-export-custom btn-sm" id="exportBtn" href="#"><i class="fa-solid fa-download me-1"></i>Export</a>
        <a class="btn btn-primary btn-sm" asp-action="Create"><i class="fa-solid fa-plus me-1"></i>Create</a>
    </div>
</section>

<section class="table-shell" data-erp-table id="structure-index-page">
    <div class="erp-table-wrap">
        <table class="table table-hover erp-table">
            <thead>
                <tr>
                    <th scope="col"><button class="table-sort" type="button" data-sort="0">Definition Name</button></th>
                    <th scope="col"><button class="table-sort" type="button" data-sort="1">Created At</button></th>
                    <th scope="col" class="text-end sticky-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in Model)
                {
                    <tr>
                        <td data-label="Definition Name"><span class="fw-semibold">@l.DefinitionName</span></td>
                        <td data-label="Created At">@l.createat.ToString("MMM dd, yyyy")</td>
                        <td data-label="Actions" class="text-end sticky-actions">
                            <div class="d-flex justify-content-end gap-1">
                                <a class="btn btn-icon btn-sm btn-icon-primary" asp-action="Edit" asp-route-name="@l.DefinitionName" title="Edit"><i class="fa-solid fa-pen-to-square"></i></a>
                                <form asp-action="Delete" asp-route-DefinitionName="@l.DefinitionName" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this entire Salary Structure?');">
                                    <button class="btn btn-icon btn-sm btn-icon-danger" type="submit" title="Delete"><i class="fa-solid fa-trash-can"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="empty-state" data-table-empty style="display: @(Model.Any() ? "none" : "block");">
            <i class="fa-solid fa-inbox"></i>
            <h3 class="h6 mt-2 mb-1">No records match the current filters</h3>
            <p class="text-muted mb-0">Adjust search, filters, or column criteria.</p>
        </div>
    </div>

    <div class="table-footer">
        <span class="text-muted small fw-semibold">Showing @Model.FirstItemOnPage-@Model.LastItemOnPage of @Model.TotalItemCount</span>
        <nav aria-label="Salary structures pagination">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { 
                page, 
                search = Context.Request.Query["search"]
            }), new PagedListRenderOptions
            {
                UlElementClasses = new[] { "pagination", "pagination-sm", "mb-0" },
                LiElementClasses = new[] { "page-item" },
                PageClasses = new[] { "page-link" }
            })
        </nav>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
