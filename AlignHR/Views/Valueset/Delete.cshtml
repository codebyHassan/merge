@model AlignHR.Models.Valueset
@{
    ViewData["Title"] = "Valuesets - Delete";
    ViewBag.ActivePage = "valueset";
}
<div class="page-section">

    <div class="page-header">
        <div class="breadcrumb">
            <a href="/">Dashboard</a>
            <span>/</span>
            <a asp-action="Index">Valuesets</a>
            <span>/</span>
            <span>Delete</span>
        </div>
    </div>

    <div class="form-card">
        <div class="form-card-header">
            <div class="form-card-title">Delete Confirmation</div>
            <div style="color: #7f1d1d; font-size: 14px; margin-top: 8px;">
                Are you sure you want to delete this valueset? This action cannot be undone and may affect records referencing it.
            </div>
        </div>

        <div class="info-list">
            <div class="info-item">
                <span class="info-label">ID:</span>
                <span class="info-value">@Model.Id</span>
            </div>
            <div class="info-item">
                <span class="info-label">GroupName:</span>
                <span class="info-value">@Model.GroupName</span>
            </div>
            <div class="info-item">
                <span class="info-label">Name:</span>
                <span class="info-value">@Model.Name</span>
            </div>
            <div class="info-item">
                <span class="info-label">Status:</span>
                <span class="info-value">@(Model.IsActive ? "Active" : "Inactive")</span>
            </div>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="flex gap-12" style="justify-content: flex-end;">
                <a class="btn btn-secondary" asp-action="Index">Cancel</a>
                <button type="submit" class="btn" style="background-color: #ef4444; color: white;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 16px; height: 16px; margin-right: 6px;">
                        <polyline points="3 6 5 6 21 6" />
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                    </svg>
                    Confirm Delete
                </button>
            </div>
        </form>
    </div>
</div>
