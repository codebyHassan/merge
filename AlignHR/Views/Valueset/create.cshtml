@model AlignHR.Models.Valueset
@{
    ViewData["Title"] = "Create Value Set";
    ViewBag.ActivePage = "valueset";
}

<div class="form-shell w-100 animate-fade-in">
    <div class="card-inner">
        <form method="post" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 mb-3 small" role="alert"></div>

            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label asp-for="GroupName" class="form-label small fw-semibold">Group Name <span class="text-danger">*</span></label>
                    <input asp-for="GroupName" class="form-control form-control-sm" placeholder="e.g. EmploymentType" required />
                    <span asp-validation-for="GroupName" class="text-danger small"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="Name" class="form-label small fw-semibold">Name <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control form-control-sm" placeholder="e.g. Full Time" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <div class="form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" id="isActiveToggle" />
                        <label class="form-check-label small fw-semibold" for="isActiveToggle">Active</label>
                    </div>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-12 d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back</a>
                    <button type="submit" class="btn btn-primary btn-sm">Save Value Set</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
