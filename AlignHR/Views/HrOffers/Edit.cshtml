@model AlignHR.Models.HrOfferFormViewModel

@{
    ViewData["Title"] = "Edit Offer — " + Model.OfferNumber;
    ViewBag.ActivePage = "HrOffers";

}

<div class="form-shell w-100 animate-fade-in">
    <div class="card-inner">

        <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
                <div style="font-size:13px;font-weight:600;color:var(--ahr-text);">@Model.OfferNumber</div>
                <div class="small text-muted mt-1">@Model.CandidateName · @Model.JobTitle</div>
            </div>
            <span class="status-badge badge-secondary">Draft</span>
        </div>

        <form asp-action="Edit" method="post" class="needs-validation" novalidate id="offerForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ApplicationFk" />
            <input type="hidden" asp-for="OfferNumber" />
            <input type="hidden" asp-for="CandidateName" />
            <input type="hidden" asp-for="JobTitle" />

            @{
                var _me = ViewData.ModelState.ContainsKey("") ? ViewData.ModelState[""]!.Errors : null;
            }
            @if (_me != null && _me.Count > 0)
            {
                <div class="alert alert-danger p-2 mb-3 small">
                    @foreach (var e in _me) { <div>@e.ErrorMessage</div> }
                </div>
            }

            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label asp-for="ProposedSalary" class="form-label small fw-semibold">
                        Proposed Salary <span class="text-danger">*</span>
                    </label>
                    <input asp-for="ProposedSalary" type="number" step="any" min="0"
                           class="form-control form-control-sm" />
                    <span asp-validation-for="ProposedSalary" class="invalid-feedback"></span>
                </div>
                <div class="col-12 col-md-4">
                    <label asp-for="ExpiryDate" class="form-label small fw-semibold">Offer Expiry Date</label>
                    <input asp-for="ExpiryDate" type="date" class="form-control form-control-sm" />
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="Remarks" class="form-label small fw-semibold">Remarks</label>
                    <textarea asp-for="Remarks" class="form-control form-control-sm" rows="5"
                              placeholder="Reason for change or additional notes…"></textarea>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="Notes" class="form-label small fw-semibold">Offer Notes</label>
                    <textarea asp-for="Notes" class="form-control form-control-sm" rows="5"
                              placeholder="Type offer terms, benefits, conditions…"></textarea>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-12 d-flex justify-content-end gap-2">
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">Cancel</a>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-check me-1"></i>Save Changes
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
