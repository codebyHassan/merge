@{
    ViewData["Title"] = "Settings";
    ViewBag.ActivePage = "Settings";
}

<div class="page-header"><div class="breadcrumb"><a href="#">Home</a><span>/</span><span>Settings</span></div><div class="page-header-row"><div><h1 class="page-title">Settings</h1><p class="page-subtitle">Configure system preferences</p></div></div></div>

<div class="settings-grid">
    <div class="settings-nav">
        <div class="settings-nav-item active" onclick="switchSettingsTab(this)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg><span>Company Profile</span></div>
        <div class="settings-nav-item" onclick="switchSettingsTab(this)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg><span>Salary Policies</span></div>
        <div class="settings-nav-item" onclick="switchSettingsTab(this)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg><span>Notifications</span></div>
    </div>
    <div class="settings-panel">
        <div class="settings-section">
            <h3 class="settings-section-title">Company Profile</h3><p class="settings-section-desc">Update organization information</p>
            <div class="form-row"><div class="form-group"><label class="form-label">Company Name</label><input class="form-input" value="TechCorp Solutions Pvt. Ltd." type="text"></div><div class="form-group"><label class="form-label">Email</label><input class="form-input" value="admin@techcorp.com" type="email"></div></div>
            <div class="form-row"><div class="form-group"><label class="form-label">Phone</label><input class="form-input" value="+91 98765 43210" type="tel"></div><div class="form-group"><label class="form-label">Website</label><input class="form-input" value="https://techcorp.com" type="url"></div></div>
        </div>
        <div class="settings-section">
            <h3 class="settings-section-title">Notifications</h3><p class="settings-section-desc">Configure alert preferences</p>
            <div class="toggle-row"><div class="toggle-info"><h4>Email Notifications</h4><p>Payroll and attendance alerts via email</p></div><div class="toggle-switch active" onclick="this.classList.toggle('active')"></div></div>
            <div class="toggle-row"><div class="toggle-info"><h4>Late Attendance Alerts</h4><p>Notify when employees are late</p></div><div class="toggle-switch active" onclick="this.classList.toggle('active')"></div></div>
            <div class="toggle-row"><div class="toggle-info"><h4>Leave Request Alerts</h4><p>New leave request notifications</p></div><div class="toggle-switch" onclick="this.classList.toggle('active')"></div></div>
        </div>
        <div style="display:flex;gap:10px;justify-content:flex-end"><button class="btn btn-secondary">Cancel</button><button class="btn btn-primary">Save Changes</button></div>
    </div>
</div>
