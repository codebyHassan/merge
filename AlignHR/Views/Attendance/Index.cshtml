@{
    ViewData["Title"] = "Attendance";
    ViewBag.ActivePage = "Attendance";
}

<div class="page-header"><div class="breadcrumb"><a href="#">Home</a><span>/</span><span>Attendance</span></div><div class="page-header-row"><div><h1 class="page-title">Attendance Management</h1><p class="page-subtitle">Track and manage daily employee attendance</p></div><div class="flex gap-8">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" style="padding: 10px; background: #d4edda; color: #155724; border-radius: 4px;">@TempData["SuccessMessage"]</div>
    }
    <form asp-action="Synchronize" method="post" style="display:inline;">
        <button type="submit" class="btn btn-secondary btn-sm">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M23 4v6h-6" />
                <path d="M1 20v-6h6" />
                <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15" />
            </svg>
            Synchronize Logs
        </button>
    </form>
    <button class="btn btn-primary btn-sm"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Mark Attendance</button></div></div></div>

<div class="stats-grid" style="grid-template-columns:repeat(4,1fr)">
    <div class="stat-card green"><div class="stat-card-header"><div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div></div><div class="stat-value">213</div><div class="stat-label">Present</div><div class="progress-bar-custom"><div class="progress-fill green" style="width:85.9%"></div></div></div>
    <div class="stat-card red"><div class="stat-card-header"><div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg></div></div><div class="stat-value">18</div><div class="stat-label">Absent</div><div class="progress-bar-custom"><div class="progress-fill red" style="width:7.3%"></div></div></div>
    <div class="stat-card orange"><div class="stat-card-header"><div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div></div><div class="stat-value">12</div><div class="stat-label">Late</div><div class="progress-bar-custom"><div class="progress-fill orange" style="width:4.8%"></div></div></div>
    <div class="stat-card purple"><div class="stat-card-header"><div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div></div><div class="stat-value">17</div><div class="stat-label">On Leave</div><div class="progress-bar-custom"><div class="progress-fill blue" style="width:6.8%"></div></div></div>
</div>

<div class="charts-grid">
    <div class="chart-card"><div class="chart-card-header"><div><div class="chart-card-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>January 2025</div><div class="chart-card-subtitle">Monthly calendar</div></div></div><div class="calendar-grid" id="attendanceCalendar"></div></div>
    <div class="chart-card"><div class="chart-card-header"><div><div class="chart-card-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>Attendance Rate</div></div></div><div style="padding:20px;text-align:center"><div style="font-size:72px;font-weight:900;background:linear-gradient(135deg,var(--green),#10B981);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:-3px">85.9%</div><p style="color:var(--text-muted);margin:8px 0 24px">Overall attendance rate</p><div style="text-align:left"><div style="display:flex;justify-content:space-between;margin-bottom:10px;font-size:13px"><span>Present</span><span style="font-weight:700;color:var(--green)">85.9%</span></div><div class="progress-bar-custom" style="margin-bottom:18px"><div class="progress-fill green" style="width:85.9%"></div></div><div style="display:flex;justify-content:space-between;margin-bottom:10px;font-size:13px"><span>Late</span><span style="font-weight:700;color:var(--orange)">4.8%</span></div><div class="progress-bar-custom" style="margin-bottom:18px"><div class="progress-fill orange" style="width:4.8%"></div></div><div style="display:flex;justify-content:space-between;margin-bottom:10px;font-size:13px"><span>Absent</span><span style="font-weight:700;color:var(--red)">7.3%</span></div><div class="progress-bar-custom"><div class="progress-fill red" style="width:7.3%"></div></div></div></div></div>
</div>
