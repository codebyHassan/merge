@model IEnumerable<AlignHR.Models.LeaveConfiguration>

@{
    ViewData["Title"] = "Leave Configuration";
    ViewBag.ActivePage = "LeaveConfigurations";
    var currentFilter = ViewData["CurrentFilter"]?.ToString();
    var totalCount = Model.Count();
    var hasConfiguration = (bool?)(ViewBag.HasConfiguration) ?? false;
}

<section class="filter-bar mb-2" aria-label="Leave configuration filters">
    <div class="input-group input-group-sm me-auto" style="width: auto;">
        <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input class="form-control"
               type="search"
               name="searchQuery"
               value="@currentFilter"
               placeholder="Search configuration"
               aria-label="Search records"
               hx-get="@Url.Action("Index")"
               hx-target="#leave-configurations-index-page"
               hx-select="#leave-configurations-index-page"
               hx-trigger="keyup[key=='Enter'], search"
               hx-include="[name='searchQuery']"
               hx-push-url="true"
               form="none" />
    </div>
    <div class="filter-group">
        <div class="dropdown">
            <button class="btn btn-export-custom btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport">
                Columns
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Grouping Type" checked />Grouping Type</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Mappings" checked />Mappings</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Status" checked />Status</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Created" checked />Created</label></li>
            </ul>
        </div>
        @if (!hasConfiguration)
        {
            <a class="btn btn-primary btn-sm" asp-action="Create"><i class="fa-solid fa-plus me-1"></i>Create</a>
        }
    </div>
</section>

<section class="table-shell" data-erp-table id="leave-configurations-index-page">
    <div class="erp-table-wrap">
        <table class="table table-hover erp-table">
            <thead>
                <tr>
                    <th scope="col"><button class="table-sort" type="button" data-sort="1">Grouping Type</button></th>
                    <th scope="col">Mappings</th>
                    <th scope="col">Status</th>
                    <th scope="col">Created</th>
                    <th scope="col" class="text-end sticky-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td data-label="Grouping Type">
                            <div class="d-flex align-items-center gap-2">
                                @if (item.IsDepartment)
                                {
                                    <i class="fa-solid fa-building text-muted"></i>
                                }
                                else if (item.IsGrade)
                                {
                                    <i class="fa-solid fa-layer-group text-muted"></i>
                                }
                                else if (item.IsDivision)
                                {
                                    <i class="fa-solid fa-sitemap text-muted"></i>
                                }
                                else
                                {
                                    <i class="fa-solid fa-route text-muted"></i>
                                }
                                <span>@item.GroupingType</span>
                            </div>
                        </td>
                        <td data-label="Mappings"><span class="status-badge badge-warning">@item.Details.Count mappings</span></td>
                        <td data-label="Status"><span class="status-badge @(item.IsActive ? "status-active" : "status-risk")">@(item.IsActive ? "Active" : "Inactive")</span></td>
                        <td data-label="Created">@item.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td data-label="Actions" class="text-end sticky-actions">
                            <div class="d-flex justify-content-end gap-1">
                                <a class="btn btn-icon btn-sm btn-icon-primary" asp-action="Edit" asp-route-id="@item.Id" title="Edit"><i class="fa-solid fa-pen-to-square"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="empty-state" data-table-empty>
                <i class="fa-solid fa-inbox"></i>
                <h3 class="h6 mt-2 mb-1">No records match the current filters</h3>
                <p class="text-muted mb-0">Adjust search or create a new configuration.</p>
            </div>
        }
    </div>

    <div class="table-footer">
        <span class="text-muted small fw-semibold">Showing @totalCount configuration(s)</span>
    </div>
</section>
