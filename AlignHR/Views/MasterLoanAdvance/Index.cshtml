@model IPagedList<AlignHR.Models.MasterLoanAdvance>
@using X.PagedList
@using X.PagedList.Mvc.Core
@using X.PagedList.Web.Common

@{
    ViewData["Title"] = "Loan & Advance";
    ViewBag.ActivePage = "MasterLoanAdvance";
}

<section class="filter-bar mb-2" aria-label="Loan & advance filters">
    <div class="input-group input-group-sm me-auto" style="width: auto;">
        <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input class="form-control"
               type="search"
               name="search"
               value="@Context.Request.Query["search"]"
               placeholder="Search employee"
               aria-label="Search records"
               hx-get="@Url.Action("Index")"
               hx-target="#loan-index-page"
               hx-select="#loan-index-page"
               hx-trigger="keyup[key=='Enter'], search"
               hx-include="[name='search']"
               hx-push-url="true"
               form="none" />
    </div>
    <div class="filter-group">
        <div class="dropdown">
            <button class="btn btn-export-custom btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport">
                Columns
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Employee" checked />Employee</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Type" checked />Type</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Date" checked />Date</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Amount" checked />Amount</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Status" checked />Status</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Deduction" checked />Deduction</label></li>
            </ul>
        </div>
        <a class="btn btn-export-custom btn-sm" id="exportBtn" href="#"><i class="fa-solid fa-download me-1"></i>Export</a>
        <a class="btn btn-primary btn-sm" asp-action="Create"><i class="fa-solid fa-plus me-1"></i>Create</a>
    </div>
</section>

<section class="table-shell" data-erp-table id="loan-index-page">
    <div class="erp-table-wrap">
        <table class="table table-hover erp-table">
            <thead>
                <tr>
                    <th scope="col"><button class="table-sort" type="button" data-sort="0">Employee</button></th>
                    <th scope="col">Type</th>
                    <th scope="col">Date</th>
                    <th scope="col">Amount</th>
                    <th scope="col">Status</th>
                    <th scope="col">Deduction</th>
                    <th scope="col" class="text-end sticky-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td data-label="Employee">
                            <span class="fw-semibold">@item.Employee?.FirstName @item.Employee?.LastName</span>
                            <br /><small class="text-muted">@item.Employee?.Code</small>
                        </td>
                        <td data-label="Type">
                            @if (item.TransactionType == AlignHR.Models.TransactionType.Salary)
                            {
                                <span class="status-badge status-active">Salary Advance</span>
                            }
                            else
                            {
                                <span class="status-badge status-pending">Loan</span>
                            }
                        </td>
                        <td data-label="Date">@item.RequestDate.ToString("dd MMM yyyy")</td>
                        <td data-label="Amount"><span class="fw-semibold">@item.TotalAmount.ToString("N2")</span></td>
                        <td data-label="Status"><span class="status-badge status-approved">@item.Status</span></td>
                        <td data-label="Deduction">
                            @if (item.LoanDetuction)
                            {
                                <span class="status-badge status-risk">Exited</span>
                            }
                            else
                            {
                                <span class="status-badge status-active">Active</span>
                            }
                        </td>
                        <td data-label="Actions" class="text-end sticky-actions">
                            <div class="d-flex justify-content-end gap-1">
                                <a class="btn btn-icon btn-sm btn-icon-info" asp-action="Details" asp-route-id="@item.id" title="Details"><i class="fa-solid fa-eye"></i></a>
                                <a class="btn btn-icon btn-sm btn-icon-primary" asp-action="Edit" asp-route-id="@item.id" title="Edit"><i class="fa-solid fa-pen-to-square"></i></a>
                                <form asp-action="Delete" asp-route-id="@item.id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this record?');">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-icon btn-sm btn-icon-danger" type="submit" title="Delete"><i class="fa-solid fa-trash-can"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="empty-state" data-table-empty style="display: @(Model.Any() ? "none" : "block");">
            <i class="fa-solid fa-inbox"></i>
            <h3 class="h6 mt-2 mb-1">No records match the current filters</h3>
            <p class="text-muted mb-0">Adjust search or column criteria.</p>
        </div>
    </div>

    <div class="table-footer">
        <span class="text-muted small fw-semibold">Showing @Model.FirstItemOnPage-@Model.LastItemOnPage of @Model.TotalItemCount</span>
        <nav aria-label="Loan & advance pagination">
            @Html.PagedListPager(Model, page => Url.Action("Index", new {
                page,
                search = Context.Request.Query["search"]
            }), new PagedListRenderOptions
            {
                UlElementClasses = new[] { "pagination", "pagination-sm", "mb-0" },
                LiElementClasses = new[] { "page-item" },
                PageClasses = new[] { "page-link" }
            })
        </nav>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
