@model AlignHR.Models.HrFeedbackDetailsViewModel

@{
    ViewData["Title"] = "Feedback Details";
    ViewBag.ActivePage = "HrJobPostings";

    var recClass = Model.Recommendation switch
    {
        "Strong Hire" => "badge-success",
        "Hire"        => "badge-success",
        "Reject"      => "badge-danger",
        _             => "badge-warning"
    };
}

<div class="form-shell w-100 animate-fade-in">
    <div class="card-inner">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
                <span class="fw-bold fs-6">@Model.RoundName</span>
                <span class="status-badge @recClass ms-2">@Model.Recommendation</span>
            </div>
            <a asp-action="Details" asp-route-id="@Model.ScheduleId"
               class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-left me-1"></i>Back</a>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-12 col-md-4"><div class="small text-muted">Interviewer</div><div>@(Model.InterviewerName ?? "—")</div></div>
            <div class="col-12 col-md-3"><div class="small text-muted">Overall Score</div>
                <div class="fw-bold @(Model.OverallScore >= 7 ? "text-success" : Model.OverallScore >= 5 ? "text-warning" : "text-danger")">
                    @(Model.OverallScore.HasValue ? Model.OverallScore.Value.ToString("0.#") : "—")
                </div>
            </div>
            <div class="col-12 col-md-3"><div class="small text-muted">Submitted</div><div>@Model.SubmittedDate.ToString("dd MMM yyyy HH:mm")</div></div>
        </div>

        @if (Model.CriteriaScores.Any())
        {
            <div class="mb-3">
                <div class="small fw-semibold mb-2">Scorecard
                    @if (Model.TotalScore.HasValue)
                    {
                        <span class="text-muted fw-normal ms-2">Total: @Model.TotalScore.Value.ToString("0.#") / @Model.MaxTotalScore.Value.ToString("0.#")</span>
                    }
                </div>
                <table class="table table-sm erp-table">
                    <thead><tr><th>Criteria</th><th>Score</th><th>Max</th></tr></thead>
                    <tbody>
                        @foreach (var cs in Model.CriteriaScores)
                        {
                            <tr>
                                <td>@cs.CriteriaName</td>
                                <td class="fw-semibold">@cs.Score.ToString("0.#")</td>
                                <td class="text-muted">@cs.MaxScore.ToString("0.#")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="row g-3">
            @if (!string.IsNullOrWhiteSpace(Model.Strengths))
            {
                <div class="col-12 col-md-6">
                    <div class="small fw-semibold text-success mb-1">Strengths</div>
                    <div style="white-space:pre-wrap;" class="small">@Model.Strengths</div>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Concerns))
            {
                <div class="col-12 col-md-6">
                    <div class="small fw-semibold text-danger mb-1">Concerns</div>
                    <div style="white-space:pre-wrap;" class="small">@Model.Concerns</div>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Comments))
            {
                <div class="col-12">
                    <div class="small fw-semibold mb-1">Additional Comments</div>
                    <div style="white-space:pre-wrap;" class="small">@Model.Comments</div>
                </div>
            }
        </div>

        <div class="mt-3 text-end">
            <a asp-action="SubmitFeedback" asp-route-scheduleId="@Model.ScheduleId"
               class="btn btn-outline-primary btn-sm"><i class="fa-solid fa-pen-to-square me-1"></i>Edit Feedback</a>
        </div>
    </div>
</div>
