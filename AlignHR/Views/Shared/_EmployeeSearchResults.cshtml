@model IEnumerable<AlignHR.Models.Employee>

@if (Model != null && Model.Any())
{
    foreach (var emp in Model)
    {
        var initials =
            $"{(string.IsNullOrWhiteSpace(emp.FirstName) ? "?" : emp.FirstName.Substring(0, 1))}" +
            $"{(string.IsNullOrWhiteSpace(emp.LastName) ? "?" : emp.LastName.Substring(0, 1))}";
        <div class="search-result-item" 
             data-id="@emp.Id" 
             data-name="@emp.FullName" 
             data-code="@emp.Code">
            <div class="item-avatar">@initials.ToUpperInvariant()</div>
            <div class="item-info">
                <div class="item-name">@emp.FullName</div>
                <div class="item-meta">
                    <span class="badge-code">@emp.Code</span>
                    <span class="text-muted">@(emp.Department?.Name ?? "No Dept")</span>
                </div>
            </div>
            <div class="item-action">
                <i class="fas fa-arrow-right"></i>
            </div>
        </div>
    }
}
else
{
    <div class="search-empty">
        <i class="fas fa-user-slash"></i>
        <span>No employees found matching your search.</span>
    </div>
}
