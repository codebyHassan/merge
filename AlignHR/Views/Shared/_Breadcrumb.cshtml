@{
    var title      = ViewData["Title"] as string ?? "Dashboard";
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action     = ViewContext.RouteData.Values["action"]?.ToString();
    var isIndex    = string.Equals(action, "Index", StringComparison.OrdinalIgnoreCase);
    var parentName = ViewData["BreadcrumbParent"] as string ?? controller;
}

<div class="workspace-header">
    <nav class="breadcrumb-nav" aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Dashboard")">
                    <i class="bi bi-house-fill small"></i>
                </a>
            </li>

            @if (!string.IsNullOrEmpty(controller) && controller != "Dashboard")
            {
                if (isIndex)
                {
                    <li class="breadcrumb-item active fw-medium" aria-current="page">@title</li>
                }
                else
                {
                    <li class="breadcrumb-item">
                        <a href="@Url.Action("Index", controller)">@parentName</a>
                    </li>
                    <li class="breadcrumb-item active fw-medium" aria-current="page">@title</li>
                }
            }
            else if (title != "Dashboard")
            {
                <li class="breadcrumb-item active fw-medium" aria-current="page">@title</li>
            }
        </ol>
    </nav>
</div>
