<header class="header">
    <div class="header-left">
        <button class="hamburger" onclick="toggleSidebar()">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>
        </button>
        <div class="header-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" placeholder="Search employees, payroll, reports...">
            <span class="search-shortcut">⌘K</span>
        </div>
    </div>
    <div class="header-right">
        <div class="header-clock"><span class="clock-dot"></span><span id="liveClock">09:45:22 AM</span></div>
        <div style="position:relative">
            <button class="header-btn" onclick="toggleNotifications()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                <span class="notif-dot"></span>
            </button>
            <div class="notif-dropdown" id="notifDropdown">
                <div class="notif-dropdown-header"><h3>Notifications</h3><button class="btn btn-sm btn-secondary">Mark all read</button></div>
                <div class="notif-list">
                    <div class="notif-item"><div class="notif-icon blue"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div><div class="notif-text"><h4>Payroll Generated for December</h4><p>248 payslips ready for review · 2 min ago</p></div></div>
                    <div class="notif-item"><div class="notif-icon green"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><div class="notif-text"><h4>Ravi Sharma marked Present</h4><p>Clock-in at 9:02 AM · 15 min ago</p></div></div>
                    <div class="notif-item"><div class="notif-icon orange"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></div><div class="notif-text"><h4>5 employees clocked in late</h4><p>Late arrivals detected today · 30 min ago</p></div></div>
                    <div class="notif-item"><div class="notif-icon red"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg></div><div class="notif-text"><h4>Leave request from Priya Patel</h4><p>Sick leave for 3 days · 1 hour ago</p></div></div>
                </div>
            </div>
        </div>
@* Theme toggle removed *@
        <div class="header-divider"></div>
        <div class="header-profile" style="position:relative;cursor:pointer;" onclick="toggleProfileMenu()">
            @{
                var sessionName = Context.Session.GetString("UserName") ?? "Admin";
                var sessionRole = Context.Session.GetString("UserRoles") ?? "User";
                var initials = string.Concat(sessionName.Split(' ').Where(w => w.Length > 0).Take(2).Select(w => w[0].ToString().ToUpper()));
            }
            <div class="header-profile-avatar">@initials</div>
            <div class="header-profile-info">
                <h4>@sessionName</h4>
                <p>@(sessionRole.Split(',').FirstOrDefault()?.Trim() ?? "User")</p>
            </div>
            <!-- Mini dropdown -->
            <div id="profileMenu" style="display:none;position:absolute;top:calc(100% + 8px);right:0;background:var(--card-bg,#fff);border:1px solid var(--border-color,#e5e7eb);border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,.12);min-width:180px;z-index:999;overflow:hidden;">
                <a asp-controller="User" asp-action="Logout"
                   style="display:flex;align-items:center;gap:10px;padding:.75rem 1rem;font-size:.875rem;color:#dc2626;text-decoration:none;transition:background .15s;"
                   onmouseover="this.style.background='rgba(239,68,68,.08)'" onmouseout="this.style.background=''">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    Sign Out
                </a>
            </div>
        </div>
    </div>
</header>
