@using X.PagedList
@model IPagedList<AlignHR.Models.MasterLoanAdvanceDetail>
@using X.PagedList.Mvc.Core
@using X.PagedList.Web.Common

@{
    ViewData["Title"] = "Installments";
    ViewBag.ActivePage = "MasterLoanAdvanceDetail";
}

<section class="filter-bar mb-2" aria-label="Installments filters">
    <div class="input-group input-group-sm me-auto" style="width: auto;">
        <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input class="form-control"
               type="search"
               name="search"
               value="@Context.Request.Query["search"]"
               placeholder="Search employee"
               aria-label="Search records"
               hx-get="@Url.Action("Index")"
               hx-target="#installments-index-page"
               hx-select="#installments-index-page"
               hx-trigger="keyup[key=='Enter'], search"
               hx-include="[name='search']"
               hx-push-url="true"
               form="none" />
    </div>
    <div class="filter-group">
        <div class="dropdown">
            <button class="btn btn-export-custom btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport">
                Columns
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Installment" checked />Installment</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Employee" checked />Employee</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Type" checked />Type</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Month" checked />Month</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="EMI Amount" checked />EMI Amount</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Deducted" checked />Deducted</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Net Balance" checked />Net Balance</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Status" checked />Status</label></li>
            </ul>
        </div>
        <a class="btn btn-export-custom btn-sm" id="exportBtn" href="#"><i class="fa-solid fa-download me-1"></i>Export</a>
        <a class="btn btn-primary btn-sm" asp-action="Create"><i class="fa-solid fa-plus me-1"></i>Create</a>
    </div>
</section>

<section class="table-shell" data-erp-table id="installments-index-page">
    <div class="erp-table-wrap">
        <table class="table table-hover erp-table">
            <thead>
                <tr>
                    <th scope="col">Installment</th>
                    <th scope="col">Employee</th>
                    <th scope="col">Type</th>
                    <th scope="col">Month</th>
                    <th scope="col">EMI Amount</th>
                    <th scope="col">Deducted</th>
                    <th scope="col">Net Balance</th>
                    <th scope="col">Status</th>
                    <th scope="col" class="text-end sticky-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var lockedMonths = ViewBag.LockedMonths as List<string> ?? new List<string>();
                    var isLocked = lockedMonths.Contains(item.DeductionMonth);
                    string statusClass = item.Status == AlignHR.Models.LoanInstallmentStatus.Deducted ? "status-active"
                        : item.Status == AlignHR.Models.LoanInstallmentStatus.Skipped ? "status-risk"
                        : "status-pending";
                    string statusText = item.Status == AlignHR.Models.LoanInstallmentStatus.Deducted ? "Deducted"
                        : item.Status == AlignHR.Models.LoanInstallmentStatus.Skipped ? "Skipped"
                        : "Pending";
                    <tr>
                        <td data-label="Installment"><span class="fw-semibold">#@item.InstallmentNo</span></td>
                        <td data-label="Employee">
                            <span class="fw-semibold">@item.MasterLoanAdvance?.Employee?.FirstName @item.MasterLoanAdvance?.Employee?.LastName</span>
                            <br /><small class="text-muted">@item.MasterLoanAdvance?.Employee?.Code</small>
                        </td>
                        <td data-label="Type">@item.MasterLoanAdvance?.TransactionType</td>
                        <td data-label="Month">@item.DeductionMonth</td>
                        <td data-label="EMI Amount">@item.TotalDeductionAmount.ToString("N2")</td>
                        <td data-label="Deducted"><span class="fw-semibold text-success">@item.DeductedAmount.ToString("N2")</span></td>
                        <td data-label="Net Balance"><span class="fw-semibold text-danger">@item.RemainingAmount.ToString("N2")</span></td>
                        <td data-label="Status"><span class="status-badge @statusClass">@statusText</span></td>
                        <td data-label="Actions" class="text-end sticky-actions">
                            <div class="d-flex justify-content-end gap-1">
                                <a class="btn btn-icon btn-sm btn-icon-info" asp-action="Details" asp-route-id="@item.id" title="Details"><i class="fa-solid fa-eye"></i></a>
                                @if (isLocked)
                                {
                                    <span class="btn btn-icon btn-sm btn-icon-primary" title="Locked - Posted to GL" style="opacity:0.5; cursor:default;"><i class="fa-solid fa-lock"></i></span>
                                }
                                else
                                {
                                    <a class="btn btn-icon btn-sm btn-icon-primary" asp-action="Edit" asp-route-id="@item.id" title="Edit"><i class="fa-solid fa-pen-to-square"></i></a>
                                    <form asp-action="Delete" asp-route-id="@item.id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this record?');">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-icon btn-sm btn-icon-danger" type="submit" title="Delete"><i class="fa-solid fa-trash-can"></i></button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="empty-state" data-table-empty style="display: @(Model.Any() ? "none" : "block");">
            <i class="fa-solid fa-inbox"></i>
            <h3 class="h6 mt-2 mb-1">No records match the current filters</h3>
            <p class="text-muted mb-0">Adjust search or column criteria.</p>
        </div>
    </div>

    <div class="table-footer">
        <span class="text-muted small fw-semibold">Showing @Model.FirstItemOnPage-@Model.LastItemOnPage of @Model.TotalItemCount</span>
        <nav aria-label="Installments pagination">
            @Html.PagedListPager(Model, page => Url.Action("Index", new {
                page,
                search = Context.Request.Query["search"]
            }), new PagedListRenderOptions
            {
                UlElementClasses = new[] { "pagination", "pagination-sm", "mb-0" },
                LiElementClasses = new[] { "page-item" },
                PageClasses = new[] { "page-link" }
            })
        </nav>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
