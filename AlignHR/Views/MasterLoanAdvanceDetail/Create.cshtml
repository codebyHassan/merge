@model AlignHR.Models.MasterLoanAdvanceDetail

@{
    ViewData["Title"] = "Add Installment";
    ViewBag.ActivePage = "MasterLoanAdvanceDetail";
}

<div class="form-shell w-100">
    <div class="card-inner">
        <div class="form-header">
            <h2 class="card-subtitle">New Installment Entry</h2>
            <p class="text-muted small">Manually add a repayment installment for an approved loan or advance.</p>
        </div>
        
        <form asp-action="Create" method="post" id="installmentForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="form-grid">
                <!-- Loan Reference Section -->
                <div class="form-item full-width">
                    <label asp-for="MasterId" class="form-label">Loan/Advance Request <span class="required">*</span></label>
                    <select asp-for="MasterId" class="form-control select-premium" asp-items="ViewBag.MasterId" required
                            hx-get="@Url.Action("GetInstallmentFields")" 
                            hx-trigger="change" 
                            hx-target="#installmentFieldsContainer">
                        <option value="">-- Select Approved Loan/Advance --</option>
                    </select>
                    <span asp-validation-for="MasterId" class="text-danger small"></span>
                </div>

                <!-- HTMX Container for auto-filled fields -->
                <div id="installmentFieldsContainer" class="form-item full-width">
                    @await Html.PartialAsync("_InstallmentFields", Model)
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-12 d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back</a>
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </div>
            </div>
        </form>
    </div>
</div>
