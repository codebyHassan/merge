@model IPagedList<AlignHR.Models.EmployeeShifts>
@using X.PagedList
@using X.PagedList.Mvc.Core
@using X.PagedList.Web.Common
@{
    ViewData["Title"] = "Employee Shifts";
    ViewBag.ActivePage = "EmployeeShifts";
}

<section class="filter-bar mb-2" aria-label="Employee shifts filters">
    <div class="input-group input-group-sm me-auto" style="width: auto; position: relative;">
        <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input class="form-control"
               type="search"
               name="search"
               value="@Context.Request.Query["search"]"
               placeholder="Search employee..."
               aria-label="Search records"
               hx-get="@Url.Action("Index")"
               hx-target="#table-container"
               hx-select="#table-container"
               hx-indicator="#search-loader"
               hx-trigger="keyup[key=='Enter'], search"
               hx-push-url="true"
               form="none" />
        <span id="search-loader" class="htmx-indicator" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); z-index: 10;">
            <div class="spinner-border spinner-border-sm text-primary" role="status" style="width: 0.85rem; height: 0.85rem; border-width: 1.5px;"></div>
        </span>
    </div>
    <div class="filter-group">
        <a class="btn btn-export-custom btn-sm" id="exportBtn" href="#">
            <i class="fa-solid fa-download me-1"></i>Export
        </a>
        <a class="btn btn-primary btn-sm" asp-action="Create">
            <i class="fa-solid fa-plus me-1"></i>Assign Shift
        </a>
    </div>
</section>

<section class="table-shell" data-erp-table id="table-container">
    <div class="erp-table-wrap">
        <table class="table table-hover erp-table">
            <thead>
                <tr>
                    <th scope="col">Emp Code</th>
                    <th scope="col">Emp Name</th>
                    <th scope="col">Shift</th>
                    <th scope="col">Effective From</th>
                    <th scope="col">Effective To</th>
                    <th scope="col">Rest Day</th>
                    <th scope="col" class="text-end sticky-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td data-label="Emp Code" class="fw-semibold">@(item.Employee?.Code ?? "—")</td>
                        <td data-label="Emp Name">@(item.Employee != null ? $"{item.Employee.FirstName} {item.Employee.LastName}" : "Unknown Employee")</td>
                        <td data-label="Shift">
                            @if (item.Shift != null)
                            {
                                <span class="status-badge" style="background: rgba(99, 102, 241, 0.1); color: #6366F1;">
                                    @item.Shift.ShiftName - @item.Shift.GroupName
                                </span>
                            }
                            else
                            {
                                <span class="status-badge badge-secondary">No Shift</span>
                            }
                        </td>
                        <td data-label="Effective From">@item.EffiectiveForm.ToString("MMM dd, yyyy")</td>
                        <td data-label="Effective To">@(item.EffiectiveTo.HasValue ? item.EffiectiveTo.Value.ToString("MMM dd, yyyy") : "Ongoing")</td>
                        <td data-label="Rest Day">
                            <span class="status-badge leave">@item.RestDay</span>
                        </td>
                        <td data-label="Actions" class="text-end sticky-actions">
                            <div class="d-flex justify-content-end gap-1">
                                <a class="btn btn-icon btn-sm btn-icon-info" asp-action="Details" asp-route-id="@item.id" title="Details">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                <a class="btn btn-icon btn-sm btn-icon-primary" asp-action="Edit" asp-route-id="@item.id" title="Edit">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.id" method="post" class="d-inline"
                                      onsubmit="return confirm('Are you sure you want to delete this shift assignment?');">
                                    <button class="btn btn-icon btn-sm btn-icon-danger" type="submit" title="Delete">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            <div class="empty-state" data-table-empty>
                                <i class="fa-solid fa-inbox"></i>
                                <h3 class="h6 mt-2 mb-1">No employee shifts assigned yet</h3>
                                <p class="text-muted mb-0">Try adjusting your search or assign a new shift.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="table-footer">
        <span class="text-muted small fw-semibold">Showing @Model.FirstItemOnPage–@Model.LastItemOnPage of @Model.TotalItemCount</span>
        <nav aria-label="Employee shifts pagination">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page, search = Context.Request.Query["search"] }), new PagedListRenderOptions
            {
                UlElementClasses = new[] { "pagination", "pagination-sm", "mb-0" },
                LiElementClasses = new[] { "page-item" },
                PageClasses      = new[] { "page-link" }
            })
        </nav>
    </div>
</section>
