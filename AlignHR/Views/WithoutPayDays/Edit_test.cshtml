@model AlignHR.Models.WithoutPayDays
@{
    ViewData["Title"] = "Edit Without Pay Days";
    ViewBag.ActivePage = "WithoutPayDays";
}

<div class="breadcrumb-container animate-fade-in">
    <div class="breadcrumb-item">
        <i class="fas fa-home"></i>
        <a href="/">Home</a>
    </div>
    <div class="breadcrumb-separator"><i class="fas fa-chevron-right"></i></div>
    <div class="breadcrumb-item">
        <a asp-action="Index">Without Pay Days</a>
    </div>
    <div class="breadcrumb-separator"><i class="fas fa-chevron-right"></i></div>
    <div class="breadcrumb-item active">Edit</div>
</div>

<div class="form-shell">
    <div class="card-inner">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="id" />
            <div asp-validation-summary="All" style="color: #e53e3e; margin-bottom: 1.5rem; font-size: 0.9rem; list-style: none; padding: 0;"></div>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
                
                <div class="form-item">
                    <label class="form-label" asp-for="EmployeeId">Employee Code <span class="required">*</span></label>
                    <select asp-for="EmployeeId" class="form-control" asp-items="ViewBag.EmployeeId">
                        <option value="">Select Employee Code</option>
                    </select>
                    <span asp-validation-for="EmployeeId" class="validation-error"></span>
                </div>

                <div class="form-item">
                    <label class="form-label" asp-for="PeriodSalery">Salary Period <span class="required">*</span></label>
                    <select asp-for="PeriodSalery" class="form-control" asp-items="ViewBag.PeriodSalery">
                        <option value="">Select Period</option>
                    </select>
                    <span asp-validation-for="PeriodSalery" class="validation-error"></span>
                </div>

                <div class="form-item">
                    <label class="form-label" asp-for="withoutpaydays">Number of Days <span class="required">*</span></label>
                    <input asp-for="withoutpaydays" class="form-control" type="number" step="0.01" required />
                    <span asp-validation-for="withoutpaydays" class="validation-error"></span>
                </div>

            </div>

            <div class="form-actions-sticky" style="margin-top: 2rem; border-top: 1px solid var(--border); padding-top: 1.5rem;">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back</a>
                <button type="submit" class="btn btn-primary btn-sm">Update Record</button>
            </div>
        </form>
    </div>
</div>
