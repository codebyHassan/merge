@model IPagedList<AlignHR.Models.DocumentType>
@using X.PagedList
@using X.PagedList.Mvc.Core
@using X.PagedList.Web.Common

@{
    ViewData["Title"] = "Document Types";
    ViewBag.ActivePage = "DocumentTypes";
    var currentFilter = ViewData["CurrentFilter"]?.ToString();
}

<section class="filter-bar mb-2" aria-label="Document type filters">
    <div class="input-group input-group-sm me-auto" style="width: auto;">
        <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input class="form-control"
               type="search"
               name="searchQuery"
               value="@currentFilter"
               placeholder="Search document types"
               aria-label="Search records"
               hx-get="@Url.Action("Index")"
               hx-target="#doc-types-index-page"
               hx-select="#doc-types-index-page"
               hx-trigger="keyup[key=='Enter'], search"
               hx-include="[name='searchQuery']"
               hx-push-url="true"
               form="none" />
    </div>
    <div class="filter-group">
        <div class="dropdown">
            <button class="btn btn-export-custom btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport">
                Columns
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="TypeName" checked />Type Name</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Category" checked />Category</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Approval" checked />Requires Approval</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Expiry" checked />Has Expiry</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Status" checked />Status</label></li>
            </ul>
        </div>
        <a class="btn btn-primary btn-sm" asp-action="Create"><i class="fa-solid fa-plus me-1"></i>Create</a>
    </div>
</section>

<section class="table-shell" data-erp-table id="doc-types-index-page">
    <div class="erp-table-wrap">
        <table class="table table-hover erp-table">
            <thead>
                <tr>
                    <th scope="col"><button class="table-sort" type="button" data-sort="0">Type Name</button></th>
                    <th scope="col">Category</th>
                    <th scope="col">Requires Approval</th>
                    <th scope="col">Has Expiry</th>
                    <th scope="col">Status</th>
                    <th scope="col" class="text-end sticky-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td data-label="Type Name"><span class="fw-semibold">@item.TypeName</span></td>
                        <td data-label="Category">@(item.Category?.CategoryName ?? "-")</td>
                        <td data-label="Requires Approval"><span class="status-badge @(item.RequiresApproval ? "badge-warning" : "badge-secondary")">@(item.RequiresApproval ? "Yes" : "No")</span></td>
                        <td data-label="Has Expiry"><span class="status-badge @(item.HasExpiry ? "badge-warning" : "badge-secondary")">@(item.HasExpiry ? "Yes" : "No")</span></td>
                        <td data-label="Status"><span class="status-badge @(item.IsActive ? "status-active" : "status-risk")">@(item.IsActive ? "Active" : "Inactive")</span></td>
                        <td data-label="Actions" class="text-end sticky-actions">
                            <div class="d-flex justify-content-end gap-1">
                                <a class="btn btn-icon btn-sm btn-icon-primary" asp-action="Edit" asp-route-id="@item.DocumentTypeID" title="Edit"><i class="fa-solid fa-pen-to-square"></i></a>
                                <form asp-action="Delete" asp-route-id="@item.DocumentTypeID" method="post" class="d-inline"
                                      onsubmit="return confirm('Are you sure you want to delete this document type?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-icon btn-sm btn-icon-danger" title="Delete">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="empty-state" data-table-empty>
                <i class="fa-solid fa-inbox"></i>
                <h3 class="h6 mt-2 mb-1">No records match the current filters</h3>
                <p class="text-muted mb-0">Adjust search or create a new document type.</p>
            </div>
        }
    </div>

    <div class="table-footer">
        <span class="text-muted small fw-semibold">Showing @Model.FirstItemOnPage-@Model.LastItemOnPage of @Model.TotalItemCount</span>
        <nav aria-label="Document types pagination">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page, searchQuery = currentFilter }), new PagedListRenderOptions
            {
                UlElementClasses = new[] { "pagination", "pagination-sm", "mb-0" },
                LiElementClasses = new[] { "page-item" },
                PageClasses = new[] { "page-link" }
            })
        </nav>
    </div>
</section>
