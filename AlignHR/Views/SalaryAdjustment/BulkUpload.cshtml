@{
    ViewData["Title"] = "Bulk Upload Adjustments";
    ViewBag.ActivePage = "SalaryAdjustment";
}

<div class="premium-wrapper animate-fade-in">
    <nav class="premium-breadcrumb">
        <ol>
            <li><a href="/"><i class="fas fa-home"></i> Home</a></li>
            <li><i class="fas fa-chevron-right separator"></i></li>
            <li><a asp-action="Index">Salary Adjustments</a></li>
            <li><i class="fas fa-chevron-right separator"></i></li>
            <li class="active">Bulk Upload</li>
        </ol>
    </nav>

    <div class="glass-card max-w-2xl mx-auto mt-5">
        <div class="card-header-fancy" style="background: linear-gradient(to right, #eef2ff, #ffffff);">
            <div class="icon-box">
                <i class="fas fa-file-excel"></i>
            </div>
            <div class="header-text">
                <h3>Bulk Adjustment Upload</h3>
                <p>Import multiple earnings and deductions using an Excel file.</p>
            </div>
        </div>

        <div class="p-5">
            <div class="alert-info-premium mb-4">
                <div class="alert-icon"><i class="fas fa-info-circle"></i></div>
                <div class="alert-content">
                    <h5>Instructions:</h5>
                    <ul>
                        <li>Download the template to ensure correct column mapping.</li>
                        <li><strong>EmployeeCode</strong> must match the system code exactly.</li>
                        <li><strong>SalaryPeriodName</strong> should match the active periods (e.g., 2025-04).</li>
                        <li>Type should be either <strong>Earning</strong> or <strong>Deduction</strong>.</li>
                    </ul>
                </div>
            </div>

            <form asp-action="BulkUpload" method="post" enctype="multipart/form-data" class="bulk-form">
                @Html.AntiForgeryToken()
                
                <div class="upload-zone" id="uploadZone">
                    <input type="file" name="file" id="fileInput" class="hidden-input" accept=".xlsx, .xls" required />
                    <div class="upload-placeholder">
                        <i class="fas fa-cloud-upload-alt fa-3x mb-3 text-primary"></i>
                        <h4 id="fileName">Click to Browse or Drag & Drop</h4>
                        <p class="text-muted small">Supports .xlsx and .xls files</p>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-5">
                    <a asp-action="DownloadTemplate" class="btn-template">
                        <i class="fas fa-download"></i> Download Template
                    </a>
                    
                    <div class="d-flex gap-3">
                        <a asp-action="Index" class="btn-cancel">Cancel</a>
                        <button type="submit" class="btn-submit">
                            <i class="fas fa-upload"></i> Start Import
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
    document.getElementById('fileInput').addEventListener('change', function(e) {
        const fileName = e.target.files[0] ? e.target.files[0].name : 'Click to Browse or Drag & Drop';
        document.getElementById('fileName').textContent = fileName;
        document.getElementById('uploadZone').style.borderColor = '#4f46e5';
        document.getElementById('uploadZone').style.background = '#eef2ff';
    });
</script>
