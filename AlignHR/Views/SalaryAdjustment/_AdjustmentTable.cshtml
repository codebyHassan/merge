@model IEnumerable<AlignHR.Models.SalaryAdjustments>

<div class="erp-table-wrap">
    <table class="table table-hover erp-table">
        <thead>
            <tr>
                <th>Employee</th>
                <th>Period</th>
                <th>Category</th>
                <th>Type</th>
                <th style="text-align: right;">Amount</th>
                <th style="text-align: center;">Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td style="padding-left: 15px;">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <div class="emp-initials">
                                    @(item.employee?.FirstName?.Substring(0, 1) ?? "E")@(item.employee?.LastName?.Substring(0, 1) ?? "")
                                </div>
                                <div>
                                    <div style="font-weight: 600; color: var(--text-main);">@item.employee?.FullName</div>
                                    <div style="font-size: 11px; color: var(--text-muted);">@item.employee?.Code</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge badge-secondary">@item.SalaryPeriod?.PeriodName</span>
                        </td>
                        <td>
                            <span style="font-weight: 500;">@item.AdjustmentCategory</span>
                        </td>
                        <td>
                            @if (item.Type == AlignHR.Models.PayrollComponentTypes.Earning)
                            {
                                <span class="badge badge-success">Earning</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">Deduction</span>
                            }
                        </td>
                        <td style="text-align: right; font-weight: 700; color: @(item.Type == AlignHR.Models.PayrollComponentTypes.Earning ? "#059669" : "#dc2626");">
                            @(item.Type == AlignHR.Models.PayrollComponentTypes.Earning ? "+" : "-") @item.Amount.ToString("N2")
                        </td>
                        <td style="text-align: center;">
                            @if (item.IsApproved)
                            {
                                <span class="badge badge-success">Approved</span>
                            }
                            else
                            {
                                <span class="badge badge-warning">Pending</span>
                            }
                        </td>
                        <td>
                            <div class="table-actions">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-icon btn-sm" title="View Details" style="background: #eff6ff; color: #3b82f6; border-color: #bfdbfe;">
                                    <i class="fas fa-eye"></i>
                                </a>
                                @if (item.SalaryPeriod != null && item.SalaryPeriod.IsPostedToGL)
                                {
                                    <div class="btn btn-icon btn-sm-locked" title="Locked: This period is posted to GL." style="display: flex; align-items: center; background: #f1f5f9; padding: 4px 10px; border-radius: 4px; border: 1px solid #e2e8f0; pointer-events: none;">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 14px; color: #64748b;">
                                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                        </svg>
                                        <span style="font-size: 0.6rem; font-weight: 700; margin-left: 4px; color: #64748b;">LOCKED</span>
                                    </div>
                                }
                                else
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-icon btn-sm" title="Edit">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                        </svg>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete this adjustment?');" style="display: inline;">
                                        <button type="submit" class="btn btn-icon btn-sm text-danger" title="Delete">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <polyline points="3 6 5 6 21 6" />
                                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                            </svg>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" style="text-align: center; padding: 40px; color: var(--text-muted);">
                        No adjustments found.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@using X.PagedList
@using X.PagedList.Mvc.Core
@using X.PagedList.Web.Common
<div class="pagination-wrapper p-4 border-top">
    @Html.PagedListPager((IPagedList)Model, page => Url.Action("Index", new { page, search = Context.Request.Query["search"] }),
        new PagedListRenderOptions {
            DisplayLinkToFirstPage = PagedListDisplayMode.Never,
            DisplayLinkToLastPage = PagedListDisplayMode.Never,
            DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
            DisplayLinkToNextPage = PagedListDisplayMode.Always,
            UlElementClasses = new[] { "pagination", "justify-content-center", "m-0" },
            LiElementClasses = new[] { "page-item" },
            PageClasses = new[] { "page-link" },
        })
</div>

<script>
    // Ensure pagination links use HTMX
    document.querySelectorAll('.pagination-wrapper a').forEach(link => {
        link.setAttribute('hx-get', link.getAttribute('href'));
        link.setAttribute('hx-target', '#table-container');
        link.setAttribute('hx-push-url', 'true');
        link.addEventListener('click', (e) => e.preventDefault());
    });
    htmx.process(document.querySelector('.pagination-wrapper'));
</script>
