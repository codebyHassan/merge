@using X.PagedList.Mvc.Core
@model X.PagedList.IPagedList<AlignHR.Models.Bonus>

@{
    ViewData["Title"] = "Bonus Management";
    ViewBag.ActivePage = "Bonus";
}
<div class="page-header">
    <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <span>Bonuses</span>
    </div>

    <div class="page-header-row">
        <div>
            <h1 class="page-title">Bonus Management</h1>
            <p class="page-subtitle">Track and manage employee bonuses, performance incentives, and tax deductions</p>
        </div>

        <div class="flex gap-8">
            <a class="btn btn-primary btn-sm" asp-action="Create">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
                Add New Bonus
            </a>
        </div>
    </div>
</div>

<div class="table-shell">
    <div class="table-toolbar">
        <div class="table-card-title">Bonus Records (@Model.TotalItemCount)</div>

        <div class="table-filters">
            <form method="get" asp-action="Index" style="display: flex; align-items: center; gap: 8px;">
                <input type="text" name="search" class="filter-input form-control" placeholder="Search Here..." value="@Context.Request.Query["search"]" />
            </form>
        </div>
    </div>

    <div class="erp-table-wrap">
        <table class="table table-hover erp-table">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Bonus Type</th>
                    <th>Period</th>
                    <th class="text-right">Amount</th>
                    <th class="text-right">Tax</th>
                    <th class="text-right">Net Bonus</th>
                    <th>Payment Date</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr id="row-@item.Id">
                        <td>
                            <div style="display: flex; flex-direction: column;">
                                <span style="font-weight: 600;">@item.Employee?.FirstName @item.Employee?.LastName</span>
                                <span style="font-size: 11px; color: #64748b;">@item.Employee?.Code</span>
                            </div>
                        </td>
                        <td><span class="badge badge-info">@item.BonusType?.Name</span></td>
                        <td>@item.SalaryPeriod?.PeriodName</td>
                        <td class="text-right amount">@item.BonusAmount.ToString("N0")</td>
                        <td class="text-right amount" style="color: #ef4444;">-@item.TaxDeduction.ToString("N0")</td>
                        <td class="text-right amount" style="color: var(--primary); font-size: 1.05rem;">@item.NetBonus.ToString("N0")</td>
                        <td>@item.PaymentDate.ToString("dd MMM yyyy")</td>
                        <td>
                            @{
                                var statusClass = item.ApprovalStatus == "Approved" ? "badge-success" : 
                                                item.ApprovalStatus == "Rejected" ? "badge-danger" : "badge-warning";
                            }
                            <span class="badge @statusClass">@item.ApprovalStatus</span>
                        </td>
                        <td>
                            <div class="table-actions" style="justify-content: center;">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-icon btn-sm" title="View Details" style="background: #eff6ff; color: #3b82f6; border-color: #bfdbfe;">
                                    <i class="fas fa-eye"></i>
                                </a>
                                @if (item.SalaryPeriod != null && item.SalaryPeriod.IsPostedToGL)
                                {
                                    <div class="btn btn-icon btn-sm-locked" title="Locked: This period is posted to GL." style="display: flex; align-items: center; background: #f1f5f9; padding: 4px 10px; border-radius: 4px; border: 1px solid #e2e8f0; pointer-events: none;">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 14px; color: #64748b;">
                                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                        </svg>
                                        <span style="font-size: 0.6rem; font-weight: 700; margin-left: 4px; color: #64748b;">LOCKED</span>
                                    </div>
                                }
                                else
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-icon btn-sm" title="Edit">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                        </svg>
                                    </a>
                                    <button onclick="deleteBonus(@item.Id)" class="btn btn-icon btn-sm text-danger" title="Delete">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <polyline points="3 6 5 6 21 6" />
                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                        </svg>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="pagination-wrapper mt-4">
        @Html.PagedListPager(Model, page => Url.Action("Index", new { page, search = Context.Request.Query["search"] }))
    </div>
</div>

<script>
    function deleteBonus(id) {
        if (confirm('Are you sure you want to delete this bonus record?')) {
            fetch(`/Bonus/Delete/${id}`, { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById(`row-${id}`).style.opacity = '0';
                        setTimeout(() => document.getElementById(`row-${id}`).remove(), 300);
                    } else {
                        alert('Error deleting record.');
                    }
                });
        }
    }
</script>
