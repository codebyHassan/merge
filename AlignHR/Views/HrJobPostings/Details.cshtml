@model AlignHR.Models.HrJobPostingDetailsViewModel

@{
    ViewData["Title"] = "Job Posting — " + Model.JobCode;
    ViewBag.ActivePage = "HrJobPostings";

    var statusClass = Model.PostingStatus switch
    {
        "Published" => "badge-success",
        "Paused"    => "badge-warning",
        "Closed"    => "badge-danger",
        _           => "badge-secondary"
    };

    // Build the copy text server-side
    var sb = new System.Text.StringBuilder();
    sb.AppendLine($"Position: {Model.JobTitle ?? Model.PositionTitle ?? "—"}");
    if (!string.IsNullOrWhiteSpace(Model.DepartmentName))   sb.AppendLine($"Department: {Model.DepartmentName}");
    if (!string.IsNullOrWhiteSpace(Model.EmploymentType))   sb.AppendLine($"Employment Type: {Model.EmploymentType}");
    if (!string.IsNullOrWhiteSpace(Model.Nature))           sb.AppendLine($"Nature: {Model.Nature}");
    if (!string.IsNullOrWhiteSpace(Model.Location))         sb.AppendLine($"Location: {Model.Location}");
    sb.AppendLine($"Open Date: {Model.OpenDate:dd MMM yyyy}");
    if (Model.CloseDate.HasValue)                            sb.AppendLine($"Close Date: {Model.CloseDate.Value:dd MMM yyyy}");
    if (Model.BudgetAmountPerMonth.HasValue)                 sb.AppendLine($"Budget / Month: {Model.BudgetAmountPerMonth.Value:N0}");
    sb.AppendLine();

    if (!string.IsNullOrWhiteSpace(Model.JobDescription))
    {
        sb.AppendLine("About the Role:");
        sb.AppendLine(Model.JobDescription.Trim());
        sb.AppendLine();
    }

    if (!string.IsNullOrWhiteSpace(Model.Reason))
    {
        sb.AppendLine("Reason / Justification:");
        sb.AppendLine(Model.Reason.Trim());
        sb.AppendLine();
    }

    if (Model.Skills.Any())
    {
        sb.AppendLine("Required Skills:");
        int sn = 1;
        foreach (var s in Model.Skills)
        {
            var line = $"{sn++}. {s.SkillName}";
            if (s.YearsExperience.HasValue)
                line += $" — {s.YearsExperience.Value:0.#} yr{(s.YearsExperience.Value != 1 ? "s" : "")}";
            if (!s.IsMandatory) line += " (optional)";
            sb.AppendLine(line);
        }
        sb.AppendLine();
    }

    if (Model.Offerings.Any())
    {
        sb.AppendLine("What We Offer:");
        int on = 1;
        foreach (var o in Model.Offerings)
        {
            var line = $"{on++}. {o.OfferingName}";
            if (!string.IsNullOrWhiteSpace(o.Description)) line += $" — {o.Description}";
            sb.AppendLine(line);
        }
    }

    if (Model.PostingStatus == "Published")
    {
        var applyUrl = Url.Action("Apply", "PublicApply", new { id = Model.Id }, Context.Request.Scheme);
        sb.AppendLine();
        sb.AppendLine($"Apply Here: {applyUrl}");
    }

    var copyText = sb.ToString().Trim();
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2 small" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2 small" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}

<div class="form-shell w-100 animate-fade-in" style="padding:0 !important;">

    @*── Hero Header ──*@
    <div style="padding:20px 22px 18px;border-bottom:1px solid var(--ahr-border)">
        <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
            <div>
                <div class="d-flex align-items-center gap-2 flex-wrap" style="margin-bottom:4px">
                    <span style="font-size:17px;font-weight:700;letter-spacing:-0.025em;color:var(--ahr-text);font-family:var(--ahr-font-display)">@(Model.JobTitle ?? "—")</span>
                    <span class="status-badge @statusClass">@(Model.PostingStatus ?? "—")</span>
                </div>
                <div style="font-size:12px;color:var(--ahr-text-tertiary);font-family:var(--ahr-font-mono);letter-spacing:0.02em">@(Model.JobCode ?? "—")</div>
            </div>

            <div class="d-flex flex-wrap gap-2" style="flex-shrink:0">
                <a asp-action="Index" class="btn btn-secondary btn-sm">Back</a>
                <a asp-controller="HrApplications" asp-action="Index" asp-route-jobPostingId="@Model.Id"
                   class="btn btn-primary btn-sm">View Candidates</a>

                @if (Model.PostingStatus == "Draft" || Model.PostingStatus == "Paused")
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary btn-sm">Edit</a>
                }
                @if (Model.PostingStatus == "Draft")
                {
                    <form asp-action="Publish" asp-route-id="@Model.Id" method="post" class="d-inline"
                          onsubmit="return confirm('Publish this job posting?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary btn-sm">Publish</button>
                    </form>
                }
                @if (Model.PostingStatus == "Published")
                {
                    <form asp-action="Pause" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-secondary btn-sm">Pause</button>
                    </form>
                    <form asp-action="Close" asp-route-id="@Model.Id" method="post" class="d-inline"
                          onsubmit="return confirm('Close this posting?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm">Close</button>
                    </form>
                }
                @if (Model.PostingStatus == "Paused")
                {
                    <form asp-action="Publish" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary btn-sm">Re-Publish</button>
                    </form>
                    <form asp-action="Close" asp-route-id="@Model.Id" method="post" class="d-inline"
                          onsubmit="return confirm('Close this posting?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm">Close</button>
                    </form>
                }
                @if (Model.PostingStatus != "Published")
                {
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline"
                          onsubmit="return confirm('Delete this job posting?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                }
            </div>
        </div>
    </div>

    @*── Posting Fields ──*@
    <div style="display:grid;grid-template-columns:repeat(4,1fr);border-bottom:1px solid var(--ahr-border)">

        <div style="padding:14px 18px;border-right:1px solid var(--ahr-border)">
            <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ahr-text-tertiary);margin-bottom:5px">Employment Type</div>
            <div style="font-size:13px;font-weight:500;color:var(--ahr-text)">@(Model.EmploymentType ?? "—")</div>
        </div>

        <div style="padding:14px 18px;border-right:1px solid var(--ahr-border)">
            <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ahr-text-tertiary);margin-bottom:5px">Location</div>
            <div style="font-size:13px;font-weight:500;color:var(--ahr-text)">@(Model.Location ?? "—")</div>
        </div>

        <div style="padding:14px 18px;border-right:1px solid var(--ahr-border)">
            <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ahr-text-tertiary);margin-bottom:5px">Open Date</div>
            <div style="font-size:13px;font-weight:500;color:var(--ahr-text)">@Model.OpenDate.ToString("dd MMM yyyy")</div>
        </div>

        <div style="padding:14px 18px">
            <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ahr-text-tertiary);margin-bottom:5px">Close Date</div>
            <div style="font-size:13px;font-weight:500;color:var(--ahr-text)">@(Model.CloseDate?.ToString("dd MMM yyyy") ?? "—")</div>
        </div>

    </div>

    @*── Requisition Fields ──*@
    @if (Model.RequisitionFK.HasValue)
    {
        <div style="display:grid;grid-template-columns:repeat(4,1fr);border-bottom:1px solid var(--ahr-border)">

            <div style="padding:14px 18px;border-right:1px solid var(--ahr-border)">
                <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ahr-text-tertiary);margin-bottom:5px">Requisition</div>
                <div style="font-size:13px;font-weight:500">
                    <a asp-controller="HrRequisitions" asp-action="Details" asp-route-id="@Model.RequisitionFK"
                       style="color:var(--ahr-text);text-decoration:underline;text-underline-offset:3px;text-decoration-color:var(--ahr-border-strong)">
                        @(Model.RequisitionNo ?? "View")
                    </a>
                </div>
            </div>

            <div style="padding:14px 18px;border-right:1px solid var(--ahr-border)">
                <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ahr-text-tertiary);margin-bottom:5px">Department</div>
                <div style="font-size:13px;font-weight:500;color:var(--ahr-text)">@(Model.DepartmentName ?? "—")</div>
            </div>

            <div style="padding:14px 18px;border-right:1px solid var(--ahr-border)">
                <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ahr-text-tertiary);margin-bottom:5px">Type</div>
                <div style="font-size:13px;font-weight:500;color:var(--ahr-text)">@(Model.RequisitionType ?? "—")</div>
            </div>

            <div style="padding:14px 18px">
                <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ahr-text-tertiary);margin-bottom:5px">Nature</div>
                <div style="font-size:13px;font-weight:500;color:var(--ahr-text)">@(Model.Nature ?? "—")</div>
            </div>

        </div>

        <div style="display:grid;grid-template-columns:repeat(4,1fr);border-bottom:1px solid var(--ahr-border)">

            <div style="padding:14px 18px;border-right:1px solid var(--ahr-border)">
                <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ahr-text-tertiary);margin-bottom:5px">Budget / Month</div>
                <div style="font-size:13px;font-weight:500;color:var(--ahr-text);font-family:var(--ahr-font-mono)">
                    @(Model.BudgetAmountPerMonth.HasValue ? Model.BudgetAmountPerMonth.Value.ToString("N0") : "—")
                </div>
            </div>

            <div style="padding:14px 18px;border-right:1px solid var(--ahr-border)">
                <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ahr-text-tertiary);margin-bottom:5px">Initial Date</div>
                <div style="font-size:13px;font-weight:500;color:var(--ahr-text)">@(Model.InitialDate?.ToString("dd MMM yyyy") ?? "—")</div>
            </div>

            <div style="padding:14px 18px;border-right:1px solid var(--ahr-border)">
                <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ahr-text-tertiary);margin-bottom:5px">Promised Date</div>
                <div style="font-size:13px;font-weight:500;color:var(--ahr-text)">@(Model.PromisedDate?.ToString("dd MMM yyyy") ?? "—")</div>
            </div>

            <div></div>

        </div>
    }

    @*── Job Description ──*@
    @if (!string.IsNullOrWhiteSpace(Model.JobDescription))
    {
        <div style="padding:16px 22px;border-bottom:1px solid var(--ahr-border)">
            <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ahr-text-tertiary);margin-bottom:10px">Job Description</div>
            <div style="font-size:13px;color:var(--ahr-text);line-height:1.7;white-space:pre-wrap">@Model.JobDescription</div>
        </div>
    }

    @*── Reason ──*@
    @if (!string.IsNullOrWhiteSpace(Model.Reason))
    {
        <div style="padding:16px 22px;border-bottom:1px solid var(--ahr-border)">
            <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ahr-text-tertiary);margin-bottom:10px">Reason / Justification</div>
            <div style="font-size:13px;color:var(--ahr-text);line-height:1.65;white-space:pre-wrap">@Model.Reason</div>
        </div>
    }

    @*── Skills + Offerings ──*@
    @if (Model.Skills.Any() || Model.Offerings.Any())
    {
        <div style="display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid var(--ahr-border)">

            <div style="padding:18px 22px;border-right:1px solid var(--ahr-border)">
                <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ahr-text-tertiary);margin-bottom:12px">Required Skills</div>
                @if (Model.Skills.Any())
                {
                    <ol style="margin:0;padding-left:18px">
                        @foreach (var skill in Model.Skills)
                        {
                            <li style="font-size:13px;color:var(--ahr-text);padding:3px 0;line-height:1.5">
                                @skill.SkillName
                                @if (skill.YearsExperience.HasValue)
                                {
                                    <span style="color:var(--ahr-text-tertiary);font-size:12px"> — @(skill.YearsExperience.Value.ToString("0.#")) yr@(skill.YearsExperience.Value != 1 ? "s" : "")</span>
                                }
                                @if (!skill.IsMandatory)
                                {
                                    <span style="color:var(--ahr-text-muted);font-size:11px"> (optional)</span>
                                }
                            </li>
                        }
                    </ol>
                }
                else
                {
                    <div style="font-size:13px;color:var(--ahr-text-muted)">—</div>
                }
            </div>

            <div style="padding:18px 22px">
                <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ahr-text-tertiary);margin-bottom:12px">Company Offerings</div>
                @if (Model.Offerings.Any())
                {
                    <ol style="margin:0;padding-left:18px">
                        @foreach (var offering in Model.Offerings)
                        {
                            <li style="font-size:13px;color:var(--ahr-text);padding:3px 0;line-height:1.5">
                                @offering.OfferingName
                                @if (!string.IsNullOrWhiteSpace(offering.Description))
                                {
                                    <span style="color:var(--ahr-text-tertiary);font-size:12px"> — @offering.Description</span>
                                }
                            </li>
                        }
                    </ol>
                }
                else
                {
                    <div style="font-size:13px;color:var(--ahr-text-muted)">—</div>
                }
            </div>

        </div>
    }

    @*── Copy-Ready Text ──*@
    <div style="padding:18px 22px">
        <div class="d-flex align-items-center justify-content-between gap-2" style="margin-bottom:10px">
            <div>
                <div style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ahr-text-tertiary)">Ready to Post</div>
                <div style="font-size:11.5px;color:var(--ahr-text-muted);margin-top:2px">Copy and paste this into LinkedIn, Indeed, or any external platform.</div>
            </div>
            <button type="button" class="btn btn-secondary btn-sm" id="btnCopyPost">Copy Text</button>
        </div>
        <textarea id="copyPostText" readonly
                  style="width:100%;min-height:220px;font-size:12.5px;font-family:var(--ahr-font-mono);line-height:1.65;color:var(--ahr-text);background:var(--ahr-surface);border:1px solid var(--ahr-border);border-radius:6px;padding:12px 14px;resize:vertical;outline:none">@copyText</textarea>
    </div>

</div>

@section Scripts {
<script>
    document.getElementById('btnCopyPost').addEventListener('click', function () {
        var ta = document.getElementById('copyPostText');
        ta.select();
        ta.setSelectionRange(0, 99999);
        try {
            navigator.clipboard.writeText(ta.value).then(function () {
                var btn = document.getElementById('btnCopyPost');
                btn.textContent = 'Copied!';
                setTimeout(function () { btn.textContent = 'Copy Text'; }, 2000);
            });
        } catch (e) {
            document.execCommand('copy');
            var btn = document.getElementById('btnCopyPost');
            btn.textContent = 'Copied!';
            setTimeout(function () { btn.textContent = 'Copy Text'; }, 2000);
        }
    });
</script>
}
