@model IPagedList<AlignHR.Models.HrJobPostingListItemViewModel>
@using X.PagedList
@using X.PagedList.Mvc.Core
@using X.PagedList.Web.Common

@{
    ViewData["Title"] = "Job Postings";
    ViewBag.ActivePage = "HrJobPostings";
    var currentFilter = ViewData["CurrentFilter"]?.ToString();
    var requisitionId = ViewData["RequisitionId"] as decimal?;
    var pending = ViewBag.PendingRequisitions as List<AlignHR.Models.HrPendingPostingRequisitionViewModel> ?? new();
}

<section class="filter-bar mb-2" aria-label="Job postings filters">
    <div class="input-group input-group-sm me-auto" style="width:auto;">
        <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input class="form-control" type="search" name="search" value="@currentFilter"
               placeholder="Search by code or title"
               hx-get="@Url.Action("Index")" hx-target="#job-postings-page"
               hx-select="#job-postings-page" hx-trigger="keyup[key=='Enter'], search"
               hx-include="[name='search']" hx-push-url="true" form="none" />
    </div>
    <div class="filter-group">
        @if (requisitionId.HasValue)
        {
            <a asp-controller="HrRequisitions" asp-action="Details" asp-route-id="@requisitionId"
               class="btn btn-icon btn-sm btn-icon-secondary" title="Back to Requisition">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
        }
    </div>
</section>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2 small" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2 small" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}

@* ── Requisitions awaiting a posting ── *@
@if (pending.Any())
{
    <div class="table-shell mb-3" style="border:1px solid color-mix(in srgb,var(--ahr-warning,#f59e0b) 40%,var(--ahr-border));">
        <div style="padding:10px 16px;border-bottom:1px solid color-mix(in srgb,var(--ahr-warning,#f59e0b) 30%,var(--ahr-border));background:color-mix(in srgb,var(--ahr-warning,#f59e0b) 7%,transparent);display:flex;align-items:center;gap:8px;">
            <i class="fa-solid fa-triangle-exclamation" style="color:var(--ahr-warning,#f59e0b);"></i>
            <span style="font-size:12px;font-weight:600;color:var(--ahr-text);">
                @pending.Count requisition@(pending.Count != 1 ? "s" : "") assigned to you need@(pending.Count == 1 ? "s" : "") a job posting
            </span>
        </div>
        <div class="erp-table-wrap">
            <table class="table table-hover erp-table" style="margin-bottom:0;">
                <thead>
                    <tr>
                        <th>Requisition</th>
                        <th>Position</th>
                        <th>Department</th>
                        <th>Assigned On</th>
                        <th class="text-end sticky-actions">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in pending)
                    {
                        <tr>
                            <td><span class="fw-semibold" style="font-family:var(--ahr-font-mono);font-size:12px;">@req.RequisitionNo</span></td>
                            <td>@req.PositionTitle</td>
                            <td>@(req.DepartmentName ?? "—")</td>
                            <td style="font-size:12px;color:var(--ahr-text-muted);">@(req.AssignedDate?.ToString("dd MMM yyyy") ?? "—")</td>
                            <td class="text-end sticky-actions">
                                <a asp-action="Create" asp-route-requisitionId="@req.RequisitionId"
                                   class="btn btn-icon btn-sm btn-icon-primary" title="Create Posting">
                                    <i class="fa-solid fa-plus"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<section class="table-shell" data-erp-table id="job-postings-page">
    <div class="erp-table-wrap">
        <table class="table table-hover erp-table">
            <thead>
                <tr>
                    <th>Job Code</th>
                    <th>Job Title</th>
                    <th>Requisition</th>
                    <th class="text-center">Candidates</th>
                    <th class="text-center">Interviews</th>
                    <th>Open Date</th>
                    <th>Status</th>
                    <th class="text-end sticky-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var statusClass = item.PostingStatus switch
                    {
                        "Published" => "badge-success",
                        "Paused"    => "badge-warning",
                        "Closed"    => "badge-danger",
                        _           => "badge-secondary"
                    };
                    <tr>
                        <td><span class="fw-semibold">@item.JobCode</span></td>
                        <td>@item.JobTitle</td>
                        <td>@(item.RequisitionNo ?? "—")</td>
                        <td class="text-center">
                            <a asp-controller="HrApplications" asp-action="Index" asp-route-jobPostingId="@item.Id"
                               class="status-badge @(item.ApplicantCount > 0 ? "badge-primary" : "badge-secondary")"
                               style="text-decoration:none;" title="View candidates">
                                @item.ApplicantCount
                            </a>
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="status-badge @(item.RoundCount > 0 ? "badge-success" : "badge-secondary")"
                               style="text-decoration:none;" title="View interview rounds">
                                @item.RoundCount
                            </a>
                        </td>
                        <td>@item.OpenDate.ToString("dd MMM yyyy")</td>
                        <td><span class="status-badge @statusClass">@item.PostingStatus</span></td>
                        <td class="text-end sticky-actions">
                            <div class="d-flex justify-content-end gap-1">
                                <a class="btn btn-icon btn-sm btn-icon-primary"
                                   asp-action="Details" asp-route-id="@item.Id" title="View">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                <a class="btn btn-icon btn-sm btn-icon-secondary"
                                   asp-controller="HrApplications" asp-action="Index"
                                   asp-route-jobPostingId="@item.Id" title="View Candidates">
                                    <i class="fa-solid fa-users"></i>
                                </a>
                               
                                @if (item.PostingStatus == "Draft" || item.PostingStatus == "Paused")
                                {
                                    <a class="btn btn-icon btn-sm btn-icon-warning"
                                       asp-action="Edit" asp-route-id="@item.Id" title="Edit">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="empty-state" data-table-empty>
                <i class="fa-solid fa-briefcase"></i>
                <h3 class="h6 mt-2 mb-1">No job postings yet</h3>
                <p class="text-muted mb-0">
                    @if (pending.Any())
                    {
                        <span>Use the panel above to create a posting for your assigned requisition.</span>
                    }
                    else
                    {
                        <span>Postings appear here once a requisition assigned to you has a posting created.</span>
                    }
                </p>
            </div>
        }
    </div>
    <div class="table-footer">
        <span class="text-muted small fw-semibold">Showing @Model.FirstItemOnPage–@Model.LastItemOnPage of @Model.TotalItemCount</span>
        <nav aria-label="Job postings pagination">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page, search = currentFilter, requisitionId }), new PagedListRenderOptions
            {
                UlElementClasses = new[] { "pagination", "pagination-sm", "mb-0" },
                LiElementClasses = new[] { "page-item" },
                PageClasses = new[] { "page-link" }
            })
        </nav>
    </div>
</section>
