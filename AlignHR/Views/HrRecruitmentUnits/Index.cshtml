@model IList<AlignHR.Models.HrRecruitmentUnitListItemViewModel>

@{
    ViewData["Title"] = "Recruitment Dept Mapping";
    ViewBag.ActivePage = "HrRecruitmentUnits";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2 small">
        @TempData["Success"]<button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-2 small">
        @TempData["Error"]<button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}

<section class="filter-bar mb-2" aria-label="Recruitment mapping actions">
    <p class="text-muted small mb-0 me-auto">
        Map each business department to the recruitment department that handles its hiring.
    </p>
    <div class="filter-group">
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="fa-solid fa-plus me-1"></i>Add Mapping
        </a>
    </div>
</section>

<section class="table-shell" data-erp-table>
    <div class="erp-table-wrap">
        <table class="table table-hover erp-table">
            <thead>
                <tr>
                    <th>Business Department</th>
                    <th>Recruitment Department</th>
                    <th class="text-center">Recruiters</th>
                    <th class="text-end sticky-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.BusinessDepartmentName</td>
                        <td>@item.RecruitmentDepartmentName</td>
                        <td class="text-center">@item.RecruiterCount</td>
                        <td class="text-end sticky-actions">
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-icon btn-sm btn-icon-primary" title="Edit">
                                <i class="fa-solid fa-pen"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                  class="d-inline"
                                  onsubmit="return confirm('Remove this mapping?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-icon btn-sm btn-icon-danger" title="Remove">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="empty-state" data-table-empty>
                <i class="fa-solid fa-arrows-left-right-to-line"></i>
                <h3 class="h6 mt-2 mb-1">No mappings configured</h3>
                <p class="text-muted mb-0">Add a mapping to define which recruitment department handles each business department's hiring.</p>
            </div>
        }
    </div>
</section>
