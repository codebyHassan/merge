@using AlignHR.Controllers
@model OfferResponseViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Job Offer — AlignHR</title>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{background:#F4F5F7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px}
    .card{background:#fff;border:1px solid #E5E7EB;border-radius:10px;width:100%;max-width:520px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,.07)}
    .hdr{background:#111827;padding:18px 24px;display:flex;align-items:center;gap:10px}
    .logo-box{width:28px;height:28px;background:#fff;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:#111827;letter-spacing:-1px;flex-shrink:0}
    .brand{color:#fff;font-size:14px;font-weight:600;letter-spacing:-.3px}
    .body{padding:28px 24px}
    .ref{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#9CA3AF;margin-bottom:6px}
    h1{font-size:18px;font-weight:700;color:#111827;margin-bottom:4px;line-height:1.3}
    .sub{font-size:13px;color:#6B7280;margin-bottom:20px}
    .info-box{background:#F9FAFB;border:1px solid #E5E7EB;border-radius:8px;padding:16px 18px;margin-bottom:20px}
    .info-row{display:flex;align-items:baseline;gap:8px;margin-bottom:8px;font-size:13.5px}
    .info-row:last-child{margin-bottom:0}
    .lbl{color:#9CA3AF;font-size:12px;width:90px;flex-shrink:0}
    .val{color:#111827;font-weight:600}
    .divider{border:none;border-top:1px solid #E5E7EB;margin:20px 0}
    /* Pending state */
    .action-hint{font-size:13px;color:#374151;margin-bottom:16px}
    .btn-group{display:flex;gap:10px;flex-wrap:wrap}
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:10px 20px;border-radius:6px;font-size:13.5px;font-weight:600;cursor:pointer;border:none;transition:background .15s,opacity .15s}
    .btn-accept{background:#15803D;color:#fff;flex:1}
    .btn-accept:hover{background:#166534}
    .btn-decline{background:#fff;color:#B91C1C;border:1px solid #FECACA;flex:1}
    .btn-decline:hover{background:#FEF2F2}
    .form-label{font-size:12px;font-weight:600;color:#374151;display:block;margin-bottom:6px}
    .form-input{width:100%;padding:8px 10px;border:1px solid #D1D5DB;border-radius:6px;font-size:13.5px;color:#111827;outline:none;font-family:inherit}
    .form-input:focus{border-color:#111827;box-shadow:0 0 0 2px rgba(17,24,39,.08)}
    /* Status states */
    .state-icon{font-size:36px;margin-bottom:12px;display:block;text-align:center}
    .state-msg{text-align:center}
    .state-msg h2{font-size:18px;font-weight:700;color:#111827;margin-bottom:6px}
    .state-msg p{font-size:13.5px;color:#6B7280;line-height:1.6}
    .badge{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;font-size:12px;font-weight:600;margin-top:12px}
    .badge-accepted{background:#F0FDF4;color:#15803D;border:1px solid #BBF7D0}
    .badge-declined{background:#FEF2F2;color:#B91C1C;border:1px solid #FECACA}
    .badge-expired {background:#F9FAFB;color:#6B7280;border:1px solid #E5E7EB}
    footer{margin-top:20px;font-size:12px;color:#9CA3AF;text-align:center}
    footer a{color:#9CA3AF}
  </style>
</head>
<body>

<div class="card">
  <div class="hdr">
    <div class="logo-box">A</div>
    <span class="brand">AlignHR</span>
  </div>
  <div class="body">

    @if (Model.State == OfferResponseState.Pending)
    {
      <div class="ref">Offer · @Model.OfferNumber</div>
      <h1>You have a job offer, @Model.CandidateName.Split(' ')[0]!</h1>
      <p class="sub">Please review and respond before @(Model.ExpiryDate?.ToString("dd MMM yyyy") ?? "—").</p>

      <div class="info-box">
        <div class="info-row"><span class="lbl">Position</span><span class="val">@Model.JobTitle</span></div>
        <div class="info-row"><span class="lbl">Salary</span><span class="val">PKR @Model.Salary.ToString("N0") / month</span></div>
        <div class="info-row"><span class="lbl">Expires</span><span class="val">@(Model.ExpiryDate?.ToString("dd MMM yyyy") ?? "—")</span></div>
      </div>

      @if (Model.Notes.Any())
      {
        <div style="background:#F9FAFB;border:1px solid #E5E7EB;border-radius:8px;padding:14px 18px;margin-bottom:20px;">
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#9CA3AF;margin-bottom:8px;">Offer Terms &amp; Notes</div>
          <ul style="margin:0;padding-left:18px;">
            @foreach (var note in Model.Notes)
            {
              <li style="font-size:13.5px;color:#374151;margin-bottom:4px;">@note</li>
            }
          </ul>
        </div>
      }

      <hr class="divider"/>

      <form method="post" asp-action="Accept" asp-controller="OfferResponse">
        @Html.AntiForgeryToken()
        <input type="hidden" name="token" value="@Model.Token"/>
        <label class="form-label">Your intended joining date</label>
        @if (ViewData["JoiningError"] != null)
        {
            <div style="color:#DC2626;font-size:13px;margin-bottom:8px;">@ViewData["JoiningError"]</div>
        }
        <input type="date" name="joiningDate" class="form-input" required
               min="@DateTime.Today.ToString("yyyy-MM-dd")"
               max="@DateTime.Today.AddYears(1).ToString("yyyy-MM-dd")" style="margin-bottom:12px;" />
        <label class="form-label">Comments <span style="font-weight:400;color:#9CA3AF;">(optional)</span></label>
        <textarea name="comments" class="form-input" rows="3" placeholder="Any questions or notes for the HR team…"
                  style="margin-bottom:12px;resize:vertical;"></textarea>
        <button type="submit" class="btn btn-accept" style="width:100%;">✓ Accept Offer</button>
      </form>
    }

    @if (Model.State == OfferResponseState.Accepted)
    {
      <div class="state-msg">
        <span class="state-icon">🎉</span>
        <h2>Offer Accepted!</h2>
        <p>You have accepted the offer for <strong>@Model.JobTitle</strong>.<br/>
        @if (Model.JoiningDate.HasValue)
        {
          <text>Your joining date is <strong>@Model.JoiningDate.Value.ToString("dd MMM yyyy")</strong>. </text>
        }
        else if (Model.PriorComments != null)
        {
          <text>@Model.PriorComments</text>
        }
        Our team will be in touch with the next steps.</p>
        <span class="badge badge-accepted">✓ Accepted</span>
      </div>
    }

    @if (Model.State == OfferResponseState.Declined)
    {
      <div class="state-msg">
        <span class="state-icon">👋</span>
        <h2>Offer Declined</h2>
        <p>You have declined the offer for <strong>@Model.JobTitle</strong>. Thank you for your time — we wish you the best in your career.</p>
        <span class="badge badge-declined">✕ Declined</span>
      </div>
    }

    @if (Model.State == OfferResponseState.Expired)
    {
      <div class="state-msg">
        <span class="state-icon">⏰</span>
        <h2>This offer has expired</h2>
        <p>The offer for <strong>@Model.JobTitle</strong> is no longer active. If you believe this is an error, please contact your recruiter.</p>
        <span class="badge badge-expired">Expired</span>
      </div>
    }

  </div>
</div>

<footer>AlignHR · Recruitment Management System</footer>

</body>
</html>
