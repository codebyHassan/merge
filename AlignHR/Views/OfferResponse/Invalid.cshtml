@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Invalid Link — AlignHR</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{background:#F4F5F7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px}
    .card{background:#fff;border:1px solid #E5E7EB;border-radius:10px;width:100%;max-width:460px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,.07)}
    .hdr{background:#111827;padding:18px 24px;display:flex;align-items:center;gap:10px}
    .logo-box{width:28px;height:28px;background:#fff;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:#111827}
    .brand{color:#fff;font-size:14px;font-weight:600}
    .body{padding:32px 24px;text-align:center}
    .icon{font-size:36px;margin-bottom:14px}
    h1{font-size:18px;font-weight:700;color:#111827;margin-bottom:8px}
    p{font-size:13.5px;color:#6B7280;line-height:1.6}
    footer{margin-top:20px;font-size:12px;color:#9CA3AF}
  </style>
</head>
<body>
<div class="card">
  <div class="hdr">
    <div class="logo-box">A</div>
    <span class="brand">AlignHR</span>
  </div>
  <div class="body">
    <div class="icon">🔗</div>
    <h1>This link is invalid or has expired</h1>
    <p>The offer link you followed is not valid. It may have already been used, or the link may be incorrect.<br/><br/>Please contact your recruiter if you need assistance.</p>
  </div>
</div>
<footer>AlignHR · Recruitment Management System</footer>
</body>
</html>
