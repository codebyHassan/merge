@model AlignHR.Models.LeavePolicy

@{
    ViewData["Title"] = "Create Leave Policy";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.ActivePage = "LeavePolicies";

    ViewData["BreadcrumbPath"] = new[] { "Leave Policies", "Create" };
    ViewData["BreadcrumbUrls"] = new[] { Url.Action("Index", "LeavePolicies"), null };
}

@section Styles {
    <style>
        .policy-compact {
            border: 1px solid #d8dee8;
            border-radius: 8px;
            background: #fff;
            box-shadow: 0 4px 12px rgba(16, 24, 40, 0.06);
        }

        .policy-compact__body {
            padding: 12px;
        }

        .policy-section {
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            background: #f8fafc;
            padding: 10px;
            margin-bottom: 10px;
        }

        .policy-section:last-of-type {
            margin-bottom: 0;
        }

        .policy-section__title {
            margin: 0 0 8px;
            font-size: 13px;
            font-weight: 800;
            color: #111827;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .policy-section__title i {
            color: #111827;
            font-size: 12px;
        }

        .policy-actions {
            padding-top: 10px;
            margin-top: 10px;
            border-top: 1px solid #e5e7eb;
            display: flex;
            justify-content: flex-end;
            gap: 8px;
        }
    </style>
}

<div class="policy-compact">
    <div class="policy-compact__body">
        <form asp-action="Create" method="post" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <section class="policy-section">
                <h2 class="policy-section__title"><i class="fa-solid fa-layer-group"></i>Policy Basics</h2>
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-lg-8">
                        <label asp-for="PolicyName" class="form-label small fw-semibold mb-1">Policy Name <span class="text-danger">*</span></label>
                        <input asp-for="PolicyName" class="form-control form-control-sm" placeholder="e.g. Standard Corporate Leave" />
                        <span asp-validation-for="PolicyName" class="text-danger small"></span>
                    </div>

                    <div class="col-12 col-lg-4 ">
                        <label asp-for="IsActive" class="form-label small fw-semibold mb-1">Status</label>
                        <div class="form-check form-switch m-0 ">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                        </div>
                    </div>
                </div>
            </section>

            <section class="policy-section">
                <h2 class="policy-section__title"><i class="fa-solid fa-calendar-days"></i>Timeline and Notes</h2>
                <div class="row g-2">
                    <div class="col-md-3">
                        <div class=" col-md-12">
                            <label asp-for="EffectiveFrom" class="form-label small fw-semibold mb-1">Start Date <span class="text-danger">*</span></label>
                            <input asp-for="EffectiveFrom" type="date" class="form-control form-control-sm" />
                            <span asp-validation-for="EffectiveFrom" class="text-danger small"></span>
                        </div>
                        <div class=" col-md-12">
                            <label asp-for="EffectiveTo" class="form-label small fw-semibold mb-1">End Date</label>
                            <input asp-for="EffectiveTo" type="date" class="form-control form-control-sm" />
                            <span asp-validation-for="EffectiveTo" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-12 col-md-9">
                        <label asp-for="Description" class="form-label small fw-semibold mb-1">Description / Scope</label>
                        <textarea asp-for="Description" class="form-control form-control-sm" rows="4" placeholder="Summarize what this policy covers and how it should be used."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                </div>
            </section>

            <div class="policy-actions">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back</a>
                <button type="submit" class="btn btn-primary btn-sm">
                    Save
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
