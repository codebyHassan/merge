@model IPagedList<AlignHR.Models.LeavePolicy>
@using X.PagedList
@using X.PagedList.Mvc.Core
@using X.PagedList.Web.Common

@{
    ViewData["Title"] = "Leave Policies";
    ViewBag.ActivePage = "LeavePolicies";
    ViewBag.LtP = "lp";
    var currentFilter = ViewData["CurrentFilter"]?.ToString();
}

<section class="filter-bar mb-2" aria-label="Leave policies filters">
    <div class="input-group input-group-sm me-auto" style="width: auto;">
        <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input class="form-control"
               type="search"
               name="searchQuery"
               value="@currentFilter"
               placeholder="Search leave policy"
               aria-label="Search records"
               hx-get="@Url.Action("Index")"
               hx-target="#leave-policies-index-page"
               hx-select="#leave-policies-index-page"
               hx-trigger="keyup[key=='Enter'], search"
               hx-include="[name='searchQuery']"
               hx-push-url="true"
               form="none" />
    </div>
    <div class="filter-group">
        <div class="dropdown">
            <button class="btn btn-export-custom btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-boundary="viewport">
                Columns
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Policy Name" checked />Policy Name</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Description" checked />Description</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Effective From" checked />Effective From</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Effective To" checked />Effective To</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Status" checked />Status</label></li>
                <li><label class="dropdown-item"><input class="form-check-input me-2" type="checkbox" data-column-toggle="Created" checked />Created</label></li>
            </ul>
        </div>
        <a class="btn btn-primary btn-sm" asp-action="Create"><i class="fa-solid fa-plus me-1"></i>Create</a>
    </div>
</section>

<section class="table-shell" data-erp-table id="leave-policies-index-page">
    <div class="erp-table-wrap">
        <table class="table table-hover erp-table">
            <thead>
                <tr>
                    <th scope="col"><button class="table-sort" type="button" data-sort="1">Policy Name</button></th>
                    <th scope="col">Description</th>
                    <th scope="col">Effective From</th>
                    <th scope="col">Effective To</th>
                    <th scope="col">Status</th>
                    <th scope="col">Created</th>
                    <th scope="col" class="text-end sticky-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td data-label="Policy Name"><span class="fw-semibold">@item.PolicyName</span></td>
                        <td data-label="Description">@(string.IsNullOrWhiteSpace(item.Description) ? "-" : item.Description)</td>
                        <td data-label="Effective From">@item.EffectiveFrom.ToString("dd MMM yyyy")</td>
                        <td data-label="Effective To">@(item.EffectiveTo?.ToString("dd MMM yyyy") ?? "-")</td>
                        <td data-label="Status"><span class="status-badge @(item.IsActive ? "status-active" : "status-risk")">@(item.IsActive ? "Active" : "Inactive")</span></td>
                        <td data-label="Created">@item.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td data-label="Actions" class="text-end sticky-actions">
                            <div class="d-flex justify-content-end gap-1">
                                <a class="btn btn-icon btn-sm btn-icon-success" asp-controller="LeavePolicyRules" asp-action="Index" asp-route-leavePolicyId="@item.Id" title="Manage Rules"><i class="fa-solid fa-list-check"></i></a>
                                <a class="btn btn-icon btn-sm btn-icon-primary" asp-action="Edit" asp-route-id="@item.Id" title="Edit"><i class="fa-solid fa-pen-to-square"></i></a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Are you sure you want to delete this leave policy?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-icon btn-sm btn-icon-danger" title="Delete">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="empty-state" data-table-empty>
                <i class="fa-solid fa-inbox"></i>
                <h3 class="h6 mt-2 mb-1">No records match the current filters</h3>
                <p class="text-muted mb-0">Adjust search or create a new leave policy.</p>
            </div>
        }
    </div>

    <div class="table-footer">
        <span class="text-muted small fw-semibold">Showing @Model.FirstItemOnPage-@Model.LastItemOnPage of @Model.TotalItemCount</span>
        <nav aria-label="Leave policies pagination">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page, searchQuery = currentFilter }), new PagedListRenderOptions
            {
                UlElementClasses = new[] { "pagination", "pagination-sm", "mb-0" },
                LiElementClasses = new[] { "page-item" },
                PageClasses = new[] { "page-link" }
            })
        </nav>
    </div>
</section>
