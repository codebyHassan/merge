@model AlignHR.Models.Employee
@{
    ViewData["Title"] = "Edit Employee";
    ViewBag.ActivePage = "Employees";
}

<form asp-action="Edit" method="post" id="employeeEditForm" class="employee-create needs-validation" enctype="multipart/form-data" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
    <input type="hidden" asp-for="Id" />

    <div class="employee-create-grid">
        <aside class="employee-profile-panel">
            <div class="profile-card-compact">
                <div class="profile-avatar-upload">
                    @if (!string.IsNullOrEmpty(Model.ProfileImage))
                    {
                        <span id="employeeInitials" style="background-image: url('/uploads/employees/@Model.ProfileImage'); background-size: cover; background-position: center;"></span>
                    }
                    else
                    {
                        <span id="employeeInitials">@(Model.FirstName?.Substring(0, 1))@(Model.LastName?.Substring(0, 1))</span>
                    }
                    <label class="btn btn-light btn-sm" for="imageInput" aria-label="Upload employee photo">
                        <i class="fa-solid fa-camera"></i>
                    </label>
                    <input type="file" name="ImageFile" id="imageInput" class="visually-hidden" accept="image/*" />
                </div>
                <div>
                    <strong id="employeeProfileName">@Model.FirstName @Model.LastName</strong>
                    <span>@Model.Code</span>
                </div>
            </div>
        </aside>

        <main class="employee-form-main">
            <ul class="nav nav-tabs border-0 mb-0" id="employeeTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="identity-tab" data-bs-toggle="tab" data-bs-target="#identity-pane" type="button" role="tab"><i class="fa-solid fa-id-card me-1"></i> Identity</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="contact-tab" data-bs-toggle="tab" data-bs-target="#contact-pane" type="button" role="tab"><i class="fa-solid fa-phone me-1"></i> Contact</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="employment-tab" data-bs-toggle="tab" data-bs-target="#employment-pane" type="button" role="tab"><i class="fa-solid fa-briefcase me-1"></i> Employment</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="reporting-tab" data-bs-toggle="tab" data-bs-target="#reporting-pane" type="button" role="tab"><i class="fa-solid fa-sitemap me-1"></i> Reporting</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="payroll-tab" data-bs-toggle="tab" data-bs-target="#payroll-pane" type="button" role="tab"><i class="fa-solid fa-money-bill-wave me-1"></i> Payroll & Statutory</button>
                </li>
            </ul>

            <div class="tab-content" id="employeeTabsContent">

                @* ── TAB 1: IDENTITY ───────────────────────────────────────────────── *@
                <div class="tab-pane fade show active" id="identity-pane" role="tabpanel">
                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="Code" class="form-label text-muted small fw-bold">Employee Code</label>
                            <input asp-for="Code" class="form-control" readonly />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="FirstName" class="form-label">First Name</label>
                            <input asp-for="FirstName" class="form-control" placeholder="First name" id="FirstName" />
                            <span asp-validation-for="FirstName" class="invalid-feedback"></span>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="LastName" class="form-label">Last Name</label>
                            <input asp-for="LastName" class="form-control" placeholder="Last name" id="LastName" />
                            <span asp-validation-for="LastName" class="invalid-feedback"></span>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="FatherHusbandName" class="form-label">Father / Husband Name</label>
                            <input asp-for="FatherHusbandName" class="form-control" placeholder="Father or husband name" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="DateOfBirth" class="form-label">Date of Birth</label>
                            <input asp-for="DateOfBirth" type="date" class="form-control" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="GenderFk" class="form-label">Gender</label>
                            <select asp-for="GenderFk" class="form-select" asp-items="ViewBag.Genders">
                                <option value="">Select gender</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="MaritalStatusFk" class="form-label">Marital Status</label>
                            <select asp-for="MaritalStatusFk" class="form-select" asp-items="ViewBag.MaritalStatuses">
                                <option value="">Select status</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="ReligionFk" class="form-label">Religion</label>
                            <select asp-for="ReligionFk" class="form-select" asp-items="ViewBag.Religions">
                                <option value="">Select religion</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="CNIC" class="form-label">CNIC</label>
                            <input asp-for="CNIC" class="form-control" placeholder="35202-1234567-1" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="CNICIssueDate" class="form-label">CNIC Issue Date</label>
                            <input asp-for="CNICIssueDate" type="date" class="form-control" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="CNICExpDate" class="form-label">CNIC Expiry Date</label>
                            <input asp-for="CNICExpDate" type="date" class="form-control" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="NationalityFk" class="form-label">Nationality</label>
                            <select asp-for="NationalityFk" class="form-select" asp-items="ViewBag.Nationalities">
                                <option value="">Select nationality</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="CitizenshipFk" class="form-label">Citizenship</label>
                            <select asp-for="CitizenshipFk" class="form-select" asp-items="ViewBag.Citizenships">
                                <option value="">Select citizenship</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="BloodGroupFk" class="form-label">Blood Group</label>
                            <select asp-for="BloodGroupFk" class="form-select" asp-items="ViewBag.BloodGroups">
                                <option value="">Select blood group</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="DomicileFk" class="form-label">Domicile</label>
                            <select asp-for="DomicileFk" class="form-select" asp-items="ViewBag.Domiciles">
                                <option value="">Select domicile</option>
                            </select>
                        </div>
                    </div>
                </div>

                @* ── TAB 2: CONTACT ────────────────────────────────────────────────── *@
                <div class="tab-pane fade" id="contact-pane" role="tabpanel">
                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="MobilePersonal" class="form-label">Personal Mobile</label>
                            <input asp-for="MobilePersonal" class="form-control" placeholder="+92-300-0000000" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="MobileOfficial" class="form-label">Official Mobile</label>
                            <input asp-for="MobileOfficial" class="form-control" placeholder="+92-300-0000000" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="EmailPersonal" class="form-label">Personal Email</label>
                            <input asp-for="EmailPersonal" type="email" class="form-control" placeholder="personal@email.com" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="EmailOfficial" class="form-label">Official Email</label>
                            <input asp-for="EmailOfficial" type="email" class="form-control" placeholder="name@company.com" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="ExtensionNo" class="form-label">Extension No.</label>
                            <input asp-for="ExtensionNo" class="form-control" placeholder="e.g. 101" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label asp-for="AddressCurrent" class="form-label">Current Address</label>
                            <textarea asp-for="AddressCurrent" class="form-control" rows="2" placeholder="Current residential address"></textarea>
                        </div>
                        <div class="col-12 col-md-6">
                            <label asp-for="AddressPermanent" class="form-label">Permanent Address</label>
                            <textarea asp-for="AddressPermanent" class="form-control" rows="2" placeholder="Permanent address"></textarea>
                        </div>
                    </div>
                </div>

                @* ── TAB 3: EMPLOYMENT ─────────────────────────────────────────────── *@
                <div class="tab-pane fade" id="employment-pane" role="tabpanel">
                    <div class="row g-3">
                        <div class="col-12"><p class="text-muted small fw-bold mb-0 text-uppercase">Organizational Structure</p></div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="DepartmentFk" class="form-label">Department</label>
                            <select asp-for="DepartmentFk" class="form-select" asp-items="ViewBag.Departments">
                                <option value="">Select department</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="SubDepartmentFk" class="form-label">Sub Department</label>
                            <select asp-for="SubDepartmentFk" class="form-select" asp-items="ViewBag.SubDepartments">
                                <option value="">Select sub-dept</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="DesiginationId" class="form-label">Designation</label>
                            <select asp-for="DesiginationId" class="form-select" asp-items="ViewBag.Designations">
                                <option value="">Select designation</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="GradeFk" class="form-label">Grade</label>
                            <select asp-for="GradeFk" class="form-select" asp-items="ViewBag.Grades">
                                <option value="">Select grade</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="DivisionFk" class="form-label">Division</label>
                            <select asp-for="DivisionFk" class="form-select" asp-items="ViewBag.Divisions">
                                <option value="">Select division</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="BranchFk" class="form-label">Branch</label>
                            <select asp-for="BranchFk" class="form-select" asp-items="ViewBag.Branches">
                                <option value="">Select branch</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="FunctionFk" class="form-label">Function</label>
                            <select asp-for="FunctionFk" class="form-select" asp-items="ViewBag.Functions">
                                <option value="">Select function</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="GroupFk" class="form-label">Group</label>
                            <select asp-for="GroupFk" class="form-select" asp-items="ViewBag.Groups">
                                <option value="">Select group</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="CostCenterFk" class="form-label">Cost Center</label>
                            <select asp-for="CostCenterFk" class="form-select" asp-items="ViewBag.CostCenters">
                                <option value="">Select cost center</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="LocationFk" class="form-label">Work Location</label>
                            <select asp-for="LocationFk" class="form-select" asp-items="ViewBag.Locations">
                                <option value="">Select location</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="CityFk" class="form-label">City</label>
                            <select asp-for="CityFk" class="form-select" asp-items="ViewBag.Cities">
                                <option value="">Select city</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="CountryFk" class="form-label">Country</label>
                            <select asp-for="CountryFk" class="form-select" asp-items="ViewBag.Countries">
                                <option value="">Select country</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="Position" class="form-label">Position</label>
                            <input asp-for="Position" class="form-control" placeholder="e.g. Senior Engineer" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="JobClassification" class="form-label">Job Classification</label>
                            <input asp-for="JobClassification" class="form-control" placeholder="e.g. Permanent" />
                        </div>

                        <div class="col-12 mt-2"><p class="text-muted small fw-bold mb-0 text-uppercase">Employment Details</p></div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="EmploymentTypeFk" class="form-label">Emp. Type</label>
                            <select asp-for="EmploymentTypeFk" class="form-select" asp-items="ViewBag.EmploymentTypes">
                                <option value="">Select type</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="EmploymentStatusFk" class="form-label">Emp. Status</label>
                            <select asp-for="EmploymentStatusFk" class="form-select" asp-items="ViewBag.EmploymentStatuses">
                                <option value="">Select status</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="Dateofjoin" class="form-label">Joining Date</label>
                            <input asp-for="Dateofjoin" type="date" class="form-control" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="RetirementDate" class="form-label">Retirement Date</label>
                            <input asp-for="RetirementDate" type="date" class="form-control" />
                        </div>

                        <div class="col-12 mt-2"><p class="text-muted small fw-bold mb-0 text-uppercase">Confirmation</p></div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="ConfirmationDueDate" class="form-label">Confirmation Due Date</label>
                            <input asp-for="ConfirmationDueDate" type="date" class="form-control" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="ConfirmationDate" class="form-label">Confirmation Date</label>
                            <input asp-for="ConfirmationDate" type="date" class="form-control" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3 d-flex align-items-end pb-1">
                            <div class="form-check form-switch">
                                <input asp-for="IsConfirmed" class="form-check-input" type="checkbox" id="isConfirmedCheck" />
                                <label class="form-check-label" for="isConfirmedCheck">Confirmed Employee</label>
                            </div>
                        </div>
                    </div>
                </div>

                @* ── TAB 4: REPORTING ──────────────────────────────────────────────── *@
                <div class="tab-pane fade" id="reporting-pane" role="tabpanel">
                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="LineManagerEmpNo" class="form-label">Reporting Manager (Code)</label>
                            <input asp-for="LineManagerEmpNo" class="form-control" placeholder="e.g. EMP-001" />
                            <span asp-validation-for="LineManagerEmpNo" class="invalid-feedback"></span>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="LeaveApproverEmpNo" class="form-label">Leave Approver (Code)</label>
                            <input asp-for="LeaveApproverEmpNo" class="form-control" placeholder="e.g. EMP-002" />
                            <span asp-validation-for="LeaveApproverEmpNo" class="invalid-feedback"></span>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="HRBPEmpNo" class="form-label">HR Business Partner (Code)</label>
                            <input asp-for="HRBPEmpNo" class="form-control" placeholder="e.g. EMP-003" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3 d-flex align-items-end pb-1">
                            <div class="form-check form-switch">
                                <input asp-for="CanApplyForOthers" class="form-check-input" type="checkbox" id="canApplyOthers" />
                                <label class="form-check-label" for="canApplyOthers">Can apply leave for others</label>
                            </div>
                        </div>
                    </div>
                </div>

                @* ── TAB 5: PAYROLL & STATUTORY ────────────────────────────────────── *@
                <div class="tab-pane fade" id="payroll-pane" role="tabpanel">
                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="BankNameFk" class="form-label">Bank Name</label>
                            <select asp-for="BankNameFk" class="form-select" asp-items="ViewBag.BankNames">
                                <option value="">Select bank</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="BankHolderName" class="form-label">Account Holder</label>
                            <input asp-for="BankHolderName" class="form-control" placeholder="Account name" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="AccountNumber" class="form-label">IBAN / Account</label>
                            <input asp-for="AccountNumber" class="form-control" placeholder="PK00..." />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="PessiRegNo" class="form-label">PESSI Reg. No.</label>
                            <input asp-for="PessiRegNo" class="form-control" placeholder="PESSI number" />
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label asp-for="SalaryStatus" class="form-label">Salary Status</label>
                            <input asp-for="SalaryStatus" class="form-control bg-light" readonly id="salaryStatusInput" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label text-muted small fw-bold">SERVICE CONTROLS</label>
                            <div class="d-flex gap-4 p-2 border rounded-2 bg-light bg-opacity-10">
                                <div class="form-check form-switch">
                                    <input asp-for="IsServiceEnded" class="form-check-input" type="checkbox" id="isServiceEndedCheck" />
                                    <label class="form-check-label small" for="isServiceEndedCheck">Service Ended</label>
                                </div>
                                <div class="form-check form-switch">
                                    <input asp-for="IsSalaryStopped" class="form-check-input" type="checkbox" id="isSalaryStoppedCheck" />
                                    <label class="form-check-label small" for="isSalaryStoppedCheck">Salary Stopped</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3" id="serviceEndDateContainer" style="display: none;">
                            <label asp-for="ServiceEndDate" class="form-label">Service End Date</label>
                            <input asp-for="ServiceEndDate" type="datetime-local" class="form-control" id="serviceEndDateInput" readonly />
                        </div>

                        <div class="col-12 mt-3">
                            <div class="row g-3">
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="deduction-card h-100">
                                        <div class="deduction-header">
                                            <label class="form-check-label" for="filerToggle">Filer Status</label>
                                            <div class="form-check form-switch form-check-premium">
                                                <input class="form-check-input" type="checkbox" asp-for="IsFiler" id="filerToggle">
                                            </div>
                                        </div>
                                        <div class="deduction-body deduction-animate-container" id="ntnContainer">
                                            <label asp-for="NTN" class="form-label small text-muted">NTN Number</label>
                                            <input asp-for="NTN" class="form-control form-control-sm" placeholder="4444-333-1" id="ntnInput" />
                                            <span id="ntnError" class="text-danger x-small" style="display: none;">Limit 8 digits</span>
                                        </div>
                                        <div class="mt-2 pt-2 border-top border-light">
                                            <div class="d-flex gap-3">
                                                <div class="form-check">
                                                    <input asp-for="TaxExempted" class="form-check-input" type="checkbox" id="taxExempt" />
                                                    <label class="form-check-label small" for="taxExempt">Exempted</label>
                                                </div>
                                                <div class="form-check">
                                                    <input asp-for="ZakatDeduction" class="form-check-input" type="checkbox" id="zakatDec" />
                                                    <label class="form-check-label small" for="zakatDec">Zakat Dec.</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="deduction-card h-100">
                                        <div class="deduction-header">
                                            <label class="form-check-label" for="eobiToggle">EOBI Membership</label>
                                            <div class="form-check form-switch form-check-premium">
                                                <input class="form-check-input" type="checkbox" asp-for="isEobi" id="eobiToggle">
                                            </div>
                                        </div>
                                        <div class="deduction-body deduction-animate-container" id="eobiNumberContainer">
                                            <label asp-for="EobiNumber" class="form-label small text-muted">EOBI Number</label>
                                            <input asp-for="EobiNumber" class="form-control form-control-sm" placeholder="EOBI #" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="deduction-card h-100">
                                        <div class="deduction-header">
                                            <label class="form-check-label" for="ssToggle">Social Security (PESSI)</label>
                                            <div class="form-check form-switch form-check-premium">
                                                <input class="form-check-input" type="checkbox" asp-for="isSocailSecuirty" id="ssToggle">
                                            </div>
                                        </div>
                                        <div class="deduction-body deduction-animate-container" id="ssNumberContainer">
                                            <label asp-for="SocailSecuirty" class="form-label small text-muted">SS Number</label>
                                            <input asp-for="SocailSecuirty" class="form-control form-control-sm" placeholder="SS #" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="deduction-card h-100">
                                        <div class="deduction-header">
                                            <label class="form-check-label" for="overtimeToggle">Overtime Policy</label>
                                            <div class="form-check form-switch form-check-premium">
                                                <input class="form-check-input" type="checkbox" asp-for="isOverTime" id="overtimeToggle">
                                            </div>
                                        </div>
                                        <div class="deduction-body deduction-animate-container" id="overtimePolicyContainer">
                                            <select asp-for="OvertimePolicyId" class="form-select form-select-sm" id="overtimePolicyDropdown">
                                                <option value="">Select policy</option>
                                                @if (ViewBag.PoliciesList != null)
                                                {
                                                    foreach (var policy in (IEnumerable<AlignHR.Models.Overtime>)ViewBag.PoliciesList)
                                                    {
                                                        <option value="@policy.OvertimeId"
                                                                selected="@(Model?.OvertimePolicyId == policy.OvertimeId || (Model?.OvertimePolicyId == null && policy.IsDefault))"
                                                                disabled="@(policy.IsDefault ? "disabled" : null)">
                                                            @policy.PolicyName @(policy.IsDefault ? "(Default)" : "")
                                                        </option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="deduction-card h-100">
                                        <div class="deduction-header">
                                            <label class="form-check-label" for="pfToggle">PF Membership</label>
                                            <div class="form-check form-switch form-check-premium">
                                                <input class="form-check-input" type="checkbox" asp-for="isPfMember" id="pfToggle">
                                            </div>
                                        </div>
                                        <div class="deduction-body deduction-animate-container" id="pfNumberContainer">
                                            <div class="row g-2">
                                                <div class="col-12">
                                                    <input asp-for="pfmembernumber" class="form-control form-control-sm" placeholder="PF Number" />
                                                </div>
                                                <div class="col-12 mt-1">
                                                    <div class="d-flex align-items-center justify-content-between">
                                                        <label class="form-check-label x-small fw-bold" for="fixedPfToggle">FIXED AMOUNT?</label>
                                                        <div class="form-check form-switch">
                                                            <input class="form-check-input" type="checkbox" asp-for="IsFixedPFAmount" id="fixedPfToggle">
                                                        </div>
                                                    </div>
                                                    <div class="deduction-animate-container mt-1" id="pfAmountContainer">
                                                        <input asp-for="PFAmount" class="form-control form-control-sm" type="number" step="0.01" placeholder="0.00" />
                                                    </div>
                                                </div>
                                                <div class="col-12 mt-1">
                                                    <div class="form-check form-switch">
                                                        <input asp-for="IsPFProfit" class="form-check-input" type="checkbox" id="pfProfitToggle">
                                                        <label class="form-check-label x-small" for="pfProfitToggle">PF Profit</label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <div class="form-actions-sticky mt-0">
                <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Back</a>
                <button class="btn btn-primary btn-sm" type="submit">Save</button>
            </div>
        </main>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const imageInput = document.getElementById('imageInput');
            const initials   = document.getElementById('employeeInitials');
            const profileName = document.getElementById('employeeProfileName');
            const firstName  = document.getElementById('FirstName');
            const lastName   = document.getElementById('LastName');

            function updateProfileCard() {
                const first = (firstName?.value || '').trim();
                const last  = (lastName?.value  || '').trim();
                const next  = `${first.charAt(0)}${last.charAt(0)}`.toUpperCase();
                if (initials && !initials.style.backgroundImage) initials.textContent = next || 'NE';
                if (profileName) profileName.textContent = `${first} ${last}`.trim() || 'Employee';
            }
            firstName?.addEventListener('input', updateProfileCard);
            lastName?.addEventListener('input', updateProfileCard);

            if (imageInput && initials) {
                imageInput.addEventListener('change', function (e) {
                    const file = e.target.files[0];
                    if (!file) return;
                    const reader = new FileReader();
                    reader.onload = ev => {
                        initials.style.backgroundImage = `url("${ev.target.result}")`;
                        initials.style.backgroundSize  = 'cover';
                        initials.style.backgroundPosition = 'center';
                        initials.textContent = '';
                    };
                    reader.readAsDataURL(file);
                });
            }

            // Service controls
            const isServiceEndedCheck  = document.getElementById('isServiceEndedCheck');
            const isSalaryStoppedCheck = document.getElementById('isSalaryStoppedCheck');
            const salaryStatusInput    = document.getElementById('salaryStatusInput');
            const serviceEndDateContainer = document.getElementById('serviceEndDateContainer');
            const serviceEndDateInput  = document.getElementById('serviceEndDateInput');

            function updateStatus() {
                if (!isServiceEndedCheck || !isSalaryStoppedCheck || !salaryStatusInput) return;
                salaryStatusInput.value = (!isServiceEndedCheck.checked && !isSalaryStoppedCheck.checked) ? 'Active' : 'Inactive';
                if (!serviceEndDateContainer || !serviceEndDateInput) return;
                if (isServiceEndedCheck.checked) {
                    serviceEndDateContainer.style.display = '';
                    if (!serviceEndDateInput.value) {
                        const now = new Date();
                        serviceEndDateInput.value = new Date(now.getTime() - now.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
                    }
                } else {
                    serviceEndDateContainer.style.display = 'none';
                    serviceEndDateInput.value = '';
                }
            }
            isServiceEndedCheck?.addEventListener('change', updateStatus);
            isSalaryStoppedCheck?.addEventListener('change', updateStatus);

            // Toggle helper
            function toggleSection(toggle, container) {
                if (!toggle || !container) return;
                container.classList.toggle('show', toggle.checked);
            }

            const filerToggle       = document.getElementById('filerToggle');
            const ntnContainer      = document.getElementById('ntnContainer');
            const eobiToggle        = document.getElementById('eobiToggle');
            const eobiNumberContainer = document.getElementById('eobiNumberContainer');
            const ssToggle          = document.getElementById('ssToggle');
            const ssNumberContainer = document.getElementById('ssNumberContainer');
            const overtimeToggle    = document.getElementById('overtimeToggle');
            const overtimePolicyContainer = document.getElementById('overtimePolicyContainer');
            const overtimePolicyDropdown  = document.getElementById('overtimePolicyDropdown');
            const defaultPolicyId   = '@ViewBag.DefaultOvertimePolicyId';
            const pfToggle          = document.getElementById('pfToggle');
            const pfNumberContainer = document.getElementById('pfNumberContainer');
            const fixedPfToggle     = document.getElementById('fixedPfToggle');
            const pfAmountContainer = document.getElementById('pfAmountContainer');

            filerToggle?.addEventListener('change',    () => toggleSection(filerToggle, ntnContainer));
            eobiToggle?.addEventListener('change',     () => toggleSection(eobiToggle, eobiNumberContainer));
            ssToggle?.addEventListener('change',       () => toggleSection(ssToggle, ssNumberContainer));
            pfToggle?.addEventListener('change',       () => toggleSection(pfToggle, pfNumberContainer));
            fixedPfToggle?.addEventListener('change',  () => toggleSection(fixedPfToggle, pfAmountContainer));
            overtimeToggle?.addEventListener('change', function () {
                toggleSection(overtimeToggle, overtimePolicyContainer);
                if (overtimeToggle.checked && defaultPolicyId && overtimePolicyDropdown && !overtimePolicyDropdown.value)
                    overtimePolicyDropdown.value = defaultPolicyId;
            });

            const ntnInput = document.getElementById('ntnInput');
            const ntnError = document.getElementById('ntnError');
            ntnInput?.addEventListener('input', function (e) {
                let v = e.target.value.replace(/\D/g, '');
                if (v.length > 8) { v = v.substring(0, 8); if (ntnError) ntnError.style.display = 'block'; }
                else if (ntnError) ntnError.style.display = 'none';
                let f = v.substring(0, 4);
                if (v.length > 4) { f += '-' + v.substring(4, 7); if (v.length > 7) f += '-' + v.substring(7, 8); }
                e.target.value = f;
            });

            updateStatus();
            toggleSection(filerToggle, ntnContainer);
            toggleSection(eobiToggle, eobiNumberContainer);
            toggleSection(ssToggle, ssNumberContainer);
            toggleSection(pfToggle, pfNumberContainer);
            toggleSection(fixedPfToggle, pfAmountContainer);
            toggleSection(overtimeToggle, overtimePolicyContainer);
        });
    </script>
}
