@model AlignHR.Models.EmployeeLeavePolicy

@{
    ViewData["Title"] = "Assign Leave Policy";
    ViewBag.ActivePage = "EmployeeLeavePolicies";
}

<div class="form-shell w-100 animate-fade-in">
    <div class="card-inner">
        <form asp-action="Create" method="post" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger p-2 mb-3 small" role="alert">
                    <div asp-validation-summary="ModelOnly"></div>
                </div>
            }

            <div class="row g-3">

                <!-- Employee Search -->
                <div class="col-12 col-md-5" style="position: relative; z-index: 20;">
                    <label class="form-label small fw-semibold">Employee <span class="text-danger">*</span></label>
                    <div id="empSearchWrap">
                        <input type="text"
                               id="empSearch"
                               class="form-control form-control-sm"
                               placeholder="Search by name or code…"
                               hx-get="@Url.Action("SearchEmployees")"
                               hx-trigger="keyup changed delay:300ms"
                               hx-target="#empResults"
                               name="term"
                               autocomplete="off" />
                        <div id="empResults" class="elp-search-drop"></div>
                    </div>
                    <div id="empChip" class="mt-1" style="display:none;">
                        <span class="status-badge badge-success d-inline-flex align-items-center gap-1">
                            <i class="fa-solid fa-circle-check" style="font-size:10px;"></i>
                            <span id="empChipName"></span>
                            <button type="button" class="btn-close btn-close-white ms-1"
                                    style="font-size:8px;" onclick="clearEmpSelection()"></button>
                        </span>
                    </div>
                    <input type="hidden" asp-for="EmployeeId" id="empId" />
                    <span asp-validation-for="EmployeeId" class="text-danger small"></span>
                </div>

                <!-- Leave Policy -->
                <div class="col-12 col-md-4">
                    <label asp-for="LeavePolicyId" class="form-label small fw-semibold">Leave Policy <span class="text-danger">*</span></label>
                    <select asp-for="LeavePolicyId" class="form-select form-select-sm" asp-items="ViewBag.LeavePolicyId">
                        <option value="">— Select Policy —</option>
                    </select>
                    <span asp-validation-for="LeavePolicyId" class="text-danger small"></span>
                </div>

                <!-- Assignment Date -->
                <div class="col-12 col-md-3">
                    <label asp-for="AssignedAt" class="form-label small fw-semibold">Assigned Date</label>
                    <input asp-for="AssignedAt" type="date" class="form-control form-control-sm"
                           value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="AssignedAt" class="text-danger small"></span>
                </div>

                <!-- Active toggle -->
                <div class="col-12 col-md-4">
                    <label class="custom-toggle">
                        <input asp-for="IsActive" type="checkbox" checked />
                        <div class="toggle-switch"></div>
                        <div class="toggle-content">
                            <div class="toggle-title">Active Assignment</div>
                            <div class="toggle-desc">Employee currently follows this policy.</div>
                        </div>
                    </label>
                </div>

            </div>

            <div class="row mt-4">
                <div class="col-12 d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-check me-1"></i>Assign Policy
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Styles {
<style>
.elp-search-drop {
    position: absolute;
    top: calc(100% + 4px);
    left: 0; right: 0;
    z-index: 9999;
    background: var(--erp-surface);
    border: 1px solid var(--erp-border);
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(16,24,40,0.12);
    max-height: 240px;
    overflow-y: auto;
}
.elp-search-drop:empty { display: none; }
.elp-result-item {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    border-bottom: 1px solid var(--erp-border);
    transition: background 0.12s;
}
.elp-result-item:last-child { border-bottom: none; }
.elp-result-item:hover { background: var(--erp-surface-subtle); }
.elp-result-avatar {
    width: 30px; height: 30px;
    border-radius: 8px;
    background: var(--erp-primary-soft);
    color: var(--erp-primary);
    font-weight: 700; font-size: 11px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
</style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('click', function (e) {
            if (!e.target.closest('#empSearchWrap')) {
                document.getElementById('empResults').innerHTML = '';
            }
        });

        function selectEmployee(id, name) {
            document.getElementById('empId').value = id;
            document.getElementById('empChipName').textContent = name;
            document.getElementById('empChip').style.display = 'block';
            document.getElementById('empSearchWrap').style.display = 'none';
            document.getElementById('empResults').innerHTML = '';
        }

        function clearEmpSelection() {
            document.getElementById('empId').value = '';
            document.getElementById('empChip').style.display = 'none';
            document.getElementById('empSearchWrap').style.display = '';
            document.getElementById('empSearch').value = '';
            document.getElementById('empSearch').focus();
        }
    </script>
}
