@model AlignHR.Models.EmployeeLeavePolicy

@{
    ViewData["Title"] = "Assignment Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header animate-fade">
    <div>
        <h1 class="page-title">Assignment Details</h1>
        <p class="page-subtitle">Viewing policy assignment details for @Model.Employee?.FullName</p>
    </div>
    <div class="flex gap-8">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;margin-right:8px">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
            </svg>
            Edit Assignment
        </a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>

<div class="animate-fade" style="animation-delay: 0.1s">
    <div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 24px;">
        
        <!-- Left Column: Employee Card -->
        <div class="hr-card" style="margin-bottom:0;">
            <div class="card-header">
                <div class="card-title"><i class="fas fa-user"></i> Employee Details</div>
            </div>
            <div class="card-body">
                <div class="flex flex-column gap-16">
                    <div class="detail-item">
                        <label class="detail-label">Full Name</label>
                        <div class="detail-value font-medium">@Model.Employee?.FullName</div>
                    </div>
                    <div class="detail-item">
                        <label class="detail-label">Employee Code</label>
                        <div class="detail-value">@Model.Employee?.Code</div>
                    </div>
                    <div class="detail-item">
                        <label class="detail-label">Department</label>
                        <div class="detail-value">@Model.Employee?.Department?.Name</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Policy Assignment -->
        <div class="hr-card" style="margin-bottom:0;">
            <div class="card-header">
                <div class="card-title"><i class="fas fa-file-contract"></i> Policy Information</div>
            </div>
            <div class="card-body">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px;">
                    <div class="detail-item">
                        <label class="detail-label">Policy Name</label>
                        <div class="detail-value font-bold text-primary">@Model.LeavePolicy?.PolicyName</div>
                    </div>
                    <div class="detail-item">
                        <label class="detail-label">Status</label>
                        <div class="detail-value">
                            <span class="status-badge @(Model.IsActive ? "active" : "inactive")">
                                @(Model.IsActive ? "Active" : "Inactive")
                            </span>
                        </div>
                    </div>
                </div>

                <div class="detail-item mb-4">
                    <label class="detail-label">Assigned On</label>
                    <div class="detail-value">@Model.AssignedAt.ToString("F")</div>
                </div>

                <div class="alert alert-info">
                    <i class="fas fa-info-circle mr-2"></i>
                    This assignment determines which leave types and entitlement rules are applied to this employee.
                </div>
            </div>
        </div>
    </div>
</div>
