@model AlignHR.Models.EmployeeLeavePolicy

@{
    ViewData["Title"] = "Remove Policy Assignment";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header animate-fade">
    <div>
        <h1 class="page-title text-danger">Remove Assignment</h1>
        <p class="page-subtitle">Are you sure you want to unassign this policy from the employee?</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</div>

<div class="animate-fade" style="animation-delay: 0.1s">
    <div class="hr-card border-danger" style="max-width: 600px; margin: 0 auto;">
        <div class="card-header bg-danger-light">
            <div class="card-title text-danger"><i class="fas fa-exclamation-triangle"></i> Confirmation Required</div>
        </div>
        <div class="card-body">
            <div class="alert alert-warning mb-4">
                This will remove the link between <strong>@Model.Employee?.FullName</strong> and the <strong>@Model.LeavePolicy?.PolicyName</strong> policy.
            </div>

            <div class="flex flex-column gap-12 mb-4">
                <div class="flex justify-between py-2 border-bottom">
                    <span class="text-muted">Employee</span>
                    <span class="font-medium">@Model.Employee?.FullName</span>
                </div>
                <div class="flex justify-between py-2 border-bottom">
                    <span class="text-muted">Policy</span>
                    <span class="font-medium">@Model.LeavePolicy?.PolicyName</span>
                </div>
                <div class="flex justify-between py-2 border-bottom">
                    <span class="text-muted">Assigned On</span>
                    <span class="font-medium">@Model.AssignedAt.ToString("MMM dd, yyyy")</span>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="flex gap-12 justify-center mt-4">
                    <button type="submit" class="btn btn-danger">Yes, Unassign Policy</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
