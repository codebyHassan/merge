@model IEnumerable<AlignHR.Models.FunctionRole>
@using AlignHR.Security
@{
    ViewData["Title"] = "Function Roles";
    ViewBag.ActivePage = "FunctionRole";
}

<section class="filter-bar mb-2" aria-label="Function Roles filters">
    <div class="input-group input-group-sm me-auto" style="width:auto;position:relative;">
        <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input class="form-control"
               type="search"
               name="search"
               value="@Context.Request.Query["search"]"
               placeholder="Search by function or role..."
               aria-label="Search function roles"
               hx-get="@Url.Action("Index")"
               hx-target="#funcroles-table"
               hx-select="#funcroles-table"
               hx-indicator="#search-loader"
               hx-trigger="keyup[key=='Enter'], search"
               hx-push-url="true"
               form="none" />
        <span id="search-loader" class="htmx-indicator" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);z-index:10;">
            <div class="spinner-border spinner-border-sm text-primary" role="status" style="width:.85rem;height:.85rem;border-width:1.5px;"></div>
        </span>
    </div>
    <div class="filter-group">
        @if (PermissionHelper.HasActionAccess(Context, "FunctionRole", "Create"))
        {
            <a class="btn btn-primary btn-sm" asp-action="Create">
                <i class="fa-solid fa-plus me-1"></i>Assign Function
            </a>
        }
    </div>
</section>

<section class="table-shell" data-erp-table id="funcroles-table">
    <div class="erp-table-wrap">
        <table class="table table-hover erp-table">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Function / Page</th>
                    <th scope="col">Route</th>
                    <th scope="col">Role</th>
                    <th scope="col">Assigned On</th>
                    <th scope="col" class="text-end sticky-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var fr in Model)
                {
                    <tr>
                        <td data-label="#">@fr.Id</td>
                        <td data-label="Function / Page" class="fw-semibold">@fr.Function?.Name</td>
                        <td data-label="Route">
                            <code style="background:var(--erp-surface-subtle,#f3f4f6);padding:.15rem .45rem;border-radius:5px;font-size:.78rem;">@fr.Function?.route</code>
                        </td>
                        <td data-label="Role"><span class="status-badge status-active">@fr.Role?.Name</span></td>
                        <td data-label="Assigned On" class="text-muted">@fr.createat.ToString("dd MMM yyyy")</td>
                        <td data-label="Actions" class="text-end sticky-actions">
                            <div class="d-flex justify-content-end gap-1">
                                @if (PermissionHelper.HasActionAccess(Context, "FunctionRole", "Delete"))
                                {
                                    <form asp-action="Delete" asp-route-id="@fr.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Remove this function assignment?');">
                                        <button class="btn btn-icon btn-sm btn-icon-danger" type="submit" title="Remove">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5">
                            <div class="empty-state" data-table-empty>
                                <i class="fa-solid fa-key"></i>
                                <h3 class="h6 mt-2 mb-1">No function assignments found</h3>
                                <p class="text-muted mb-0">Click <strong>Assign Function</strong> to get started.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="table-footer">
        <span class="text-muted small fw-semibold">@Model.Count() assignments</span>
    </div>
</section>
