@model IPagedList<AlignHR.Models.OverTimeHours>
@using X.PagedList
@using X.PagedList.Mvc.Core

<table class="table table-hover erp-table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Employee</th>
            <th>Salary Period</th>
            <th>OT Hours</th>
            <th>Amount</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            foreach (var l in Model)
            {
                <tr>
                    <td>@l.id</td>
                    <td>
                        @(l.Employee?.FullName ?? "N/A")
                        @if (!string.IsNullOrEmpty(l.Employee?.Code))
                        {
                            <br /><small class="text-muted">Code: @l.Employee.Code</small>
                        }
                    </td>
                    <td>@(l.SalaryPeriod?.PeriodName ?? "N/A")</td>
                    <td>@l.OTHours</td>
                    <td>@l.Amount</td>
                    <td>
                        <div class="table-actions">
                            <a asp-action="Details" asp-route-id="@l.id" class="btn btn-icon btn-sm" title="View Details" style="background: #eff6ff; color: #3b82f6; border-color: #bfdbfe;">
                                <i class="fas fa-eye"></i>
                            </a>
                            @if (l.SalaryPeriod != null && l.SalaryPeriod.IsPostedToGL)
                            {
                                <div class="btn btn-icon btn-sm-locked" title="Locked: This period is posted to GL." style="display: flex; align-items: center; background: #f1f5f9; padding: 4px 10px; border-radius: 4px; border: 1px solid #e2e8f0; pointer-events: none;">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 14px; color: #64748b;">
                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                    </svg>
                                    <span style="font-size: 0.6rem; font-weight: 700; margin-left: 4px; color: #64748b;">LOCKED</span>
                                </div>
                            }
                            else
                            {
                                <a asp-action="Edit" asp-route-id="@l.id" class="btn btn-icon btn-sm" title="Edit">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                </a>

                                <form asp-action="Delete" asp-route-id="@l.id" method="post" style="display:inline;"
                                      onsubmit="return confirm('Are you sure you want to delete this record?');">
                                    <button class="btn btn-icon btn-sm text-danger" type="submit" title="Delete">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <polyline points="3 6 5 6 21 6" />
                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                        </svg>
                                    </button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center py-5 text-muted">
                    No records found.
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="pagination-wrapper mt-4">
    @Html.PagedListPager(Model, page => Url.Action("Index", new { page, search = ViewBag.Search }))
</div>
