@model AlignHR.Models.HrPipelineViewModel

@{
    ViewData["Title"] = "Pipeline — " + Model.JobCode;
    ViewBag.ActivePage = "HrJobPostings";
}

<section class="filter-bar mb-3">
    <div class="fw-semibold">@Model.JobCode — @Model.JobTitle</div>
    <div class="filter-group ms-auto">
        <a asp-action="Index" asp-route-jobPostingId="@Model.JobPostingId"
           class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-list me-1"></i>List View</a>
        <a asp-action="Create" asp-route-jobPostingId="@Model.JobPostingId"
           class="btn btn-primary btn-sm"><i class="fa-solid fa-plus me-1"></i>Add Application</a>
    </div>
</section>

<div class="d-flex gap-3 overflow-auto pb-3" style="align-items:flex-start;">
    @foreach (var stage in Model.Stages.Where(s => s.Applications.Any() || s.Order <= 5))
    {
        <div style="min-width:220px;max-width:240px;">
            <div class="card-inner mb-2 py-2 px-3 d-flex justify-content-between align-items-center">
                <span class="small fw-semibold">@stage.StageName</span>
                <span class="badge bg-secondary">@stage.Applications.Count</span>
            </div>
            @foreach (var app in stage.Applications)
            {
                <div class="card-inner mb-2 p-2">
                    <div class="fw-semibold small">@app.CandidateName</div>
                    <div class="text-muted" style="font-size:11px;">@app.CandidateEmail</div>
                    @if (app.TotalExperienceYears.HasValue)
                    {
                        <div class="text-muted" style="font-size:11px;">@($"{app.TotalExperienceYears:0.#} yrs exp")</div>
                    }
                    <div class="mt-2 d-flex gap-1">
                        <a asp-action="Details" asp-route-id="@app.Id"
                           class="btn btn-icon btn-sm btn-icon-primary" title="View">
                            <i class="fa-solid fa-eye"></i>
                        </a>
                        <a asp-action="MoveStage" asp-route-id="@app.Id"
                           class="btn btn-icon btn-sm btn-icon-warning" title="Move Stage">
                            <i class="fa-solid fa-arrows-up-down"></i>
                        </a>
                    </div>
                </div>
            }
            @if (!stage.Applications.Any())
            {
                <div class="card-inner py-3 text-center">
                    <span class="text-muted" style="font-size:11px;">Empty</span>
                </div>
            }
        </div>
    }
</div>
