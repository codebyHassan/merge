@model AlignHR.Models.AttendenceLogs
@{
    ViewData["Title"] = "Add Attendance Log";
    ViewBag.ActivePage = "AttendenceLogs";
}

<!-- Breadcrumb Area -->
<div class="breadcrumb-container animate-fade-in">
    <div class="breadcrumb-item">
        <i class="fas fa-home"></i>
        <a href="/">Home</a>
    </div>
    <div class="breadcrumb-separator"><i class="fas fa-chevron-right"></i></div>
    <div class="breadcrumb-item">
        <a asp-action="Index">Attendance Logs</a>
    </div>
    <div class="breadcrumb-separator"><i class="fas fa-chevron-right"></i></div>
    <div class="breadcrumb-item active">Add Log</div>
</div>

<!-- Main Content Card -->
<div class="form-shell">
    <div class="card-inner">
        <form asp-action="create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
            
            <div class="form-grid">
                <div class="form-item" style="position: relative; z-index: 1001;">
                    <label asp-for="EmployeeID" class="form-label">Employee <span class="required">*</span></label>
                    <div style="position: relative;">
                        <input type="text" id="employeeSearch" name="term" class="form-control" placeholder="Type name or code..." autocomplete="off"
                               hx-get="/Ajax/SearchEmployees"
                               hx-trigger="keyup delay:300ms, search"
                               hx-target="#employeeResults"
                               hx-indicator="#emp-loader" />
                        <span id="emp-loader" class="htmx-indicator" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%);">
                            <i class="fas fa-spinner fa-spin" style="color: #6366f1;"></i>
                        </span>
                    </div>
                    <div id="employeeResults" class="search-results-container"></div>
                    <input type="hidden" asp-for="EmployeeID" id="selectedEmployeeId" required />
                    <span asp-validation-for="EmployeeID" class="text-danger small"></span>
                    
                    <div id="employee-detail-card-container"></div>
                </div>

                <div class="form-item">
                    <label asp-for="AttendenceDate" class="form-label">Attendance Date <span class="required">*</span></label>
                    <input asp-for="AttendenceDate" type="date" class="form-control" required />
                    <span asp-validation-for="AttendenceDate" class="text-danger small"></span>
                </div>

                <div class="form-item">
                    <label asp-for="PunchTime" class="form-label">Punch Time <span class="required">*</span></label>
                    <input asp-for="PunchTime" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" class="form-control" required />
                    <span asp-validation-for="PunchTime" class="text-danger small"></span>
                </div>

                <div class="form-item">
                    <label asp-for="PunchType" class="form-label">Punch Type <span class="required">*</span></label>
                    <select asp-for="PunchType" class="form-control" asp-items="ViewBag.PunchTypes" required>
                        <option value="">-- Select Type --</option>
                    </select>
                    <span asp-validation-for="PunchType" class="text-danger small"></span>
                </div>

                <div class="form-item">
                    <label asp-for="Source" class="form-label">Source <span class="required">*</span></label>
                    <input asp-for="Source" class="form-control" placeholder="e.g., Web, Mobile, Biometric" required />
                    <span asp-validation-for="Source" class="text-danger small"></span>
                </div>

                <div class="form-item">
                    <label asp-for="Devicesd" class="form-label">Device Info</label>
                    <input asp-for="Devicesd" class="form-control" placeholder="e.g., iPhone 15, Office Terminal" />
                    <span asp-validation-for="Devicesd" class="text-danger small"></span>
                </div>

                <div class="form-item">
                    <label asp-for="latitude" class="form-label">Latitude</label>
                    <input asp-for="latitude" class="form-control" type="number" step="0.000001" value="0.000000" />
                    <span asp-validation-for="latitude" class="text-danger small"></span>
                </div>

                <div class="form-item">
                    <label asp-for="longitude" class="form-label">Longitude</label>
                    <input asp-for="longitude" class="form-control" type="number" step="0.000001" value="0.000000" />
                    <span asp-validation-for="longitude" class="text-danger small"></span>
                </div>

                <div class="form-item">
                    <label asp-for="shiftidFk" class="form-label">Assigned Shift</label>
                    <select asp-for="shiftidFk" class="form-control" asp-items="ViewBag.Shifts">
                        <option value="">-- Select Shift --</option>
                    </select>
                    <span asp-validation-for="shiftidFk" class="text-danger small"></span>
                </div>
            </div>

            <div class="form-actions-sticky">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back</a>
                <button type="submit" class="btn btn-primary btn-sm">Save Log Entry</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Clear hidden ID when user types
            const searchInput = document.getElementById('employeeSearch');
            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    const hiddenInput = document.getElementById('selectedEmployeeId');
                    if (hiddenInput) hiddenInput.value = '';
                });
            }

            // Handle Employee Selection
            document.body.addEventListener('click', function(e) {
                const row = e.target.closest('.search-result-item');
                if (row) {
                    const id = row.dataset.id;
                    const name = row.dataset.name;
                    const code = row.dataset.code;
                    
                    const hiddenInput = document.getElementById('selectedEmployeeId');
                    hiddenInput.value = id;
                    document.getElementById('employeeResults').innerHTML = '';
                    document.getElementById('employeeSearch').value = name + ' (' + code + ')';
                    
                    // Trigger HTMX to load employee details
                    htmx.ajax('GET', '/AttendenceLogs/GetEmployeeDetails', {
                        values: { EmployeeID: id },
                        target: '#employee-detail-card-container',
                        swap: 'innerHTML'
                    });
                }
            });

            // Close search results when clicking outside
            document.addEventListener('click', function(e) {
                if (!e.target.closest('#employeeSearch') && !e.target.closest('#employeeResults')) {
                    const results = document.getElementById('employeeResults');
                    if (results) results.innerHTML = '';
                }
            });
        });
    </script>
}
