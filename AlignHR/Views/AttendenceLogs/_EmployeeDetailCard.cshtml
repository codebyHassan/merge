@model AlignHR.Models.Employee

<div class="employee-card animate-slide-in">
    <div class="card-header">
        <div class="header-left">
            @if (!string.IsNullOrEmpty(Model.ProfileImage))
            {
                <img src="/uploads/employees/@Model.ProfileImage" class="detail-avatar" alt="@Model.FirstName" />
            }
            else
            {
                <div class="detail-avatar-placeholder">
                    @(Model.FirstName.Substring(0, 1) + Model.LastName.Substring(0, 1))
                </div>
            }
            <div class="header-main">
                <span class="employee-name">@Model.FirstName @Model.LastName</span>
                <span class="employee-code">#@Model.Code</span>
            </div>
        </div>
        <div class="employee-status @(Model.EmploymentStatus?.Name?.ToLower() ?? "unknown")">
            @(Model.EmploymentStatus?.Name ?? "N/A")
        </div>
    </div>
    <div class="card-body">
        <div class="info-item">
            <i class="fas fa-building"></i>
            <span class="info-label">Department:</span>
            <span class="info-value">@(Model.Department?.Name ?? "N/A")</span>
        </div>
        <div class="info-item">
            <i class="fas fa-map-marker-alt"></i>
            <span class="info-label">Location:</span>
            <span class="info-value">@(Model.Location?.Name ?? "N/A")</span>
        </div>
    </div>
</div>
