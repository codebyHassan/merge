@model IPagedList<AlignHR.Models.AttendenceLogs>
@using X.PagedList
@using X.PagedList.Mvc.Core
@using X.PagedList.Web.Common

@{
    ViewData["Title"] = "Attendance Logs";
    ViewBag.ActivePage = "AttendenceLogs";
}

<section class="filter-bar mb-2" aria-label="Attendance logs filters">
    <div class="input-group input-group-sm me-auto" style="width: auto; position: relative;">
        <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input class="form-control"
               type="search"
               name="search"
               value="@Context.Request.Query["search"]"
               placeholder="Search employee or source..."
               aria-label="Search records"
               hx-get="@Url.Action("Index")"
               hx-target="#table-container"
               hx-select="#table-container"
               hx-indicator="#search-loader"
               hx-trigger="keyup[key=='Enter'], search"
               hx-push-url="true"
               form="none" />
        <span id="search-loader" class="htmx-indicator" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); z-index: 10;">
            <div class="spinner-border spinner-border-sm text-primary" role="status" style="width: 0.85rem; height: 0.85rem; border-width: 1.5px;"></div>
        </span>
    </div>
    <div class="filter-group">
        <a class="btn btn-export-custom btn-sm" id="exportBtn" href="#">
            <i class="fa-solid fa-download me-1"></i>Export
        </a>
        <a class="btn btn-primary btn-sm" asp-action="create">
            <i class="fa-solid fa-plus me-1"></i>Mark Attendance
        </a>
    </div>
</section>

<section class="table-shell" data-erp-table id="table-container">
    <div class="erp-table-wrap">
        <table class="table table-hover erp-table">
            <thead>
                <tr>
                    <th scope="col"><button class="table-sort" type="button" data-sort="0">ID</button></th>
                    <th scope="col">Emp Code</th>
                    <th scope="col"><button class="table-sort" type="button" data-sort="2">Employee Name</button></th>
                    <th scope="col">Attendance Date</th>
                    <th scope="col">Punch Time</th>
                    <th scope="col">Type</th>
                    <th scope="col">Source</th>
                    <th scope="col">Device</th>
                    <th scope="col" class="text-end sticky-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in Model)
                {
                    <tr>
                        <td data-label="ID">@l.id</td>
                        <td data-label="Emp Code" class="fw-semibold">@(l.Employee?.Code ?? "—")</td>
                        <td data-label="Employee Name">@(l.Employee != null ? l.Employee.FirstName + " " + l.Employee.LastName : "Unknown Employee")</td>
                        <td data-label="Attendance Date">@l.AttendenceDate.ToString("MMM dd, yyyy")</td>
                        <td data-label="Punch Time">@l.PunchTime.ToString("HH:mm:ss")</td>
                        <td data-label="Type">
                            @{
                                var badgeClass = l.PunchType == AlignHR.Models.PunchType.In ? "status-badge approved" :
                                                 l.PunchType == AlignHR.Models.PunchType.Out ? "status-badge rejected" : "status-badge pending";
                            }
                            <span class="@badgeClass">
                                @l.PunchType?.ToString()
                            </span>
                        </td>
                        <td data-label="Source">@l.Source</td>
                        <td data-label="Device">@l.Devicesd</td>
                        <td data-label="Actions" class="text-end sticky-actions">
                            <div class="d-flex justify-content-end gap-1">
                                <a class="btn btn-icon btn-sm btn-icon-primary" asp-action="Edit" asp-route-id="@l.id" title="Edit">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@l.id" method="post" class="d-inline"
                                      onsubmit="return confirm('Are you sure you want to delete this log entry?');">
                                    <button class="btn btn-icon btn-sm btn-icon-danger" type="submit" title="Delete">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="empty-state" data-table-empty>
                <i class="fa-solid fa-inbox"></i>
                <h3 class="h6 mt-2 mb-1">No attendance logs found</h3>
                <p class="text-muted mb-0">Try adjusting your search or mark a new attendance entry.</p>
            </div>
        }
    </div>
    <div class="table-footer">
        <span class="text-muted small fw-semibold">Showing @Model.FirstItemOnPage–@Model.LastItemOnPage of @Model.TotalItemCount</span>
        <nav aria-label="Attendance logs pagination">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page, search = Context.Request.Query["search"] }), new PagedListRenderOptions
            {
                UlElementClasses = new[] { "pagination", "pagination-sm", "mb-0" },
                LiElementClasses = new[] { "page-item" },
                PageClasses      = new[] { "page-link" }
            })
        </nav>
    </div>
</section>
