@model IPagedList<AlignHR.Models.Shift>
@using X.PagedList
@using X.PagedList.Mvc.Core
@using X.PagedList.Web.Common
@{
    ViewData["Title"] = "Shifts";
    ViewBag.ActivePage = "Shift";
}

<section class="filter-bar mb-2" aria-label="Shifts filters">
    <div class="input-group input-group-sm me-auto" style="width: auto; position: relative;">
        <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input class="form-control"
               type="search"
               name="search"
               value="@Context.Request.Query["search"]"
               placeholder="Search shift..."
               aria-label="Search records"
               hx-get="@Url.Action("Index")"
               hx-target="#shift-index-page"
               hx-select="#shift-index-page"
               hx-indicator="#search-loader"
               hx-trigger="keyup[key=='Enter'], search"
               hx-include="[name='search'], [name='group']"
               hx-push-url="true"
               form="none" />
        <span id="search-loader" class="htmx-indicator" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); z-index: 10;">
            <div class="spinner-border spinner-border-sm text-primary" role="status" style="width: 0.85rem; height: 0.85rem; border-width: 1.5px;"></div>
        </span>
    </div>
    <div class="filter-group">
        <button class="btn btn-export-custom btn-sm" type="button"
                data-bs-toggle="collapse"
                data-bs-target="#advancedFiltersCollapse">
            <i class="fa-solid fa-filter me-1"></i>Advanced
        </button>
        <a class="btn btn-export-custom btn-sm" id="exportBtn" href="#">
            <i class="fa-solid fa-download me-1"></i>Export
        </a>
        <a class="btn btn-primary btn-sm" asp-action="create">
            <i class="fa-solid fa-plus me-1"></i>Add Shift
        </a>
    </div>
</section>

<div class="collapse @(Context.Request.Query["group"].ToString() != "" ? "show" : "")" id="advancedFiltersCollapse">
    <div class="card card-body mb-2 p-2" style="background: var(--erp-surface-subtle); border: 1px solid var(--erp-border);">
        <div class="row g-2">
            <div class="col-12 col-md-3">
                <label class="form-label small fw-semibold mb-1">Group</label>
                <select name="group" class="form-select form-select-sm"
                        hx-get="@Url.Action("Index")"
                        hx-target="#shift-index-page"
                        hx-select="#shift-index-page"
                        hx-trigger="change"
                        hx-include="[name='search'], [name='group']"
                        hx-push-url="true"
                        form="none">
                    <option value="">All Groups</option>
                    @foreach (var g in Enum.GetValues(typeof(AlignHR.Models.GroupName)).Cast<AlignHR.Models.GroupName>())
                    {
                        <option value="@g" selected="@(Context.Request.Query["group"].ToString() == g.ToString())">@g</option>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

<section class="table-shell" data-erp-table id="shift-index-page">
    <div class="erp-table-wrap">
        <table class="table table-hover erp-table">
            <thead>
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">Group</th>
                    <th scope="col">Start Time</th>
                    <th scope="col">End Time</th>
                    <th scope="col">Grace Time</th>
                    <th scope="col">Break Start</th>
                    <th scope="col">Break End</th>
                    <th scope="col">Night Shift</th>
                    <th scope="col" class="text-end sticky-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in Model)
                {
                    <tr>
                        <td data-label="Name">@l.ShiftName</td>
                        <td data-label="Group">
                            @if (l.GroupName != null)
                            {
                                var groupBadge = l.GroupName == AlignHR.Models.GroupName.Morning ? "badge-success" :
                                                 l.GroupName == AlignHR.Models.GroupName.Evening ? "badge-warning" : "badge-dark";
                                <span class="status-badge @groupBadge">@l.GroupName</span>
                            }
                            else
                            {
                                <span class="status-badge badge-secondary">—</span>
                            }
                        </td>
                        <td data-label="Start Time">@(l.StartTime?.ToString("HH:mm") ?? "—")</td>
                        <td data-label="End Time">@(l.EndTime?.ToString("HH:mm") ?? "—")</td>
                        <td data-label="Grace Time">@(l.GraceTime?.ToString("HH:mm") ?? "—")</td>
                        <td data-label="Break Start">@(l.BreakStartTime?.ToString("HH:mm") ?? "—")</td>
                        <td data-label="Break End">@(l.BreakEndTime?.ToString("HH:mm") ?? "—")</td>
                        <td data-label="Night Shift">
                            @if (l.IsNightShift == true)
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger px-2"><i class="fa-solid fa-moon me-1"></i>Night</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary bg-opacity-10 text-muted px-2"><i class="fa-solid fa-sun me-1"></i>Day</span>
                            }
                        </td>
                        <td data-label="Actions" class="text-end sticky-actions">
                            <div class="d-flex justify-content-end gap-1">
                                <a class="btn btn-icon btn-sm btn-icon-info" asp-action="Details" asp-route-id="@l.Id" title="Details"><i class="fa-solid fa-eye"></i></a>
                                <a class="btn btn-icon btn-sm btn-icon-primary" asp-action="Edit" asp-route-id="@l.Id" title="Edit"><i class="fa-solid fa-pen-to-square"></i></a>
                                <form asp-action="Delete" asp-route-id="@l.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this shift?');">
                                    <button class="btn btn-icon btn-sm btn-icon-danger" type="submit" title="Delete"><i class="fa-solid fa-trash-can"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="empty-state" data-table-empty>
                <i class="fa-solid fa-inbox"></i>
                <h3 class="h6 mt-2 mb-1">No shifts match the current filters</h3>
                <p class="text-muted mb-0">Try adjusting your search or group filter, or create a new shift.</p>
            </div>
        }
    </div>
    <div class="table-footer">
        <span class="text-muted small fw-semibold">Showing @Model.FirstItemOnPage–@Model.LastItemOnPage of @Model.TotalItemCount</span>
        <nav aria-label="Shifts pagination">
            @Html.PagedListPager(Model, page => Url.Action("Index", new {
                page,
                search = Context.Request.Query["search"],
                group   = Context.Request.Query["group"]
            }), new PagedListRenderOptions
            {
                UlElementClasses = new[] { "pagination", "pagination-sm", "mb-0" },
                LiElementClasses = new[] { "page-item" },
                PageClasses      = new[] { "page-link" }
            })
        </nav>
    </div>
</section>
