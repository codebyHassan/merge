@model AlignHR.Models.DocApprovalAssignment
@{
    ViewData["Title"] = "Delete Approval Assignment";
    ViewBag.ActivePage = "DocApprovalAssignment";
}

<div class="form-shell w-100">
    <div class="card-inner">
        <h5 class="text-danger mb-4">Delete Document Approval Assignment</h5>
        
        <div class="alert alert-warning">
            <h5>Warning!</h5>
            <p>Are you sure you want to delete this approval assignment? Future document uploads of this type by this user will not trigger any approval workflow unless a new assignment is created.</p>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12 col-md-6">
                <label class="form-label small fw-semibold">Target Employee</label>
                <div class="form-control form-control-sm bg-light">@(Model.User?.FirstName + " " + Model.User?.LastName)</div>
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label small fw-semibold">DMS Definition File</label>
                <div class="form-control form-control-sm bg-light">@Model.DmsDefinitionName</div>
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label small fw-semibold">Approval Template</label>
                <div class="form-control form-control-sm bg-light">@Model.ApprovalTemplate?.TemplateName</div>
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label small fw-semibold">Status</label>
                <div class="form-control form-control-sm bg-light">@(Model.IsActive ? "Active" : "Inactive")</div>
            </div>
            <div class="col-12">
                <label class="form-label small fw-semibold">Notes</label>
                <div class="form-control form-control-sm bg-light" style="min-height: 50px;">@Model.Notes</div>
            </div>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
                <button type="submit" class="btn btn-danger btn-sm">Delete Permanently</button>
            </div>
        </form>
    </div>
</div>
