@model AlignHR.Models.ApprovalTemplate
@{
    ViewData["Title"] = "Delete Approval Template";
    ViewBag.ActivePage = "ApprovalTemplate";
}

<div class="form-shell w-100">
    <div class="card-inner">
        <h5 class="text-danger mb-4">Delete Approval Template</h5>
        
        <div class="alert alert-warning">
            <h5>Warning!</h5>
            <p>Are you sure you want to delete this approval template? This action cannot be undone. All sequential steps defined within this template will also be deleted.</p>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12 col-md-6">
                <label class="form-label small fw-semibold">Template Name</label>
                <div class="form-control form-control-sm bg-light">@Model.TemplateName</div>
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label small fw-semibold">Status</label>
                <div class="form-control form-control-sm bg-light">@(Model.IsActive ? "Active" : "Inactive")</div>
            </div>
            <div class="col-12">
                <label class="form-label small fw-semibold">Description</label>
                <div class="form-control form-control-sm bg-light" style="min-height: 50px;">@Model.Description</div>
            </div>
        </div>

        <div class="mb-4">
            <h6 class="fw-semibold text-muted small text-uppercase">Defined Steps (@Model.Steps?.Count)</h6>
            <div class="table-responsive border rounded">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light text-muted small text-uppercase">
                        <tr>
                            <th class="fw-semibold px-3 py-2" style="width: 15%;">Step</th>
                            <th class="fw-semibold px-3 py-2" style="width: 45%;">Step Label / Description</th>
                            <th class="fw-semibold px-3 py-2" style="width: 40%;">Approver Role</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Steps != null)
                        {
                            var orderedSteps = Model.Steps.OrderBy(s => s.StepNo).ToList();
                            for (int i = 0; i < orderedSteps.Count; i++)
                            {
                                var step = orderedSteps[i];
                                <tr>
                                    <td class="px-3 py-2 fw-semibold">Step @(i + 1)</td>
                                    <td class="px-3 py-2">@step.StepLabel</td>
                                    <td class="px-3 py-2">@step.Role?.Name</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
                <button type="submit" class="btn btn-danger btn-sm">Delete Permanently</button>
            </div>
        </form>
    </div>
</div>
