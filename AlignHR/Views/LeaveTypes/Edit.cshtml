@model AlignHR.Models.LeaveType

@{
    ViewData["Title"] = "Edit Leave Type";
    ViewBag.ActivePage = "LeaveTypes";
}

<div class="form-shell w-100 animate-fade-in">
    <div class="card-inner">
        <form asp-action="Edit" method="post" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />
            <input type="hidden" asp-for="CreatedBy" />
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger p-2 mb-3 small" role="alert">
                    <div asp-validation-summary="ModelOnly"></div>
                </div>
            }

            <div class="row g-3">

                <!-- Row 1: Identity fields -->
                <div class="col-12 col-md-4">
                    <label asp-for="Name" class="form-label small fw-semibold">Leave Type Name <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control form-control-sm" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-12 col-md-3">
                    <label asp-for="Code" class="form-label small fw-semibold">Code <span class="text-danger">*</span></label>
                    <input asp-for="Code" class="form-control form-control-sm" required />
                    <span asp-validation-for="Code" class="text-danger small"></span>
                </div>
                <div class="col-12 col-md-3">
                    <label asp-for="ColorCode" class="form-label small fw-semibold">Display Color</label>
                    <div class="d-flex align-items-center gap-2">
                        <input asp-for="ColorCode" type="color" class="form-control form-control-sm"
                               style="width:38px;height:31px;padding:2px;cursor:pointer;" />
                        <input type="text" id="hxDisplay" class="form-control form-control-sm font-monospace"
                               value="@Model.ColorCode" readonly style="width:100px;" />
                    </div>
                    <div class="form-text">Used for calendars and reports.</div>
                </div>

                <!-- Row 2: Toggles -->
                <div class="col-12 col-md-4">
                    <label class="custom-toggle">
                        <input type="checkbox" name="IsPaid" value="true" @(Model.IsPaid ? "checked" : "") />
                        <div class="toggle-switch"></div>
                        <div class="toggle-content">
                            <div class="toggle-title">Paid Leave</div>
                            <div class="toggle-desc">Standard compensation applies during this leave.</div>
                        </div>
                    </label>
                </div>
                <div class="col-12 col-md-4">
                    <label class="custom-toggle">
                        <input type="checkbox" name="RequiresAttachment" value="true" @(Model.RequiresAttachment ? "checked" : "") />
                        <div class="toggle-switch"></div>
                        <div class="toggle-content">
                            <div class="toggle-title">Requires Documentation</div>
                            <div class="toggle-desc">Employee must attach proof (e.g. medical certificate).</div>
                        </div>
                    </label>
                </div>
                <div class="col-12 col-md-4">
                    <label class="custom-toggle">
                        <input type="checkbox" name="IsActive" value="true" @(Model.IsActive ? "checked" : "") />
                        <div class="toggle-switch"></div>
                        <div class="toggle-content">
                            <div class="toggle-title">Active</div>
                            <div class="toggle-desc">Visible and selectable in the employee portal.</div>
                        </div>
                    </label>
                </div>

            </div>

            <div class="row mt-4">
                <div class="col-12 d-flex justify-content-end gap-2">
                    <span class="text-muted small me-auto align-self-center">
                        ID #@Model.Id &middot; Created @Model.CreatedAt.ToString("MMM dd, yyyy")
                    </span>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-floppy-disk me-1"></i>Save Changes
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var colorInput = document.getElementById('ColorCode');
        if (colorInput) {
            colorInput.addEventListener('input', function () {
                document.getElementById('hxDisplay').value = this.value;
            });
        }
    </script>
}
