@model IEnumerable<AlignHR.Models.Employee>

@if (Model != null && Model.Any())
{
    foreach (var emp in Model)
    {
        <div class="search-result-item" 
             data-id="@emp.Id" 
             data-name="@emp.FullName" 
             data-code="@emp.Code"
             data-image="@emp.ProfileImage"
             data-dept="@(emp.Department?.Name ?? "No Dept")"
             data-subdept="@(emp.SubDepartment?.Name ?? "N/A")"
             data-grade="@(emp.Grade?.Name ?? "N/A")"
             data-division="@(emp.Division?.Name ?? "N/A")"
             data-designation="@(emp.Designation?.Name ?? "N/A")"
             data-emptype="@(emp.EmploymentType?.Name ?? "N/A")"
             data-empstatus="@(emp.EmploymentStatus?.Name ?? "N/A")"
             data-doj="@emp.Dateofjoin.ToString("yyyy-MM-dd")"
             data-location="@(emp.Location?.Name ?? "N/A")"
             data-status="@emp.SalaryStatus">
            <div class="item-info">
                <div class="item-name">@emp.FullName</div>
                <div class="item-meta">
                    <span class="badge-code">@emp.Code</span>
                    <span class="text-muted">@(emp.Department?.Name ?? "No Dept")</span>
                </div>
            </div>
            <div class="item-action">
                <i class="fas fa-plus-circle"></i>
            </div>
        </div>
    }
}
else
{
    <div class="search-empty">
        <i class="fas fa-user-slash mb-2 d-block" style="font-size: 24px; opacity: 0.5;"></i>
        No employees found matching your search.
    </div>
}
