@{
    ViewData["Title"] = "Reports";
    ViewBag.ActivePage = "Reports";
}

<div class="page-header"><div class="breadcrumb"><a href="#">Home</a><span>/</span><span>Reports</span></div><div class="page-header-row"><div><h1 class="page-title">Reports &amp; Analytics</h1><p class="page-subtitle">Generate and download detailed reports</p></div></div></div>

<div class="report-grid">
    <div class="report-card"><div class="report-icon" style="background:rgba(59,130,246,0.1);color:#3B82F6"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="12" width="4" height="9" rx="1"/><rect x="10" y="7" width="4" height="14" rx="1"/><rect x="17" y="3" width="4" height="18" rx="1"/></svg></div><h3>Attendance Report</h3><p>Daily, weekly &amp; monthly summaries</p><button class="btn btn-primary btn-sm" style="margin-top:16px">Generate</button></div>
    <div class="report-card"><div class="report-icon" style="background:rgba(16,185,129,0.1);color:var(--green)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div><h3>Payroll Report</h3><p>Salary disbursement &amp; deductions</p><button class="btn btn-primary btn-sm" style="margin-top:16px">Generate</button></div>
    <div class="report-card"><div class="report-icon" style="background:rgba(139,92,246,0.1);color:var(--purple)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></div><h3>Performance Report</h3><p>Employee productivity &amp; metrics</p><button class="btn btn-primary btn-sm" style="margin-top:16px">Generate</button></div>
</div>

<div class="charts-grid" style="margin-top:28px">
    <div class="chart-card">
        <div class="chart-card-header"><div><div class="chart-card-title">Analytics Overview</div></div></div>
        <div class="chart-container" style="height:280px"><canvas id="reportChart"></canvas></div>
    </div>
    <div class="chart-card">
        <div class="chart-card-header"><div><div class="chart-card-title">Quick Export</div></div></div>
        <div style="padding:20px;display:flex;flex-direction:column;gap:12px">
            <button class="btn btn-secondary" style="width:100%;justify-content:center">Export as Excel</button>
            <button class="btn btn-secondary" style="width:100%;justify-content:center">Export as PDF</button>
            <button class="btn btn-secondary" style="width:100%;justify-content:center">Export as CSV</button>
        </div>
    </div>
</div>
