@model AlignHR.Models.TaxSlabMaster
@{
    ViewData["Title"] = "Create Tax Slab";
    ViewBag.ActivePage = "TaxSlabMaster";
}

<div class="form-shell w-100">
    <div class="card-inner">
        <form asp-action="Create" method="post" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label class="form-label small fw-semibold" asp-for="FiscalFK">Financial Year <span class="text-danger">*</span></label>
                    <select asp-for="FiscalFK" class="form-select form-select-sm" required asp-items="@(new SelectList(ViewBag.FiscalYears, "id", "title"))">
                        <option value="">-- Select Financial Year --</option>
                    </select>
                    <span asp-validation-for="FiscalFK" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label small fw-semibold" asp-for="IncomeFrom">Annual Income From <span class="text-danger">*</span></label>
                    <input asp-for="IncomeFrom" class="form-control form-control-sm" placeholder="Ex : 600,000" step="0.01" required />
                    <span asp-validation-for="IncomeFrom" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label small fw-semibold" asp-for="IncomeTo">Annual Income To</label>
                    <input asp-for="IncomeTo" class="form-control form-control-sm" placeholder="Ex : 900,000" step="0.01" />
                    <span asp-validation-for="IncomeTo" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label small fw-semibold" asp-for="FixedTax">Fixed Tax Amount</label>
                    <input asp-for="FixedTax" class="form-control form-control-sm" placeholder="Ex: 10,000.00" step="0.01" />
                    <span asp-validation-for="FixedTax" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label small fw-semibold" asp-for="RatePercent">Tax Rate % <span class="text-danger">*</span></label>
                    <input asp-for="RatePercent" class="form-control form-control-sm" placeholder="Ex: 5.00" step="0.01" required />
                    <span asp-validation-for="RatePercent" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4 d-flex align-items-end">
                    <div class="form-check form-switch mb-2">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                        <label class="form-check-label small fw-semibold" asp-for="IsActive">Is Active</label>
                    </div>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-12 d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back</a>
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </div>
            </div>
        </form>
    </div>
</div>
