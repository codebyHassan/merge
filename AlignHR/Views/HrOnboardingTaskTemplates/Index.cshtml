@model IList<AlignHR.Models.HrTaskTemplateListItemViewModel>

@{
    ViewData["Title"] = "Onboarding Task Templates";
    ViewBag.ActivePage = "HrOnboardingTaskTemplates";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2 small">
        @TempData["Success"]<button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-end mb-2">
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="fa-solid fa-plus me-1"></i>New Template
    </a>
</div>

<section class="table-shell" data-erp-table>
    <div class="erp-table-wrap">
        <table class="table table-hover erp-table">
            <thead>
                <tr>
                    <th>Task Name</th>
                    <th>Responsible Dept</th>
                    <th>Mandatory</th>
                    <th>Active</th>
                    <th class="text-end sticky-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model)
                {
                    <tr>
                        <td class="fw-semibold">@t.TaskName</td>
                        <td>@t.ResponsibleDepartment</td>
                        <td>@(t.IsMandatory ? "<span class='status-badge badge-warning'>Yes</span>" : "<span class='text-muted small'>No</span>")</td>
                        <td>@(t.IsActive ? "<span class='status-badge badge-success'>Active</span>" : "<span class='status-badge badge-danger'>Inactive</span>")</td>
                        <td class="text-end sticky-actions">
                            <a asp-action="Edit" asp-route-id="@t.Id"
                               class="btn btn-icon btn-sm btn-icon-primary" title="Edit">
                                <i class="fa-solid fa-pen"></i>
                            </a>
                            @if (t.IsActive)
                            {
                                <form asp-action="Deactivate" asp-route-id="@t.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Deactivate this template?');">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-icon btn-sm btn-icon-danger" title="Deactivate">
                                        <i class="fa-solid fa-ban"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="empty-state" data-table-empty>
                <i class="fa-solid fa-list-check"></i>
                <h3 class="h6 mt-2 mb-1">No task templates</h3>
                <p class="text-muted mb-0">Create templates to auto-populate onboarding checklists.</p>
            </div>
        }
    </div>
</section>
